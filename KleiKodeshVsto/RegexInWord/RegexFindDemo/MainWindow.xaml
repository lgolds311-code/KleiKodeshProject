<Window x:Class="RegexFindDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RegexFind Demo"
        Width="320"
        Height="450"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI"
        Background="#FFFFFF">

    <!-- Host the RegexFindView directly as a WPF UserControl.
         In production it lives inside a WindowsFormsHost inside a VSTO task pane,
         but for debugging the UI we can host it directly in a WPF window. -->
    <Border x:Name="ViewHost"
            BorderThickness="0"/>

</Window>
