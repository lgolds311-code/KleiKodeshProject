<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Root theme dictionary — merges all sub-dictionaries.
        Add new theme files here; keep each file under 200 lines.
        NOTE: Pack URI paths must be all-lowercase (WPF BAML compiler lowercases them).
    -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/RegexFindLib;component/ui/themes/icons.xaml"/>
        <ResourceDictionary Source="/RegexFindLib;component/ui/themes/brushes.xaml"/>
        <ResourceDictionary Source="/RegexFindLib;component/ui/themes/buttonstyles.xaml"/>
        <ResourceDictionary Source="/RegexFindLib;component/ui/themes/formattoggle.xaml"/>
        <ResourceDictionary Source="/RegexFindLib;component/ui/themes/comboboxstyles.xaml"/>
        <ResourceDictionary Source="/RegexFindLib;component/ui/themes/miscstyles.xaml"/>
        <ResourceDictionary Source="/RegexFindLib;component/ui/themes/palettestyles.xaml"/>
        <ResourceDictionary Source="/RegexFindLib;component/ui/themes/colorpickerstyles.xaml"/>
        <ResourceDictionary Source="/RegexFindLib;component/ui/themes/formatoptionsrowstyles.xaml"/>
        <ResourceDictionary Source="/RegexFindLib;component/ui/themes/spinnertextboxstyles.xaml"/>
    </ResourceDictionary.MergedDictionaries>
</ResourceDictionary>
