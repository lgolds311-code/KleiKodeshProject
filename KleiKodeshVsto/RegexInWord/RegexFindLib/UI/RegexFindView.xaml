<UserControl x:Class="RegexFindLib.UI.RegexFindView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RegexFindLib.UI"
             mc:Ignorable="d"
             MinWidth="280"
             d:Height="450"
             d:Width="350"
             FlowDirection="RightToLeft"
             FontFamily="Segoe UI"
             FontSize="13"
             Background="White">
    <!--
        IMPORTANT: Background must be set (not Transparent or null) for ComboBox dropdown popups to work correctly.
        The ElementHost will override this with the Office theme color at runtime.
        If Background is null/Transparent, ComboBox dropdown popups will have black background.
    -->

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RegexFindLib;component/ui/RegexFindDictionary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:BoolToVisibilityConverter        x:Key="BoolToVis"/>
            <local:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
            <local:BoolToFlowDirectionConverter     x:Key="BoolToFlowDir"/>
            <local:IntToVisibilityConverter         x:Key="IntToVis"/>

            <!-- History item template — plain row matching OfficeComboItem style -->
            <DataTemplate x:Key="HistoryItemTemplate">
                <TextBlock Text="{Binding}"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"/>
            </DataTemplate>

            <!-- History list item container — hover + click matching OfficeComboItem -->
            <Style x:Key="HistoryItemContainerStyle" TargetType="ListBoxItem">
                <Setter Property="Padding"         Value="8,5"/>
                <Setter Property="FontFamily"      Value="Segoe UI"/>
                <Setter Property="FontSize"        Value="12"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="Bd" Background="Transparent"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#0A808080"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <!--
        Layout mirrors the HTML exactly:
          #title-bar      — flex-row: [החלפה toggle] [mode+slop] [help icon]
          #search-find-container   — input-wrapper + options-row + font-style-row
          #search-replace-container (hidden by default)
          #results-container       — regex-palette OR results list
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- title-bar -->
            <RowDefinition Height="Auto"/>   <!-- find container -->
            <RowDefinition Height="Auto"/>   <!-- replace container -->
            <RowDefinition Height="*"/>      <!-- results -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             TITLE BAR
             #title-bar: flex-wrap, space-between, secondary-bg, border-bottom
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BgSecBrush}"
                BorderBrush="{StaticResource BorderStrong}"
                BorderThickness="0,0,0,1"
                Padding="6,3">
            <DockPanel LastChildFill="False">

                <!-- LEFT side (RTL: Dock=Right) — החלפה + regex tips + engine toggle -->
                <ToggleButton DockPanel.Dock="Right"
                              Style="{StaticResource IconToggle}"
                              IsChecked="{Binding ShowReplace}"
                              Height="Auto" Width="Auto" Padding="8,4"
                              ToolTip="החלפה">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource Icon.ReplaceAll}"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              Stretch="Uniform" FlowDirection="LeftToRight"
                              Width="14" Height="14" Margin="0,0,4,0"/>
                        <TextBlock Text="החלפה" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>

                <ToggleButton DockPanel.Dock="Right"
                              Style="{StaticResource IconToggle}"
                              IsChecked="{Binding ShowRegexPalette}"
                              ToolTip="לוח תווי רג'קס">
                    <Path Data="{StaticResource Icon.Sparkle}"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                          Stretch="Uniform" FlowDirection="LeftToRight"
                          Width="16" Height="16"/>
                </ToggleButton>

                <!-- Engine toggle — switches between custom regex engine and Word native search -->
                <ToggleButton DockPanel.Dock="Right"
                              Style="{StaticResource IconToggle}"
                              IsChecked="{Binding UseWordSearch}"
                              Height="Auto" Width="Auto" Padding="8,4"
                              ToolTip="חיפוש מובנה של Word">
                    <Grid Width="16" Height="16">
                        <!-- Unchecked state: dim normal W -->
                        <TextBlock Text="W" FontSize="13" FontWeight="Normal"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Opacity" Value="0.55"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UseWordSearch}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!-- Checked state: bold accent W -->
                        <TextBlock Text="W" FontSize="13" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{StaticResource AccentBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UseWordSearch}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </ToggleButton>

                <!-- RIGHT side (RTL: Dock=Left) — mode select + מרחק -->
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <ComboBox ItemsSource="{Binding SearchModesBinding}"
                              SelectedIndex="{Binding SearchModeIndex}"
                              IsEditable="False"
                              Width="90" Height="24" FontSize="12"
                              Padding="6,0,4,0"
                              ToolTip="כיוון החיפוש"/>
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding ShowReplace, Converter={StaticResource InvBoolToVis}}">
                        <!--<TextBlock Text="מרחק:" VerticalAlignment="Center"
                                   FontSize="12" Margin="5,0,3,0"
                                   Foreground="{StaticResource TextSecBrush}"/>
                        <controls:UpDownTextBox
                                 xmlns:controls="clr-namespace:WpfLib.Controls;assembly=WpfLib"
                                 Value="{Binding Slop, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Step="1" Width="38" Height="24" FontSize="12"
                                 ToolTip="מרחק בין מילים (מקשי ↑↓)"/>-->
                    </StackPanel>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             FIND CONTAINER  (#search-find-container)
        ══════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="1" Margin="10,8,10,0">

            <!-- input-wrapper: [regex .*] [text fills] [🔍] — LTR DockPanel, absolute dock positions -->
            <Border x:Name="FindInputBorder" CornerRadius="4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Background="Transparent" Height="28" Margin="0,0,0,5">
                <DockPanel FlowDirection="LeftToRight">
                    <!-- 🔍 search icon — LEFT side -->
                    <Button DockPanel.Dock="Left"
                            Style="{StaticResource InputIconButton}"
                            Command="{Binding SearchCommand}"
                            ToolTip="חיפוש">
                        <Path Data="{StaticResource Icon.Search}"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              Stretch="Uniform" FlowDirection="LeftToRight"
                              Width="16" Height="16"/>
                    </Button>
                    <!-- .* regex toggle — LEFT side of the input (HTML: left of text) -->
                    <ToggleButton DockPanel.Dock="Left"
                                  Style="{StaticResource InputIconToggle}"
                                  IsChecked="{Binding UseRegex}"
                                  ToolTip="{Binding WildcardTooltip}">
                        <Path Data="{StaticResource Icon.Regex}"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              Stretch="Uniform" FlowDirection="LeftToRight"
                              Width="16" Height="16"/>
                    </ToggleButton>
                    <!-- history dropdown button — must be docked BEFORE the fill TextBox -->
                    <Button DockPanel.Dock="Right"
                            x:Name="FindHistoryBtn"
                            Style="{StaticResource InputIconButton}"
                            Click="FindHistoryBtn_Click"
                            ToolTip="היסטוריית חיפוש">
                        <Path Data="M4 6L8 10L12 6"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              StrokeThickness="1.5" StrokeLineJoin="Round"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Width="10" Height="6" Stretch="Uniform"
                              FlowDirection="LeftToRight"/>
                    </Button>
                    <!-- text fills remaining space -->
                    <TextBox x:Name="FindBox"
                             Style="{StaticResource SearchTextBox}"
                             FlowDirection="RightToLeft"
                             Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             local:PlaceholderBehavior.Placeholder="חיפוש..."
                             GotFocus="FindBox_GotFocus"
                             KeyDown="FindBox_KeyDown">
                        <TextBox.ToolTip>
                            <ToolTip>
                                <StackPanel>
                                    <TextBlock Text="חיפוש" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="Enter — תוצאה הבאה"/>
                                    <TextBlock Text="Shift+Enter — תוצאה הקודמת"/>
                                </StackPanel>
                            </ToolTip>
                        </TextBox.ToolTip>
                    </TextBox>
                </DockPanel>
            </Border>

            <!-- find history popup -->
            <Popup x:Name="FindHistoryPopup"
                   PlacementTarget="{Binding ElementName=FindInputBorder}"
                   Placement="Bottom" StaysOpen="False" AllowsTransparency="False"
                   DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <Border Background="{Binding Background, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        BorderBrush="#50808080" BorderThickness="1"
                        MinWidth="{Binding ActualWidth, ElementName=FindInputBorder}"
                        MaxHeight="220">
                    <ListBox ItemsSource="{Binding RecentSearchesBinding}"
                             SelectedItem="{Binding SelectedSearchHistory, Mode=TwoWay}"
                             ItemTemplate="{StaticResource HistoryItemTemplate}"
                             ItemContainerStyle="{StaticResource HistoryItemContainerStyle}"
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="FindHistoryList_SelectionChanged"
                             Margin="0,2"/>
                </Border>
            </Popup>

            <!-- find-options-wrapper: font-size | B I U x² x₂ | A(color) | clear | copy -->
            <local:FormatOptionsRow
                FontSizeValue="{Binding FindFormatting.FontSize, Mode=TwoWay}"
                Bold="{Binding FindFormatting.Bold, Mode=TwoWay}"
                Italic="{Binding FindFormatting.Italic, Mode=TwoWay}"
                Underline="{Binding FindFormatting.Underline, Mode=TwoWay}"
                Superscript="{Binding FindFormatting.Superscript, Mode=TwoWay}"
                Subscript="{Binding FindFormatting.Subscript, Mode=TwoWay}"
                TextColor="{Binding FindFormatting.TextColor, Mode=TwoWay}"
                TextColorWordDecimal="{Binding FindFormatting.TextColorWordDecimal, Mode=TwoWay}"
                ClearCommand="{Binding ClearFindFormattingCommand}"
                CopyCommand="{Binding CopyFindFormattingCommand}"
                Margin="0,0,0,5"/>

            <!-- find-font-style-wrapper: [style combobox] [font combobox] -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding StyleList}"
                          Text="{Binding FindFormatting.StyleName, UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="True" Height="26" FontSize="12"
                          VirtualizingPanel.IsVirtualizing="True"
                          local:PlaceholderBehavior.Placeholder="בחר סגנון"
                          ToolTip="בחר סגנון"/>
                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding FontListBinding}"
                          Text="{Binding FindFormatting.FontName, UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="True" Height="26" FontSize="12"
                          local:PlaceholderBehavior.Placeholder="בחר גופן"
                          ToolTip="בחר גופן">
                    <ComboBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ComboBox.ItemsPanel>
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2,1" FlowDirection="LeftToRight">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Preview}" FontSize="11"
                                           Opacity="0.6" Margin="0,0,8,0"
                                           FontFamily="{Binding Name}"
                                           FlowDirection="{Binding IsHebrew, Converter={StaticResource BoolToFlowDir}}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12"
                                           FontWeight="Medium" TextAlignment="Right"/>
                            </Grid>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

        </StackPanel>

        <!-- ══════════════════════════════════════════════════════════
             REPLACE CONTAINER (#search-replace-container)
             Hidden by default; shown when ShowReplace = true
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource BgSecBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,8,10,8"
                Visibility="{Binding ShowReplace,
                    Converter={StaticResource BoolToVis}}">
            <StackPanel>

                <!-- input-wrapper: [replace icon] [replace-all icon] [text] -->
                <Border x:Name="ReplaceInputBorder" CornerRadius="4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Background="Transparent" Height="28" Margin="0,0,0,5">
                    <DockPanel FlowDirection="LeftToRight">
                        <!-- replace icon — docks Left → appears on LEFT (LTR) = RIGHT in RTL UI -->
                        <Button DockPanel.Dock="Left"
                                Style="{StaticResource InputIconButton}"
                                Command="{Binding ReplaceCommand}"
                                ToolTip="החלף">
                            <Path Data="{StaticResource Icon.Replace}"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  Stretch="Uniform" FlowDirection="LeftToRight"
                                  Width="16" Height="16"/>
                        </Button>
                        <!-- replace-all icon -->
                        <Button DockPanel.Dock="Left"
                                Style="{StaticResource InputIconButton}"
                                Command="{Binding ReplaceAllCommand}"
                                ToolTip="החלף הכל">
                            <Path Data="{StaticResource Icon.ReplaceAll}"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  Stretch="Uniform" FlowDirection="LeftToRight"
                                  Width="16" Height="16"/>
                        </Button>
                        <!-- history dropdown button — must be docked BEFORE the fill TextBox -->
                        <Button DockPanel.Dock="Right"
                                x:Name="ReplaceHistoryBtn"
                                Style="{StaticResource InputIconButton}"
                                Click="ReplaceHistoryBtn_Click"
                                ToolTip="היסטוריית החלפה">
                            <Path Data="M4 6L8 10L12 6"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  StrokeThickness="1.5" StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Width="10" Height="6" Stretch="Uniform"
                                  FlowDirection="LeftToRight"/>
                        </Button>
                        <!-- replace text fills remaining space -->
                        <TextBox x:Name="ReplaceBox"
                                 Style="{StaticResource SearchTextBox}"
                                 FlowDirection="RightToLeft"
                                 Text="{Binding ReplaceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 local:PlaceholderBehavior.Placeholder="החלף ב..."
                                 ToolTip="החלף ב..."
                                 GotFocus="ReplaceBox_GotFocus"
                                 KeyDown="ReplaceBox_KeyDown"/>
                    </DockPanel>
                </Border>

                <!-- replace history popup -->
                <Popup x:Name="ReplaceHistoryPopup"
                       PlacementTarget="{Binding ElementName=ReplaceInputBorder}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="False"
                       DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <Border Background="{Binding Background, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            BorderBrush="#50808080" BorderThickness="1"
                            MinWidth="{Binding ActualWidth, ElementName=ReplaceInputBorder}"
                            MaxHeight="220">
                        <ListBox ItemsSource="{Binding RecentReplacementsBinding}"
                                 SelectedItem="{Binding SelectedReplaceHistory, Mode=TwoWay}"
                                 ItemTemplate="{StaticResource HistoryItemTemplate}"
                                 ItemContainerStyle="{StaticResource HistoryItemContainerStyle}"
                                 BorderThickness="0" Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="ReplaceHistoryList_SelectionChanged"
                                 Margin="0,2"/>
                    </Border>
                </Popup>

                <!-- replace-options-wrapper -->
                <local:FormatOptionsRow
                    FontSizeValue="{Binding ReplaceFormatting.FontSize, Mode=TwoWay}"
                    Bold="{Binding ReplaceFormatting.Bold, Mode=TwoWay}"
                    Italic="{Binding ReplaceFormatting.Italic, Mode=TwoWay}"
                    Underline="{Binding ReplaceFormatting.Underline, Mode=TwoWay}"
                    Superscript="{Binding ReplaceFormatting.Superscript, Mode=TwoWay}"
                    Subscript="{Binding ReplaceFormatting.Subscript, Mode=TwoWay}"
                    TextColor="{Binding ReplaceFormatting.TextColor, Mode=TwoWay}"
                    TextColorWordDecimal="{Binding ReplaceFormatting.TextColorWordDecimal, Mode=TwoWay}"
                    ClearCommand="{Binding ClearReplaceFormattingCommand}"
                    CopyCommand="{Binding CopyReplaceFormattingCommand}"
                    Margin="0,0,0,5"/>

                <!-- replace-font-style-wrapper -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding StyleList}"
                              Text="{Binding ReplaceFormatting.StyleName, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True" Height="26" FontSize="12"
                              VirtualizingPanel.IsVirtualizing="True"
                              local:PlaceholderBehavior.Placeholder="בחר סגנון"
                              ToolTip="בחר סגנון"/>
                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding FontListBinding}"
                              Text="{Binding ReplaceFormatting.FontName, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True" Height="26" FontSize="12"
                              local:PlaceholderBehavior.Placeholder="בחר גופן"
                              ToolTip="בחר גופן">
                        <ComboBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel/>
                            </ItemsPanelTemplate>
                        </ComboBox.ItemsPanel>
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2,1" FlowDirection="LeftToRight">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Preview}" FontSize="11"
                                               Opacity="0.6" Margin="0,0,8,0"
                                               FontFamily="{Binding Name}"
                                               FlowDirection="{Binding IsHebrew, Converter={StaticResource BoolToFlowDir}}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12"
                                               FontWeight="Medium" TextAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             RESULTS CONTAINER (#results-container)
             Fills remaining space. Shows regex palette OR results list.
        ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="3">

            <!-- Regex palette (help toggle on) -->
            <local:RegexPalettePanel
                x:Name="RegexPalette"
                Tips="{Binding PaletteTips}"
                Background="{StaticResource BgSecBrush}"
                Visibility="{Binding ShowRegexPalette,
                    Converter={StaticResource BoolToVis}}"/>

            <!-- Search results list (help toggle off) -->
            <Border Background="{StaticResource BgSecBrush}"
                    Visibility="{Binding ShowRegexPalette,
                        Converter={StaticResource InvBoolToVis}}">
                <Grid>
                    <!-- No-results message — shown when search ran but found nothing -->
                    <TextBlock Text="לא נמצאו תוצאות התואמות לחיפוש"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecBrush}"
                               FontStyle="Italic"
                               FontSize="12"
                               Padding="20"
                               Visibility="{Binding NoResults,
                                   Converter={StaticResource BoolToVis}}"/>

                    <!-- Results list -->
                    <ListBox x:Name="ResultsList"
                             ItemsSource="{Binding Results}"
                             SelectedIndex="{Binding SelectedResultIndex}"
                             ItemContainerStyle="{StaticResource ResultItem}"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="5,3"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             KeyDown="ResultsList_KeyDown"
                             SelectionChanged="ResultsList_SelectionChanged"
                             Visibility="{Binding NoResults,
                                 Converter={StaticResource InvBoolToVis}}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <local:SnippetBlock Snippet="{Binding}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

        </Grid>

    </Grid>
</UserControl>
