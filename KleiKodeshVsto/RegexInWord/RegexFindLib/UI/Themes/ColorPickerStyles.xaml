<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:RegexFindLib.UI">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/RegexFindLib;component/ui/themes/icons.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <local:ColorToBrushConverter x:Key="ColorToBrush"/>

    <!-- ── Swatch DataTemplate (ThemeColors + StandardColors) ──────────── -->
    <DataTemplate x:Key="SwatchTemplate" DataType="{x:Type local:WordColor}">
        <Border Width="18" Height="18" Margin="1"
                Cursor="Hand"
                ToolTip="{Binding Name}"
                Background="{Binding WpfColor, Converter={StaticResource ColorToBrush}}"
                BorderThickness="0.5">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="#50808080"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush"     Value="#0078D4"/>
                            <Setter Property="BorderThickness" Value="2"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick"
                              Command="{Binding SelectColorCommand,
                                  RelativeSource={RelativeSource AncestorType=local:ColorPickerButton}}"
                              CommandParameter="{Binding}"/>
            </Border.InputBindings>
        </Border>
    </DataTemplate>

    <!-- ── ColorPickerButton ─────────────────────────────────────────────── -->
    <Style TargetType="local:ColorPickerButton">
        <Setter Property="Width"  Value="26"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:ColorPickerButton">
                    <Grid>

                        <!-- Trigger button -->
                        <Button x:Name="PART_Button"
                                Width="26" Height="26"
                                Padding="0" BorderThickness="0"
                                Background="Transparent" Cursor="Hand"
                                ToolTip="{TemplateBinding ToolTip}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd"
                                            SnapsToDevicePixels="True"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="4" Padding="3">
                                        <Grid>
                                            <Path Data="{StaticResource Icon.ColorPalette}"
                                                  Fill="{Binding Foreground,
                                                      RelativeSource={RelativeSource AncestorType=local:ColorPickerButton}}"
                                                  Stretch="Uniform" FlowDirection="LeftToRight"
                                                  Width="16" Height="16" Margin="0,0,0,3"/>
                                            <!-- Color underline bar -->
                                            <Border Height="3"
                                                    VerticalAlignment="Bottom"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="2,0,2,0"
                                                    Background="{Binding SwatchBrush,
                                                        RelativeSource={RelativeSource AncestorType=local:ColorPickerButton}}"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#0A808080"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#14808080"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Popup -->
                        <Popup x:Name="PART_Popup"
                               PlacementTarget="{Binding ElementName=PART_Button}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="False">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="#50808080" BorderThickness="1"
                                    MinWidth="220" Padding="6">
                                <StackPanel>

                                    <!-- Auto / No color -->
                                    <UniformGrid Columns="2" Margin="0,0,0,4">
                                        <Border Height="28" Cursor="Hand" Margin="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#0A808080"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding SelectAutoColorCommand,
                                                                  RelativeSource={RelativeSource AncestorType=local:ColorPickerButton}}"/>
                                            </Border.InputBindings>
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <Border Width="14" Height="14" Margin="0,0,5,0"
                                                        BorderBrush="#50808080" BorderThickness="1"
                                                        Background="Black"/>
                                                <TextBlock Text="אוטומטי"
                                                           VerticalAlignment="Center"
                                                           FontSize="12"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Height="28" Cursor="Hand" Margin="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#0A808080"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding SelectNoColorCommand,
                                                                  RelativeSource={RelativeSource AncestorType=local:ColorPickerButton}}"/>
                                            </Border.InputBindings>
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <Border Width="14" Height="14" Margin="0,0,5,0"
                                                        BorderBrush="#50808080" BorderThickness="1"
                                                        Background="White"/>
                                                <TextBlock Text="ללא צבע"
                                                           VerticalAlignment="Center"
                                                           FontSize="12"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <Separator Opacity="0.4" Margin="0,0,0,4"/>

                                    <!-- Theme colors -->
                                    <TextBlock Text="צבעי ערכת נושא"
                                               FontWeight="SemiBold" FontSize="11"
                                               Margin="0,0,0,4"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    <ItemsControl ItemsSource="{Binding ThemeColors,
                                                      RelativeSource={RelativeSource TemplatedParent}}"
                                                  ItemTemplate="{StaticResource SwatchTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel FlowDirection="RightToLeft"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>

                                    <Separator Opacity="0.4" Margin="0,4"/>

                                    <!-- Standard colors -->
                                    <TextBlock Text="צבעים רגילים"
                                               FontWeight="SemiBold" FontSize="11"
                                               Margin="0,0,0,4"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    <ItemsControl ItemsSource="{Binding StandardColors,
                                                      RelativeSource={RelativeSource TemplatedParent}}"
                                                  ItemTemplate="{StaticResource SwatchTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel FlowDirection="RightToLeft"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>

                                    <Separator Opacity="0.4" Margin="0,4,0,2"/>

                                    <!-- More colors -->
                                    <Border Height="28" Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#0A808080"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding OpenNativePickerCommand,
                                                              RelativeSource={RelativeSource AncestorType=local:ColorPickerButton}}"/>
                                        </Border.InputBindings>
                                        <TextBlock Text="צבעים נוספים..."
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   Foreground="#0078D4"/>
                                    </Border>

                                </StackPanel>
                            </Border>
                        </Popup>

                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.56"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
