<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Adaptive color tokens — work with any Office theme (light, dark, black).

        Primary bg/fg come from the UserControl.Background/Foreground set by
        WpfTaskPane.CreateNew via OfficeThemeWatcher. All secondary surfaces
        use opacity overlays so they adapt automatically.

        The foreground is always the contrasting color (dark on light bg, light
        on dark bg). So foreground-based overlays work on both themes:
          - On white bg: foreground is ~#262626, so 12% fg = subtle dark tint ✓
          - On dark bg:  foreground is ~#D4D4D4, so 12% fg = subtle light tint ✓

        We approximate this with a mid-gray (#808080) at various opacities —
        mid-gray is equidistant from black and white so it's visible on both.
    -->

    <!-- Background overlays — mid-gray based, visible on both light and dark -->
    <SolidColorBrush x:Key="BgSecBrush"    Color="#0F808080"/>  <!-- ~6% -->
    <SolidColorBrush x:Key="BgTerBrush"    Color="#1A808080"/>  <!-- ~10% -->
    <SolidColorBrush x:Key="HoverBrush"    Color="#0A808080"/>  <!-- ~4% -->
    <SolidColorBrush x:Key="PressedBrush"  Color="#14808080"/>  <!-- ~8% -->
    <SolidColorBrush x:Key="BorderBrush"   Color="#50808080"/>  <!-- ~31% — visible on both -->
    <SolidColorBrush x:Key="BorderStrong"  Color="#80808080"/>  <!-- ~50% — stronger border -->

    <!-- Accent — fixed, contrasts on both light and dark -->
    <SolidColorBrush x:Key="AccentBrush"   Color="#0078D4"/>
    <SolidColorBrush x:Key="AccentHover"   Color="#106EBE"/>
    <SolidColorBrush x:Key="AccentPressed" Color="#005A9E"/>

    <!-- Selected state — light blue tint, works on light and dark -->
    <SolidColorBrush x:Key="SelectedBrush" Color="#3300B4FF"/>  <!-- 20% accent blue -->

    <!-- Text — bound to UserControl.Foreground in styles, not hardcoded here -->
    <!-- Secondary text uses 60% opacity of the inherited foreground -->
    <SolidColorBrush x:Key="TextSecBrush"  Color="#99808080"/>  <!-- 60% white — secondary text on dark -->

</ResourceDictionary>
