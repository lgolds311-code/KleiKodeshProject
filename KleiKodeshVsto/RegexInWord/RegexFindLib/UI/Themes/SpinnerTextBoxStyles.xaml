<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:RegexFindLib.UI"
                    xmlns:controls="clr-namespace:WpfLib.Controls;assembly=WpfLib">

    <!-- ── SpinnerTextBox ──────────────────────────────────────────────── -->
    <Style TargetType="local:SpinnerTextBox">
        <Setter Property="Height" Value="28"/>
        <Setter Property="FlowDirection" Value="RightToLeft"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:SpinnerTextBox">
                    <!--
                        Office-style numeric spinner:
                        [  value text  ] [▲]
                                         [▼]
                        Border matches the ComboBox style: #EDEBE9, 4px radius.
                    -->
                    <Border x:Name="OuterBorder"
                            CornerRadius="4"
                            BorderBrush="#50808080"
                            BorderThickness="1"
                            Background="{TemplateBinding Background}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                            </Grid.ColumnDefinitions>

                            <!-- Numeric input — integer or float depending on IsFloat -->
                            <controls:UpDownTextBox x:Name="PART_IntBox"
                                                    Grid.Column="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Padding="6,0"
                                                    FontSize="12"
                                                    FontFamily="Segoe UI"
                                                    Foreground="{TemplateBinding Foreground}"
                                                    CaretBrush="{TemplateBinding Foreground}"
                                                    VerticalContentAlignment="Center"
                                                    TextAlignment="Center"
                                                    FocusVisualStyle="{x:Null}"
                                                    Value="{Binding IntValue, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                    Step="{Binding Step, RelativeSource={RelativeSource TemplatedParent}}"
                                                    Visibility="Visible"/>

                            <controls:UpDownFloatTextBox x:Name="PART_FloatBox"
                                                         Grid.Column="0"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         Padding="6,0"
                                                         FontSize="12"
                                                         FontFamily="Segoe UI"
                                                         Foreground="{TemplateBinding Foreground}"
                                                         CaretBrush="{TemplateBinding Foreground}"
                                                         VerticalContentAlignment="Center"
                                                         TextAlignment="Center"
                                                         FocusVisualStyle="{x:Null}"
                                                         Value="{Binding FloatValue, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                         Step="{Binding FloatStep, RelativeSource={RelativeSource TemplatedParent}}"
                                                         Visibility="Collapsed"/>

                            <!-- ▲ / ▼ buttons stacked on the right -->
                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- ▲ Up -->
                                <RepeatButton Grid.Row="0"
                                              x:Name="PART_UpBtn"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Padding="0"
                                              Cursor="Hand"
                                              Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="0,4,0,0">
                                                <Path Data="M5 7L8 4L11 7"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" 
                                                      StrokeThickness="1.2"
                                                      StrokeLineJoin="Round"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      Width="8" Height="5" Stretch="Uniform" HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      FlowDirection="LeftToRight"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#0A808080"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#14808080"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>

                                <!-- Divider between ▲ and ▼ -->
                                <Border Grid.Row="0" Grid.RowSpan="2"
                                        BorderBrush="#50808080" BorderThickness="1,0,0,0"
                                        IsHitTestVisible="False"/>

                                <!-- ▼ Down -->
                                <RepeatButton Grid.Row="1"
                                              x:Name="PART_DownBtn"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Padding="0"
                                              Cursor="Hand"
                                              Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="0,0,4,0">
                                                <Path Data="M5 4L8 7L11 4"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" 
                                                      StrokeThickness="1.2"
                                                      StrokeLineJoin="Round"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      Width="8" Height="5" Stretch="Uniform" HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      FlowDirection="LeftToRight"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#0A808080"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#14808080"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>

                            </Grid>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
