<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Three-state format toggle (CheckBox IsThreeState)
        null  → transparent
        true  → #3300B4FF (Office selected blue tint)
        false → #18DC3545 red tint + red diagonal line (1.5px, rounded caps)
    -->
    <Style x:Key="FormatToggle" TargetType="CheckBox">
        <Setter Property="IsThreeState"    Value="True"/>
        <Setter Property="Width"           Value="28"/>
        <Setter Property="Height"          Value="28"/>
        <Setter Property="Padding"         Value="5"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                        <Border x:Name="Bg" CornerRadius="2" Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <!-- false state: soft red tint + red diagonal line -->
                        <Border x:Name="ExcludedTint" CornerRadius="2"
                                Background="#18DC3545"
                                IsHitTestVisible="False" Visibility="Collapsed"/>
                        <Canvas x:Name="ExcludedLine"
                                IsHitTestVisible="False" Visibility="Collapsed">
                            <Line X1="4" Y1="4" X2="24" Y2="24"
                                  Stroke="#DC3545" StrokeThickness="1.5"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Canvas>
                        <Border x:Name="Hover" CornerRadius="2"
                                Background="Transparent" IsHitTestVisible="False"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#3300B4FF"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="False">
                            <Setter TargetName="ExcludedTint" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="ExcludedLine" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Hover" Property="Background" Value="#0A808080"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
