<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Three-state format toggle (CheckBox IsThreeState)
        null  → transparent
        true  → #3300B4FF (Office selected blue)
        false → #33FF0000 (Office error red) + diagonal line
    -->
    <Style x:Key="FormatToggle" TargetType="CheckBox">
        <Setter Property="IsThreeState"    Value="True"/>
        <Setter Property="Width"           Value="28"/>
        <Setter Property="Height"          Value="28"/>
        <Setter Property="Padding"         Value="5"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                        <Border x:Name="Bg" CornerRadius="2" Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border x:Name="ErrorLine" CornerRadius="2"
                                IsHitTestVisible="False" Visibility="Collapsed">
                            <Border.Background>
                                <DrawingBrush TileMode="None" Stretch="Fill">
                                    <DrawingBrush.Drawing>
                                        <GeometryDrawing>
                                            <GeometryDrawing.Geometry>
                                                <LineGeometry StartPoint="0,0" EndPoint="1,1"/>
                                            </GeometryDrawing.Geometry>
                                            <GeometryDrawing.Pen>
                                                <Pen Brush="#DC3545" Thickness="0.1"/>
                                            </GeometryDrawing.Pen>
                                        </GeometryDrawing>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Border.Background>
                        </Border>
                        <Border x:Name="Hover" CornerRadius="2"
                                Background="Transparent" IsHitTestVisible="False"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#3300B4FF"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="False">
                            <!-- no background tint — just the red diagonal line -->
                            <Setter TargetName="ErrorLine" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Hover" Property="Background" Value="#0A808080"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
