<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:RegexFindLib.UI">

    <!-- ── SnippetBlock — justified text with match highlighted ─────────── -->
    <Style TargetType="local:SnippetBlock">
        <Setter Property="Foreground"
                Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:SnippetBlock">
                    <TextBlock x:Name="PART_Text"
                               TextWrapping="Wrap"
                               TextAlignment="Justify"
                               FontSize="12"
                               Foreground="{TemplateBinding Foreground}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── RegexTip item — symbol | meaning + example ───────────────────── -->
    <DataTemplate x:Key="RegexTipTemplate" DataType="{x:Type local:RegexTip}">
        <Button Padding="8,4" Background="Transparent" BorderThickness="0"
                Cursor="Hand"
                local:RegexTipBehavior.Enable="True">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel>
                            <WrapPanel>
                                <TextBlock Text="{Binding Symbol}"
                                           FontFamily="Courier New"
                                           FontWeight="Bold"
                                           Foreground="#0078D4"
                                           MinWidth="70"
                                           Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding Meaning}"
                                           Foreground="{Binding Foreground,
                                               RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            </WrapPanel>
                            <TextBlock Text="{Binding Example}"
                                       FontFamily="Courier New"
                                       FontSize="11"
                                       Opacity="0.6"
                                       Margin="70,0,0,0"
                                       Foreground="{Binding Foreground,
                                           RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#0A808080"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#14808080"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </DataTemplate>

    <!-- ── RegexPalettePanel ─────────────────────────────────────────────── -->
    <Style TargetType="local:RegexPalettePanel">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:RegexPalettePanel">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{TemplateBinding Tips}"
                                      ItemTemplate="{StaticResource RegexTipTemplate}"
                                      Margin="5"/>
                    </ScrollViewer>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
