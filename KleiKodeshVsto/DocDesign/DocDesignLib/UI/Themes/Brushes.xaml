<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Adaptive color tokens — identical to RegexFindLib and WebSitesLib.
        Mid-gray (#808080) overlays work on both light and dark Office themes.
    -->
    <SolidColorBrush x:Key="BgSecBrush"   Color="#0F808080"/>
    <SolidColorBrush x:Key="BgTerBrush"   Color="#1A808080"/>
    <SolidColorBrush x:Key="HoverBrush"   Color="#0A808080"/>
    <SolidColorBrush x:Key="PressedBrush" Color="#14808080"/>
    <SolidColorBrush x:Key="BorderBrush"  Color="#50808080"/>
    <SolidColorBrush x:Key="BorderStrong" Color="#80808080"/>
    <SolidColorBrush x:Key="AccentBrush"  Color="#0078D4"/>
    <SolidColorBrush x:Key="SelectedBrush" Color="#3300B4FF"/>
    <SolidColorBrush x:Key="TextSecBrush" Color="#99808080"/>
</ResourceDictionary>
