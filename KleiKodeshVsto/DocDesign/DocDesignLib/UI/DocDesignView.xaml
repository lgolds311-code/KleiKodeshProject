<UserControl x:Class="DocDesign.DocDesignView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:WpfLib.Controls;assembly=WpfLib"
             xmlns:ap="clr-namespace:WpfLib.AttachedProperties;assembly=WpfLib"
             xmlns:local="clr-namespace:DocDesign.UI"
             mc:Ignorable="d"
             MinWidth="280"
             FlowDirection="RightToLeft"
             FontFamily="Segoe UI"
             FontSize="12"
             Background="White">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/DocDesign;component/UI/DocDesignDictionary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <UserControl.DataContext>
        <local:DocDesignViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!-- ══════════════════════════════════════════════════════
                 SECTION: עיצוב פסקה
            ══════════════════════════════════════════════════════ -->
            <Expander Header="עיצוב פסקה" IsExpanded="True">
                <StackPanel Margin="10,4,10,4">

                    <!-- Apply buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <Button ToolTip="סגנון מילה ראשונה"
                                Command="{Binding ParagraphsViewModel.ApplyFirstWordStyleCommand}">
                            <Path Data="{StaticResource Icon.FirstWordStyle}"/>
                        </Button>
                        <Button ToolTip="עיצוב חלון"
                                Command="{Binding ParagraphsViewModel.ApplyFirstWordHangingCommand}">
                            <Path Data="{StaticResource Icon.Hanging}"/>
                        </Button>
                        <Button ToolTip="עיצוב חלון כפול"
                                Command="{Binding ParagraphsViewModel.ApplyDoubleFirstWordHangingCommand}">
                            <Path Data="{StaticResource Icon.DoubleHanging}"/>
                        </Button>
                        <Button ToolTip="מירכוז שורה אחרונה"
                                Command="{Binding ParagraphsViewModel.ApplyCenterLastLineCommand}">
                            <Path Data="{StaticResource Icon.CenterLastLine}"/>
                        </Button>
                    </StackPanel>

                    <!-- Remove buttons — same icon at 45% opacity + red diagonal overlay -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Button ToolTip="הסר סגנון מילה ראשונה"
                                Command="{Binding ParagraphsViewModel.RemoveFirstWordStyleCommand}">
                            <Grid>
                                <Path Data="{StaticResource Icon.FirstWordStyle}" Opacity="0.45"/>
                                <Border CornerRadius="2" Background="#18DC3545" IsHitTestVisible="False"/>
                                <Line X1="0" Y1="0" X2="1" Y2="1"
                                      Stretch="Fill"
                                      Stroke="#DC3545" StrokeThickness="1.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      IsHitTestVisible="False"/>
                            </Grid>
                        </Button>
                        <Button ToolTip="הסר עיצוב חלון"
                                Command="{Binding ParagraphsViewModel.RemoveFirstWordHangingCommand}">
                            <Grid>
                                <Path Data="{StaticResource Icon.Hanging}" Opacity="0.45"/>
                                <Border CornerRadius="2" Background="#18DC3545" IsHitTestVisible="False"/>
                                <Line X1="0" Y1="0" X2="1" Y2="1"
                                      Stretch="Fill"
                                      Stroke="#DC3545" StrokeThickness="1.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      IsHitTestVisible="False"/>
                            </Grid>
                        </Button>
                        <Button ToolTip="הסר מירכוז שורה אחרונה"
                                Command="{Binding ParagraphsViewModel.RemoveCenterLastLineCommand}">
                            <Grid>
                                <Path Data="{StaticResource Icon.CenterLastLine}" Opacity="0.45"/>
                                <Border CornerRadius="2" Background="#18DC3545" IsHitTestVisible="False"/>
                                <Line X1="0" Y1="0" X2="1" Y2="1"
                                      Stretch="Fill"
                                      Stroke="#DC3545" StrokeThickness="1.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      IsHitTestVisible="False"/>
                            </Grid>
                        </Button>
                    </StackPanel>

                    <!-- Style picker row -->
                    <StackPanel Margin="0,0,0,4">
                        <TextBlock Text="הגדרות"
                                   Opacity="0.55"
                                   FontSize="11"
                                   Margin="0,6,0,2"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ToggleButton x:Name="ChooseStylesToggle"
                                          Grid.Column="0"
                                          Style="{StaticResource CheckedToggle}"
                                          Content="החל על ▾"
                                          Height="26"
                                          Padding="8,0"
                                          FontSize="11"
                                          HorizontalAlignment="Stretch"
                                          IsHitTestVisible="{Binding IsOpen, ElementName=ChooseStylesPopup,
                                              Converter={StaticResource ReverseBoolConverter}}"
                                          IsChecked="{Binding RefreshStyles}"/>
                            <Popup x:Name="ChooseStylesPopup"
                                   StaysOpen="False"
                                   PlacementTarget="{Binding ElementName=ChooseStylesToggle}"
                                   IsOpen="{Binding IsChecked, ElementName=ChooseStylesToggle}"
                                   AllowsTransparency="False"
                                   MaxHeight="220">
                                <Border BorderBrush="#50808080"
                                        BorderThickness="1"
                                        MinWidth="{Binding ActualWidth, ElementName=ChooseStylesToggle}"
                                        Background="{Binding Background, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                    <StackPanel>
                                        <!-- "סמן הכל" row -->
                                        <Border x:Name="SelectAllBd" Background="Transparent" Cursor="Hand">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#0A808080"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <CheckBox Content="סמן הכל"
                                                      IsChecked="{Binding ParagraphsViewModel.CheckAllStyles}"
                                                      Padding="4,0"
                                                      Margin="8,5"/>
                                        </Border>
                                        <Separator Background="#50808080" Margin="0,2"/>
                                        <!-- Style items -->
                                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                                      VerticalScrollBarVisibility="Auto"
                                                      MaxHeight="180">
                                            <ItemsControl ItemsSource="{Binding ParagraphsViewModel.ActiveStyles}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="Transparent" Cursor="Hand">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="#0A808080"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <CheckBox Content="{Binding Name}"
                                                                      IsChecked="{Binding Apply}"
                                                                      Padding="4,0"
                                                                      Margin="8,4"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                            </Popup>

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="8,0,0,0">
                                <TextBlock Text="מינ׳ שורות" Margin="0,0,4,0" Opacity="0.65"/>
                                <controls:UpDownTextBox Value="{Binding ParagraphsViewModel.MinLineCount}"
                                                        Width="38" Height="26"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <TextBlock Text="סגנון מילה ראשונה"
                               Opacity="0.55"
                               FontSize="11"
                               Margin="0,6,0,2"
                               ToolTip="בחר סגנון עבור מילה ראשונה (סגנון תו בלבד)"/>
                    <ComboBox VirtualizingPanel.IsVirtualizing="True"
                              ItemsSource="{Binding ParagraphsViewModel.FirstWordStyle.Styles}"
                              Text="{Binding ParagraphsViewModel.FirstWordStyle.SelectedStyle}"
                              IsEditable="True"
                              Margin="0,0,0,2"
                              ToolTip="בחר סגנון עבור מילה ראשונה (סגנון תו בלבד)"/>

                </StackPanel>
            </Expander>

            <!-- ══════════════════════════════════════════════════════
                 SECTION: איזון טורים
            ══════════════════════════════════════════════════════ -->
            <Expander Header="איזון טורים">
                <StackPanel Margin="10,4,10,4">

                    <StackPanel Orientation="Horizontal" Margin="0,2,0,4">
                        <Button ToolTip="יישור טורים"
                                Command="{Binding ColumnsViewModel.AlignColumnsCommand}">
                            <Path Data="{StaticResource Icon.AlignColumns}"/>
                        </Button>
                        <Button ToolTip="הגדרות טורים"
                                Command="{Binding ColumnsViewModel.OpenColumnsDialogCommand}">
                            <Path Data="{StaticResource Icon.ColumnsSettings}"/>
                        </Button>
                        <Button ToolTip="חפש טורים שאינם מאוזנים"
                                Command="{Binding ColumnsViewModel.FindNextUnevenColumnsCommand}">
                            <Path Data="{StaticResource Icon.ColumnsSearch}"/>
                        </Button>
                    </StackPanel>

                    <Grid Margin="0,0,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock DockPanel.Dock="Right" Text="מרווח מקסימלי בין קטעים" Opacity="0.65"/>
                        <controls:UpDownTextBox Grid.Column="2"
                            Value="{Binding ColumnsViewModel.AlignColumns.MaxSpaceAfter}"
                                                Width="38" Height="26"/>
                    </Grid>

                </StackPanel>
            </Expander>

            <!-- ══════════════════════════════════════════════════════
                 SECTION: מרווחים
            ══════════════════════════════════════════════════════ -->
            <Expander Header="מרווחים">
                <StackPanel Margin="10,4,10,6">

                    <Grid ap:GridSetup.Columns="auto * auto auto auto"
                          ap:GridSetup.Rows="auto auto auto auto auto">
                        <Grid.Resources>
                            <Style TargetType="Button" BasedOn="{StaticResource ResetButton}"/>
                        </Grid.Resources>

                        <Button Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                Command="{Binding SpacingViewModel.SetSpaceAfterCommand}" CommandParameter="=">
                            <Path/>
                        </Button>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="מרווח אחרי" Opacity="0.75" Margin="6,0"/>
                        <controls:UpDownFloatTextBox Grid.Row="0" Grid.Column="2" Width="44" Height="26" Margin="0,2"
                                Step="{Binding SpacingViewModel.StepSize}" Value="{Binding SpacingViewModel.SpaceAfter}"/>
                        <RepeatButton Grid.Row="0" Grid.Column="3" Style="{StaticResource DecreaseButton}" Height="26"
                                      Command="{Binding SpacingViewModel.SetSpaceAfterCommand}" CommandParameter="-">
                            <Path/>
                        </RepeatButton>
                        <RepeatButton Grid.Row="0" Grid.Column="4" Style="{StaticResource IncreaseButton}" Height="26"
                                      Command="{Binding SpacingViewModel.SetSpaceAfterCommand}" CommandParameter="+">
                            <Path/>
                        </RepeatButton>

                        <Button Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"
                                Command="{Binding SpacingViewModel.SetSpaceBeforeCommand}" CommandParameter="=">
                            <Path/>
                        </Button>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="מרווח לפני" Opacity="0.75" Margin="6,0"/>
                        <controls:UpDownFloatTextBox Grid.Row="1" Grid.Column="2" Width="44" Height="26" Margin="0,2"
                                Step="{Binding SpacingViewModel.StepSize}" Value="{Binding SpacingViewModel.SpaceBefore}"/>
                        <RepeatButton Grid.Row="1" Grid.Column="3" Style="{StaticResource DecreaseButton}" Height="26"
                                      Command="{Binding SpacingViewModel.SetSpaceBeforeCommand}" CommandParameter="-">
                            <Path/>
                        </RepeatButton>
                        <RepeatButton Grid.Row="1" Grid.Column="4" Style="{StaticResource IncreaseButton}" Height="26"
                                      Command="{Binding SpacingViewModel.SetSpaceBeforeCommand}" CommandParameter="+">
                            <Path/>
                        </RepeatButton>

                        <Button Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                                Command="{Binding SpacingViewModel.SetLineSpacingCommand}" CommandParameter="=">
                            <Path/>
                        </Button>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="בין שורות" Opacity="0.75" Margin="6,0"/>
                        <controls:UpDownFloatTextBox Grid.Row="2" Grid.Column="2" Width="44" Height="26" Margin="0,2"
                                Step="{Binding SpacingViewModel.StepSize}" Value="{Binding SpacingViewModel.LineSpacing}"/>
                        <RepeatButton Grid.Row="2" Grid.Column="3" Style="{StaticResource DecreaseButton}" Height="26"
                                      Command="{Binding SpacingViewModel.SetLineSpacingCommand}" CommandParameter="-">
                            <Path/>
                        </RepeatButton>
                        <RepeatButton Grid.Row="2" Grid.Column="4" Style="{StaticResource IncreaseButton}" Height="26"
                                      Command="{Binding SpacingViewModel.SetLineSpacingCommand}" CommandParameter="+">
                            <Path/>
                        </RepeatButton>

                        <Button Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"
                                Command="{Binding SpacingViewModel.SetWordSpacingCommand}" CommandParameter="=">
                            <Path/>
                        </Button>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="בין מילים" Opacity="0.75" Margin="6,0"/>
                        <controls:UpDownFloatTextBox Grid.Row="3" Grid.Column="2" Width="44" Height="26" Margin="0,2"
                                Step="{Binding SpacingViewModel.StepSize}" Value="{Binding SpacingViewModel.WordSpacing}"/>
                        <RepeatButton Grid.Row="3" Grid.Column="3" Style="{StaticResource DecreaseButton}" Height="26"
                                      Command="{Binding SpacingViewModel.SetWordSpacingCommand}" CommandParameter="-">
                            <Path/>
                        </RepeatButton>
                        <RepeatButton Grid.Row="3" Grid.Column="4" Style="{StaticResource IncreaseButton}" Height="26"
                                      Command="{Binding SpacingViewModel.SetWordSpacingCommand}" CommandParameter="+">
                            <Path/>
                        </RepeatButton>

                        <Button Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"
                                Command="{Binding SpacingViewModel.SetCharacterStretchCommand}" CommandParameter="=">
                            <Path/>
                        </Button>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="מתיחת אותיות" Opacity="0.75" Margin="6,0"/>
                        <controls:UpDownFloatTextBox Grid.Row="4" Grid.Column="2" Width="44" Height="26" Margin="0,2"
                                Step="{Binding SpacingViewModel.StepSize}" Value="{Binding SpacingViewModel.CharacterStretch}"/>
                        <RepeatButton Grid.Row="4" Grid.Column="3" Style="{StaticResource DecreaseButton}" Height="26"
                                      Command="{Binding SpacingViewModel.SetCharacterStretchCommand}" CommandParameter="-">
                            <Path/>
                        </RepeatButton>
                        <RepeatButton Grid.Row="4" Grid.Column="4" Style="{StaticResource IncreaseButton}" Height="26"
                                      Command="{Binding SpacingViewModel.SetCharacterStretchCommand}" CommandParameter="+">
                            <Path/>
                        </RepeatButton>
                    </Grid>

                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock DockPanel.Dock="Left" Text="גודל צעד" Opacity="0.65"/>
                        <controls:UpDownFloatTextBox Step="0.5"
                                                     Grid.Column="2"
                                                     Value="{Binding SpacingViewModel.StepSize}"
                                                     Width="44" Height="26"/>
                    </Grid>

                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</UserControl>
