<Window x:Class="DocDesignDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DocDesign Demo"
        Width="340"
        Height="600"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI"
        Background="#FFFFFF">

    <!--
        Hosts DocDesignView directly as a WPF UserControl.
        In production it lives inside a WindowsFormsHost inside a VSTO task pane.
        Toggle the commented Background/Foreground lines to test dark mode.
    -->
    <Border x:Name="ViewHost" BorderThickness="0"/>

</Window>
