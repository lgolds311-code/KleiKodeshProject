<!-- NakdanView.xaml  |  Hebrew vowelization task-pane  |  RTL  |  MVVM -->
<UserControl x:Class="Nakdan.UI.NakdanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Nakdan.UI"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="300"
             FlowDirection="RightToLeft"
             FontFamily="Segoe UI"
             FontSize="13"
             Background="White"
             Foreground="Black">
    <!--
        Background must be set (not Transparent) so ComboBox dropdown popups work correctly.
        ElementHost overrides this with the Office theme color at runtime.
    -->

    <UserControl.DataContext>
        <local:NakdanViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="NakdanDictionary.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ── Converters ────────────────────────────────────── -->
            <local:BoolToVisibilityConverter  x:Key="BoolToVis"/>
            <local:GenreDescriptionConverter  x:Key="GenreDesc"/>

        </ResourceDictionary>
    </UserControl.Resources>

    <!-- ═══════════════════════════════════════════════════════════
         ROOT
    ═══════════════════════════════════════════════════════════ -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="12,12,12,12">

            <!-- ─────────────────────────────────────────────────
                 SECTION LABEL: VOWELIZE ACTIONS
            ───────────────────────────────────────────────── -->
            <TextBlock Text="פעולות ניקוד"
                       Style="{StaticResource SectionLabel}"
                       Margin="0,0,0,8"/>

            <!-- Vowelize selection -->
            <Button Style="{StaticResource ActionButton}"
                    Command="{Binding VowelizeSelectionCommand}"
                    Margin="0,0,0,12"
                    ToolTip="נקד רק את הטקסט המסומן">
                <TextBlock Text="נקד טקסט מסומן" VerticalAlignment="Center"/>
            </Button>

            <!-- Remove nikkud from selection -->
            <Button Style="{StaticResource ActionButton}"
                    Command="{Binding RemoveNikkudCommand}"
                    Margin="0,0,0,12"
                    ToolTip="הסר ניקוד מהטקסט המסומן">
                <TextBlock Text="הסר ניקוד מטקסט" VerticalAlignment="Center"/>
            </Button>

            <!-- Remove cantillations from selection -->
            <Button Style="{StaticResource ActionButton}"
                    Command="{Binding RemoveCantillationsCommand}"
                    Margin="0,0,0,12"
                    ToolTip="הסר טעמים מהטקסט המסומן">
                <TextBlock Text="הסר טעמים מטקסט" VerticalAlignment="Center"/>
            </Button>

            <!-- ─────────────────────────────────────────────────
                 GENRE SELECTOR
            ───────────────────────────────────────────────── -->
            <TextBlock Text="סוג הטקסט"
                       Style="{StaticResource SectionLabel}"
                       Margin="0,0,0,4"/>
            <ComboBox ItemsSource="{Binding Genres}"
                      SelectedItem="{Binding SelectedGenre, Mode=TwoWay}"
                      Height="28"
                      Margin="0,0,0,12">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayName}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- ─────────────────────────────────────────────────
                 SECTION LABEL: IGNORE STYLES
            ───────────────────────────────────────────────── -->

            <TextBlock Text="סמן סגנונות לדלג בתהליך הניקוד:"
                       Style="{StaticResource SectionLabel}"
                       Margin="0,0,0,8"/>

            <!-- Dropdown with checkboxes -->
            <ToggleButton x:Name="IgnoreStylesToggle"
                          Style="{StaticResource CheckedToggle}"
                          Content="בחר סגנונות ▾"
                          Height="28"
                          Padding="8,0"
                          FontSize="12"
                          HorizontalAlignment="Stretch"
                          Margin="0,0,0,0"/>
            <Popup x:Name="IgnoreStylesPopup"
                   StaysOpen="False"
                   PlacementTarget="{Binding ElementName=IgnoreStylesToggle}"
                   IsOpen="{Binding IsChecked, ElementName=IgnoreStylesToggle}"
                   AllowsTransparency="False"
                   MaxHeight="220">
                <Border BorderBrush="#50808080"
                        BorderThickness="1"
                        MinWidth="{Binding ActualWidth, ElementName=IgnoreStylesToggle}"
                        Background="{Binding Background, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  MaxHeight="200">
                        <ItemsControl ItemsSource="{Binding Styles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="Transparent" Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#0A808080"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <CheckBox Content="{Binding DisplayName}"
                                                  IsChecked="{Binding IsIgnored, Mode=TwoWay}"
                                                  Padding="4,0"
                                                  Margin="8,4"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Popup>

            <!-- ─────────────────────────────────────────────────
                 STATUS / BUSY BLOCK — always visible at bottom
                 Label on top, status area below.
                 When inactive: dimmed with prompt text.
                 When active: full opacity with status/busy message.
            ───────────────────────────────────────────────── -->
            <TextBlock Text="סטטוס"
                       Style="{StaticResource SectionLabel}"
                       Margin="0,12,0,4"/>

            <Border CornerRadius="4" BorderThickness="1" ClipToBounds="True">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background"  Value="{StaticResource BgSecBrush}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                        <Setter Property="Opacity"     Value="0.5"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="Opacity" Value="1.0"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Background"  Value="#18DC3545"/>
                                <Setter Property="BorderBrush" Value="#DC3545"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Top row: status text + X button -->
                    <Grid Grid.Row="0" Margin="8,6,8,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Status / busy text or prompt -->
                        <TextBlock Grid.Column="0"
                                   FontSize="12" TextWrapping="Wrap"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text"       Value=""/>
                                    <Setter Property="Foreground" Value="{Binding Foreground,
                                                RelativeSource={RelativeSource AncestorType=UserControl},
                                                Converter={StaticResource OpacityConverter}}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                            <Setter Property="Text" Value="מנקד… אנא המתן"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="Text" Value="{Binding StatusMessage}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasError}" Value="True">
                                            <Setter Property="Foreground" Value="#DC3545"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- X button: cancel while busy, clear status when done -->
                        <Button Grid.Column="1"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Padding="6,0" Margin="6,0,0,0"
                                VerticalAlignment="Center">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Command"  Value="{Binding ClearStatusCommand}"/>
                                    <Setter Property="ToolTip"  Value="סגור"/>
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                            <Setter Property="Command" Value="{Binding CancelCommand}"/>
                                            <Setter Property="ToolTip" Value="בטל את הניקוד"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecBrush}"/>
                        </Button>
                    </Grid>

                    <!-- Bottom row: indeterminate progress bar (busy only) -->
                    <ProgressBar Grid.Row="1"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                                 IsIndeterminate="True"
                                 Height="2"
                                 Foreground="{StaticResource AccentBrush}"
                                 Background="Transparent"
                                 BorderThickness="0"/>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
