<Window x:Class="WebSitesLib.UI.WhiteListDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dd="urn:gong-wpf-dragdrop"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        Title="רשימת אתרים מותרים"
        MaxHeight="350"
        MinWidth="320"
        PreviewKeyDown="Window_PreviewKeyDown"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown"
        TouchDown="Window_TouchDown"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI"
        x:Name="Root">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WebSitesLib;component/ui/WebSitesDictionary.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Dialog-specific ListBox — adds border -->
            <Style x:Key="DialogListBox" TargetType="ListBox">
                <Setter Property="Background"       Value="Transparent"/>
                <Setter Property="BorderThickness"  Value="1"/>
                <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}"/>
                <Setter Property="Padding"          Value="0"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Custom window chrome -->
    <Border BorderThickness="1"
            CornerRadius="2"
            BorderBrush="{StaticResource BorderBrush}"
            Background="{Binding Background, RelativeSource={RelativeSource AncestorType=Window}}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Title bar  -->
                <RowDefinition Height="Auto"/>  <!-- Separator  -->
                <RowDefinition Height="*"/>     <!-- List       -->
                <RowDefinition Height="Auto"/>  <!-- Separator  -->
                <RowDefinition Height="Auto"/>  <!-- Footer     -->
            </Grid.RowDefinitions>

            <!-- ── TITLE BAR ──────────────────────────────────────── -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgSecBrush}"
                    Padding="8,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="רשימת אתרים מותרים"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0"
                               Opacity="0.85"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}"/>

                    <Button Grid.Column="1"
                            ToolTip="סגור"
                            Click="CloseButton_Click">
                        <Viewbox Width="12" Height="12" FlowDirection="LeftToRight">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}"
                                      Data="{StaticResource Icon.Close}"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>

            <Rectangle Grid.Row="1" Style="{StaticResource SeparatorLine}"/>

            <!-- ── WHITELIST ──────────────────────────────────────── -->
            <ListBox x:Name="Whitelist"
                     Grid.Row="2"
                     x:FieldModifier="public"
                     Style="{StaticResource DialogListBox}"
                     ItemsSource="{Binding WebAddressModels}"
                     MinHeight="120"
                     dd:DragDrop.IsDragSource="True"
                     dd:DragDrop.IsDropTarget="True">
                <ListBox.Resources>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource DialogListItem}"/>
                </ListBox.Resources>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox IsChecked="{Binding IsVisible}"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"/>
                            <StackPanel x:Name="Info" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="12"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <TextBlock Text="{Binding Description}"
                                           FontSize="10"
                                           Opacity="0.50"
                                           Margin="0,1,0,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </StackPanel>
                        </StackPanel>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsVisible}" Value="false">
                                <Setter TargetName="Info" Property="Opacity" Value="0.40"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Rectangle Grid.Row="3" Style="{StaticResource SeparatorLine}"/>

            <!-- ── FOOTER ─────────────────────────────────────────── -->
            <Border Grid.Row="4"
                    Background="{StaticResource BgSecBrush}"
                    Padding="8,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>  <!-- Select all  -->
                        <ColumnDefinition Width="*"/>     <!-- Move btns   -->
                        <ColumnDefinition Width="Auto"/>  <!-- OK          -->
                    </Grid.ColumnDefinitions>

                    <CheckBox x:Name="CheckAllBox"
                              Grid.Column="0"
                              Content="סמן הכל"
                              VerticalAlignment="Center"
                              Checked="CheckAllBox_CheckChanged"
                              Unchecked="CheckAllBox_CheckChanged"/>

                    <StackPanel Orientation="Horizontal"
                                Grid.Column="1"
                                HorizontalAlignment="Center">
                        <Button ToolTip="הזז למעלה" Click="MoveUpButton_Click">
                            <Viewbox Width="14" Height="14" FlowDirection="LeftToRight">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}"
                                          Data="{StaticResource Icon.MoveUp}"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button ToolTip="הזז למטה" Click="MoveDownButton_Click">
                            <Viewbox Width="14" Height="14" FlowDirection="LeftToRight">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}"
                                          Data="{StaticResource Icon.MoveDown}"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </StackPanel>

                    <Button x:Name="OK_Button"
                            Grid.Column="2"
                            Style="{StaticResource ActionButton}"
                            Content="אישור"
                            Width="90"
                            Click="OK_Button_Click"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
