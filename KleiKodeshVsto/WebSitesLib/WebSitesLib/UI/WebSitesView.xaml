<UserControl x:Class="WebSitesLib.UI.WebSitesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WebSitesLib.UI"
             mc:Ignorable="d"
             FlowDirection="RightToLeft"
             FontFamily="Segoe UI"
             FontSize="13"
             Background="White">
    <!--
        Background must be set (not Transparent) so Popup backgrounds work correctly.
        ElementHost overrides this with the Office theme color at runtime.
    -->

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WebSitesLib;component/ui/WebSitesDictionary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Tab strip   -->
            <RowDefinition Height="Auto"/>  <!-- Address bar -->
            <RowDefinition Height="*"/>     <!-- Browser     -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             ROW 0 — TAB STRIP
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BgSecBrush}"
                BorderBrush="{StaticResource BorderStrong}"
                BorderThickness="0,0,0,1"
                Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Tab list -->
                <ListBox x:Name="TabStrip"
                         Grid.Column="0"
                         ItemsSource="{Binding ElementName=BrowserTabs, Path=TabsCollection}"
                         SelectedIndex="{Binding ElementName=BrowserTabs, Path=SelectedIndex}">
                    <ListBox.Resources>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource TabItemStyle}"/>
                    </ListBox.Resources>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="TabBorder"
                                    MaxWidth="150"
                                    Background="Transparent"
                                    BorderThickness="0,0,1,1"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    ToolTip="{Binding Title}">
                                <Grid Height="34">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock x:Name="TabTitle"
                                               Grid.Column="0"
                                               Style="{StaticResource TabTitle}"
                                               Text="{Binding Title}"
                                               Padding="8,0,4,0"/>

                                    <Button x:Name="CloseTabBtn"
                                            Grid.Column="1"
                                            ToolTip="סגור כרטיסייה"
                                            Command="{Binding CloseTabCommand}"
                                            Padding="5"
                                            Margin="0,0,4,0"
                                            VerticalAlignment="Center"
                                            Visibility="Hidden">
                                        <Path Style="{StaticResource TabClosePath}"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                    <Setter TargetName="CloseTabBtn" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="TabBorder"   Property="Background" Value="{StaticResource HoverBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="TabBorder"   Property="Background"
                                            Value="{Binding Background, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    <Setter TargetName="TabBorder"   Property="BorderThickness" Value="0,0,1,0"/>
                                    <Setter TargetName="CloseTabBtn" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="TabTitle"    Property="Opacity" Value="1"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- New-tab + dropdown -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="2,0">

                    <Button ToolTip="כרטיסייה חדשה"
                            Command="{Binding ElementName=BrowserTabs, Path=NewTabCommand}"
                            Padding="7">
                        <Viewbox Width="14" Height="14" FlowDirection="LeftToRight">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      Data="{StaticResource Icon.Add}"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <ToggleButton x:Name="TabDropDownToggle"
                                  ToolTip="הצג את כל הכרטיסיות"
                                  Padding="7">
                        <Viewbox Width="10" Height="10" FlowDirection="LeftToRight">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      Data="{StaticResource Icon.ChevronDown}"/>
                            </Canvas>
                        </Viewbox>
                    </ToggleButton>

                    <Popup IsOpen="{Binding IsChecked, ElementName=TabDropDownToggle}"
                           PlacementTarget="{Binding ElementName=TabDropDownToggle}"
                           Placement="Bottom"
                           AllowsTransparency="False"
                           StaysOpen="False">
                        <Border Style="{StaticResource DropdownBorder}">
                            <ListBox ItemsSource="{Binding ElementName=BrowserTabs, Path=TabsCollection}"
                                     SelectedIndex="{Binding ElementName=BrowserTabs, Path=SelectedIndex}">
                                <ListBox.Resources>
                                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource TabItemStyle}"/>
                                </ListBox.Resources>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="DropItem"
                                                CornerRadius="2"
                                                Padding="8,4"
                                                Background="Transparent"
                                                Cursor="Hand">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Title}"
                                                           Style="{StaticResource TabTitle}"
                                                           MaxWidth="200"
                                                           Margin="0"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding Title}">
                                                    <TextBlock.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                      Command="{Binding MoveToFrontCommand}"/>
                                                    </TextBlock.InputBindings>
                                                </TextBlock>
                                                <Button Grid.Column="1"
                                                        ToolTip="סגור כרטיסייה"
                                                        Command="{Binding CloseTabCommand}"
                                                        Padding="4"
                                                        Margin="4,0,0,0"
                                                        VerticalAlignment="Center">
                                                    <Path Style="{StaticResource TabClosePath}"
                                                          Width="7" Height="7"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                <Setter TargetName="DropItem" Property="Background" Value="{StaticResource HoverBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter TargetName="DropItem" Property="Background" Value="{StaticResource PressedBrush}"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             ROW 1 — ADDRESS / TOOLBAR BAR
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{Binding Background, RelativeSource={RelativeSource Self}}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,5"
                FlowDirection="LeftToRight">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- nav buttons  -->
                    <ColumnDefinition Width="*"/>     <!-- address bar  -->
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="0,0,4,0">
                    <Button ToolTip="חזור אחורה"
                            Command="{Binding ElementName=BrowserTabs, Path=GoBackCommand}">
                        <Viewbox Width="16" Height="16" FlowDirection="LeftToRight">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      Data="{StaticResource Icon.Back}"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <Button ToolTip="קדימה"
                            Command="{Binding ElementName=BrowserTabs, Path=GoForwardCommand}">
                        <Viewbox Width="16" Height="16" FlowDirection="LeftToRight">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      Data="{StaticResource Icon.Forward}"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <Button ToolTip="רענן"
                            Command="{Binding ElementName=BrowserTabs, Path=RefreshCommand}">
                        <Viewbox Width="16" Height="16" FlowDirection="LeftToRight">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      Data="{StaticResource Icon.Reload}"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>

                <ComboBox x:Name="AddressBarCombo"
                          Grid.Column="1"
                          Style="{StaticResource AddressBarCombo}"
                          ItemsSource="{Binding ElementName=BrowserTabs, Path=VisibleAddressModels}"
                          SelectedValue="{Binding ElementName=BrowserTabs, Path=CurrentAddressModel}">
                    <ComboBox.InputBindings>
                        <KeyBinding Key="Return"
                                    Command="{Binding ElementName=BrowserTabs, Path=NavigateCommand}"/>
                    </ComboBox.InputBindings>
                </ComboBox>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             ROW 2 — BROWSER CONTENT
        ══════════════════════════════════════════════════════════ -->
        <local:BrowserTabControl x:Name="BrowserTabs" Grid.Row="2"/>

    </Grid>
</UserControl>
