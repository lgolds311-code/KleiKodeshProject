<UserControl x:Class="WebSitesLib.UI.WebSitesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WebSitesLib.UI"
             mc:Ignorable="d"
             FlowDirection="RightToLeft"
             FontFamily="Segoe UI"
             FontSize="13"
             Background="White">
    <!--
        Background must be set (not Transparent) so Popup backgrounds work correctly.
        ElementHost overrides this with the Office theme color at runtime.
    -->

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WebSitesLib;component/ui/WebSitesDictionary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <!-- Hide native TabPanel — we draw our own tab strip -->
            <Style TargetType="local:BrowserTabControl">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin"  Value="0"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Style.Resources>
                    <Style TargetType="TabPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                    <Style TargetType="TabItem">
                        <Setter Property="Padding"         Value="0"/>
                        <Setter Property="Margin"          Value="0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <ContentPresenter Margin="0" ContentSource="Content"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Style.Resources>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Tab strip   -->
            <RowDefinition Height="Auto"/>  <!-- Address bar -->
            <RowDefinition Height="*"/>     <!-- Browser     -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             ROW 0 — TAB STRIP
             Chrome/Edge pattern: strip bg = slightly darker than toolbar.
             Active tab = same as toolbar (white/content bg) → "lifts up" effect.
             Inactive tabs = transparent (inherit strip bg).
             No borders between tabs — just the accent bar on active.
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BgSecBrush}">
            <DockPanel LastChildFill="True">

                <!-- New-tab + dropdown — docked right (RTL: renders on left) -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            FlowDirection="LeftToRight"
                            VerticalAlignment="Stretch">

                    <ToggleButton x:Name="TabDropDownToggle"
                                  ToolTip="הצג את כל הכרטיסיות"
                                  Width="26" Height="26"
                                  Padding="5"
                                  VerticalAlignment="Center">
                        <Viewbox FlowDirection="LeftToRight">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      Data="{StaticResource Icon.ChevronDown}"/>
                            </Canvas>
                        </Viewbox>
                    </ToggleButton>

                    <Button ToolTip="כרטיסייה חדשה"
                            Command="{Binding ElementName=BrowserTabs, Path=NewTabCommand}"
                            Width="26" Height="26"
                            Padding="5"
                            VerticalAlignment="Center">
                        <Viewbox FlowDirection="LeftToRight">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      Data="{StaticResource Icon.Add}"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <Popup IsOpen="{Binding IsChecked, ElementName=TabDropDownToggle}"
                           PlacementTarget="{Binding ElementName=TabDropDownToggle}"
                           Placement="Bottom"
                           AllowsTransparency="False"
                           StaysOpen="False">
                        <Border Style="{StaticResource DropdownBorder}">
                            <ListBox ItemsSource="{Binding ElementName=BrowserTabs, Path=TabsCollection}"
                                     SelectedIndex="{Binding ElementName=BrowserTabs, Path=SelectedIndex}">
                                <ListBox.Resources>
                                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource TabItemStyle}"/>
                                </ListBox.Resources>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="DropItem"
                                                CornerRadius="2"
                                                Padding="4,3"
                                                Background="Transparent"
                                                Cursor="Hand">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding NavigateToTabCommand}"/>
                                            </Border.InputBindings>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- × button — col 0, visual left -->
                                                <Button Grid.Column="0"
                                                        ToolTip="סגור כרטיסייה"
                                                        Command="{Binding CloseTabCommand}"
                                                        Width="20" Height="20"
                                                        Padding="3"
                                                        Margin="0,0,4,0"
                                                        VerticalAlignment="Center">
                                                    <Path Style="{StaticResource TabClosePath}"
                                                          Width="7" Height="7"/>
                                                </Button>
                                                <!-- Title — col 1, visual right -->
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Title}"
                                                           Style="{StaticResource TabTitle}"
                                                           MaxWidth="200"
                                                           Margin="0"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding Title}"/>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                <Setter TargetName="DropItem" Property="Background" Value="#0A808080"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter TargetName="DropItem" Property="Background" Value="#14808080"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>
                </StackPanel>

                <!-- Tab list — fills remaining space -->
                <ListBox x:Name="TabStrip"
                         ItemsSource="{Binding ElementName=BrowserTabs, Path=TabsCollection}"
                         SelectedIndex="{Binding ElementName=BrowserTabs, Path=SelectedIndex}"
                         VerticalAlignment="Stretch">
                    <ListBox.Resources>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource TabItemStyle}"/>
                    </ListBox.Resources>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!--
                                Fluent-style tab chip:
                                - Transparent bg, text at 60% opacity
                                - Hover: subtle mid-gray tint
                                - Active: full opacity text + 2px accent bar at bottom
                                - Close ×: thin, appears on hover/active only
                            -->
                            <Grid x:Name="TabRoot"
                                  Height="28"
                                  MinWidth="60"
                                  MaxWidth="160"
                                  Background="Transparent"
                                  ToolTip="{Binding Title}">
                                <!-- 2px accent indicator at bottom — active only -->
                                <Border x:Name="ActiveBar"
                                        Height="2"
                                        Background="#0078D4"
                                        VerticalAlignment="Bottom"
                                        Visibility="Collapsed"/>

                                <DockPanel Margin="0">
                                    <!-- × docked Right — in RTL renders on visual LEFT -->
                                    <Button x:Name="CloseTabBtn"
                                            DockPanel.Dock="Right"
                                            Command="{Binding CloseTabCommand}"
                                            ToolTip="סגור כרטיסייה"
                                            Width="18" Height="18"
                                            Padding="3"
                                            Margin="0,0,3,0"
                                            VerticalAlignment="Center"
                                            Visibility="Hidden"
                                            Opacity="0.55">
                                        <Path Data="M1,1 L7,7 M7,1 L1,7"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              StrokeThickness="1"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Width="8" Height="8"
                                              Stretch="Fill"
                                              FlowDirection="LeftToRight"/>
                                    </Button>

                                    <TextBlock x:Name="TabTitle"
                                               Text="{Binding Title}"
                                               FontSize="11"
                                               FontFamily="Segoe UI"
                                               Padding="8,0"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Opacity="0.75"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                </DockPanel>
                            </Grid>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                    <Setter TargetName="CloseTabBtn" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="TabRoot"     Property="Background" Value="#0A808080"/>
                                    <Setter TargetName="TabTitle"    Property="Opacity"    Value="0.9"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="ActiveBar"   Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="TabRoot"     Property="Background"
                                            Value="{Binding Background, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    <Setter TargetName="CloseTabBtn" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="TabTitle"    Property="Opacity"    Value="1"/>
                                    <Setter TargetName="TabTitle"    Property="FontWeight"  Value="SemiBold"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             ROW 1 — ADDRESS BAR
             Same bg as content (UserControl.Background) — toolbar is "white".
             Single border at bottom separates chrome from browser content.
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=UserControl}}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="4,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>     <!-- address bar — left in RTL  -->
                    <ColumnDefinition Width="Auto"/>  <!-- nav buttons — right in RTL -->
                </Grid.ColumnDefinitions>

                <ComboBox x:Name="AddressBarCombo"
                          Grid.Column="0"
                          Style="{StaticResource AddressBarCombo}"
                          IsDropDownOpen="{Binding ElementName=BrowserTabs, Path=IsAddressDropDownOpen, Mode=TwoWay}"
                          ItemsSource="{Binding ElementName=BrowserTabs, Path=VisibleAddressModels}"
                          SelectedValue="{Binding ElementName=BrowserTabs, Path=CurrentAddressModel}">
                    <ComboBox.InputBindings>
                        <KeyBinding Key="Return"
                                    Command="{Binding ElementName=BrowserTabs, Path=NavigateCommand}"/>
                    </ComboBox.InputBindings>
                </ComboBox>

                <StackPanel Orientation="Horizontal" Grid.Column="1"
                            FlowDirection="LeftToRight"
                            Margin="4,0,0,0">
                    <Button ToolTip="חזור אחורה"
                            Command="{Binding ElementName=BrowserTabs, Path=GoBackCommand}">
                        <Viewbox Width="16" Height="16" FlowDirection="LeftToRight">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      Data="{StaticResource Icon.Back}"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <Button ToolTip="קדימה"
                            Command="{Binding ElementName=BrowserTabs, Path=GoForwardCommand}">
                        <Viewbox Width="16" Height="16" FlowDirection="LeftToRight">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      Data="{StaticResource Icon.Forward}"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <Button ToolTip="רענן"
                            Command="{Binding ElementName=BrowserTabs, Path=RefreshCommand}">
                        <Viewbox Width="16" Height="16" FlowDirection="LeftToRight">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      Data="{StaticResource Icon.Reload}"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             ROW 2 — BROWSER CONTENT
        ══════════════════════════════════════════════════════════ -->
        <local:BrowserTabControl x:Name="BrowserTabs" Grid.Row="2"/>

    </Grid>
</UserControl>
