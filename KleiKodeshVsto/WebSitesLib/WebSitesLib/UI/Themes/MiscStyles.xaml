<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Thin Edge-style scrollbar — matches RegexFindLib ─────── -->
    <ControlTemplate x:Key="ScrollThumb" TargetType="Thumb">
        <Border x:Name="Bd" Background="#4D808080" CornerRadius="0"
                Margin="2,2,2,2" MinHeight="20" MinWidth="8"/>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#66808080"/>
            </Trigger>
            <Trigger Property="IsDragging" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#80808080"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="VertScrollBar" TargetType="ScrollBar">
        <Grid Width="12">
            <Track x:Name="PART_Track" IsDirectionReversed="True">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                  Background="Transparent" BorderThickness="0" Opacity="0"/>
                </Track.DecreaseRepeatButton>
                <Track.Thumb><Thumb Template="{StaticResource ScrollThumb}"/></Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                  Background="Transparent" BorderThickness="0" Opacity="0"/>
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="HorzScrollBar" TargetType="ScrollBar">
        <Grid Height="12">
            <Track x:Name="PART_Track">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageLeftCommand"
                                  Background="Transparent" BorderThickness="0" Opacity="0"/>
                </Track.DecreaseRepeatButton>
                <Track.Thumb><Thumb Template="{StaticResource ScrollThumb}"/></Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageRightCommand"
                                  Background="Transparent" BorderThickness="0" Opacity="0"/>
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <Style TargetType="ScrollBar">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Width"    Value="12"/>
                <Setter Property="MinWidth" Value="12"/>
                <Setter Property="Template" Value="{StaticResource VertScrollBar}"/>
            </Trigger>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height"    Value="12"/>
                <Setter Property="MinHeight" Value="12"/>
                <Setter Property="Template"  Value="{StaticResource HorzScrollBar}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── ListBox — transparent, no border ─────────────────────── -->
    <Style TargetType="ListBox">
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Padding"          Value="0"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>

    <!-- ── Tab strip list item — no chrome ──────────────────────── -->
    <Style x:Key="TabItemStyle" TargetType="ListBoxItem">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="IsSelected"       Value="{Binding IsSelected}"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Padding"          Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <ContentPresenter/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Dialog list item ──────────────────────────────────────── -->
    <Style x:Key="DialogListItem" TargetType="ListBoxItem">
        <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
        <Setter Property="Padding"                    Value="10,6"/>
        <Setter Property="Cursor"                     Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd" Background="Transparent"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#0A808080"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#14808080"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── CheckBox — VSCode-style square tick ───────────────────── -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground"
                Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=FrameworkElement}}"/>
        <Setter Property="FontFamily"       Value="Segoe UI"/>
        <Setter Property="FontSize"         Value="12"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="Box"
                                Width="14" Height="14"
                                CornerRadius="2"
                                BorderThickness="1"
                                BorderBrush="#50808080"
                                Background="Transparent"
                                Margin="0,0,6,0">
                            <Path x:Name="Tick"
                                  Data="M2,7 L5,10 L10,3"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=FrameworkElement}}"
                                  StrokeThickness="1.5"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="9" Height="9"
                                  Opacity="0"
                                  Margin="1"/>
                        </Border>
                        <ContentPresenter VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Tick" Property="Opacity"     Value="1"/>
                            <Setter TargetName="Box"  Property="Background"  Value="#14808080"/>
                            <Setter TargetName="Box"  Property="BorderBrush" Value="#80808080"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush"  Value="#80808080"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Separator line ────────────────────────────────────────── -->
    <Style x:Key="SeparatorLine" TargetType="Rectangle">
        <Setter Property="Height"           Value="1"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
        <Setter Property="Fill"             Value="#50808080"/>
    </Style>

</ResourceDictionary>
