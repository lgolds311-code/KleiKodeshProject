<Window x:Class="WebSitesLib.WhiteListDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WebSitesLib"
        xmlns:helpers="clr-namespace:WpfLib.Helpers;assembly=WpfLib"
        xmlns:ap="clr-namespace:WpfLib.AttachedProperties;assembly=WpfLib"
        xmlns:dd="urn:gong-wpf-dragdrop"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        Title="רשימת אתרים מותרים"
        MaxHeight="350"
        MinWidth="320"
        PreviewKeyDown="Window_PreviewKeyDown"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown"
        TouchDown="Window_TouchDown"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI"
        x:Name="Root">

    <Window.Resources>
        <ResourceDictionary>

            <!-- ══════════════════════════════════════════════════════
            ICON GEOMETRY
            ══════════════════════════════════════════════════════ -->
            <Geometry x:Key="CloseIcon">M10.9393 12L6.9696 15.9697L8.03026 17.0304L12 13.0607L15.9697 17.0304L17.0304 15.9697L13.0607 12L17.0303 8.03039L15.9696 6.96973L12 10.9393L8.03038 6.96973L6.96972 8.03039L10.9393 12Z</Geometry>
            <Geometry x:Key="MoveUpIcon">M13,20H11V8L5.5,13.5L4.08,12.08L12,4.16L19.92,12.08L18.5,13.5L13,8V20Z</Geometry>
            <Geometry x:Key="MoveDownIcon">M11,4H13V16L18.5,10.5L19.92,11.92L12,19.84L4.08,11.92L5.5,10.5L11,16V4Z</Geometry>

            <!-- ══════════════════════════════════════════════════════
            PATH (icon glyphs)
            ══════════════════════════════════════════════════════ -->
            <Style TargetType="Path">
                <Setter Property="Fill"    Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}"/>
                <Setter Property="Stretch" Value="Uniform"/>
                <Setter Property="Width"   Value="14"/>
                <Setter Property="Height"  Value="14"/>
                <Setter Property="Margin"  Value="0"/>
                <Setter Property="Opacity" Value="0.75"/>
            </Style>

            <!-- ══════════════════════════════════════════════════════
            ICON BUTTON — flat, square, VSCode toolbar style
            ══════════════════════════════════════════════════════ -->
            <Style x:Key="IconButton" TargetType="Button">
                <Setter Property="FlowDirection"    Value="RightToLeft"/>
                <Setter Property="Background"       Value="Transparent"/>
                <Setter Property="BorderThickness"  Value="0"/>
                <Setter Property="Padding"          Value="6"/>
                <Setter Property="Cursor"           Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="2"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush
                                                Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Opacity="0.10"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Path.Opacity" Value="1"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush
                                                Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Opacity="0.17"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.35"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Implicit Button → IconButton -->
            <Style TargetType="Button" BasedOn="{StaticResource IconButton}"/>

            <!-- ══════════════════════════════════════════════════════
            OK / ACTION BUTTON — bordered, VSCode secondary button
            ══════════════════════════════════════════════════════ -->
            <Style x:Key="ActionButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
                <Setter Property="Padding"     Value="12,5"/>
                <Setter Property="FontSize"    Value="12"/>
                <Setter Property="FontFamily"  Value="Segoe UI"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    CornerRadius="2"
                                    BorderThickness="1"
                                    Padding="{TemplateBinding Padding}">
                                <Border.Background>
                                    <SolidColorBrush
                                        Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Opacity="0.05"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush
                                        Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Opacity="0.20"/>
                                </Border.BorderBrush>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush
                                                Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Opacity="0.10"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter TargetName="Bd" Property="BorderBrush">
                                        <Setter.Value>
                                            <SolidColorBrush
                                                Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Opacity="0.40"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush
                                                Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Opacity="0.17"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.35"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══════════════════════════════════════════════════════
            CHECKBOX — VSCode-style square tick box
            ══════════════════════════════════════════════════════ -->
            <Style TargetType="CheckBox">
                <Setter Property="FlowDirection"    Value="RightToLeft"/>
                <Setter Property="Foreground"       Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}"/>
                <Setter Property="FontFamily"       Value="Segoe UI"/>
                <Setter Property="FontSize"         Value="12"/>
                <Setter Property="Cursor"           Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <!-- The box -->
                                <Border x:Name="Box"
                                        Width="14" Height="14"
                                        CornerRadius="2"
                                        BorderThickness="1"
                                        Margin="0,0,6,0">
                                    <Border.BorderBrush>
                                        <SolidColorBrush
                                            Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Opacity="0.40"/>
                                    </Border.BorderBrush>
                                    <Border.Background>
                                        <SolidColorBrush
                                            Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Opacity="0.05"/>
                                    </Border.Background>
                                    <!-- Tick mark -->
                                    <Path x:Name="Tick"
                                          Data="M2,7 L5,10 L10,3"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}"
                                          StrokeThickness="1.5"
                                          Fill="Transparent"
                                          Stretch="Uniform"
                                          Width="9" Height="9"
                                          Opacity="0"
                                          Margin="1"/>
                                </Border>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Tick" Property="Opacity" Value="1"/>
                                    <Setter TargetName="Box" Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush
                                                Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Opacity="0.15"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter TargetName="Box" Property="BorderBrush">
                                        <Setter.Value>
                                            <SolidColorBrush
                                                Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Opacity="0.60"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Box" Property="BorderBrush">
                                        <Setter.Value>
                                            <SolidColorBrush
                                                Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Opacity="0.65"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══════════════════════════════════════════════════════
            LIST BOX
            ══════════════════════════════════════════════════════ -->
            <Style TargetType="ListBox">
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="0"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
                <Setter Property="BorderBrush">
                    <Setter.Value>
                        <SolidColorBrush
                            Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=Window}}"
                            Opacity="0.12"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══════════════════════════════════════════════════════
            LIST BOX ITEM
            ══════════════════════════════════════════════════════ -->
            <Style TargetType="ListBoxItem">
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Padding"          Value="10,6"/>
                <Setter Property="Cursor"           Value="Hand"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="Bd"
                                    Background="Transparent"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush
                                                Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Opacity="0.06"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush
                                                Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Opacity="0.10"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══════════════════════════════════════════════════════
            SEPARATOR LINE
            ══════════════════════════════════════════════════════ -->
            <Style x:Key="SeparatorLineStyle" TargetType="Rectangle">
                <Setter Property="Height" Value="1"/>
                <Setter Property="IsHitTestVisible" Value="False"/>
                <Setter Property="Fill">
                    <Setter.Value>
                        <SolidColorBrush
                            Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=Window}}"
                            Opacity="0.10"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══════════════════════════════════════════════════════
            TITLE BAR BORDER
            ══════════════════════════════════════════════════════ -->
            <Style x:Key="TitleBarStyle" TargetType="Border">
                <Setter Property="Padding" Value="8,5"/>
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush
                            Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=Window}}"
                            Opacity="0.04"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══════════════════════════════════════════════════════
            TITLE TEXT
            ══════════════════════════════════════════════════════ -->
            <Style x:Key="TitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily"  Value="Segoe UI"/>
                <Setter Property="FontSize"    Value="12"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin"      Value="4,0,0,0"/>
                <Setter Property="Opacity"     Value="0.85"/>
                <Setter Property="Foreground"
                        Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}"/>
            </Style>

            <!-- ══════════════════════════════════════════════════════
            ITEM NAME / DESCRIPTION TextBlock styles
            ══════════════════════════════════════════════════════ -->
            <Style x:Key="ItemNameStyle" TargetType="TextBlock">
                <Setter Property="FontFamily"  Value="Segoe UI"/>
                <Setter Property="FontSize"    Value="12"/>
                <Setter Property="Foreground"
                        Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}"/>
            </Style>

            <Style x:Key="ItemDescriptionStyle" TargetType="TextBlock"
                   BasedOn="{StaticResource ItemNameStyle}">
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="Opacity"  Value="0.50"/>
                <Setter Property="Margin"   Value="0,1,0,0"/>
            </Style>

            <!-- ══════════════════════════════════════════════════════
            FOOTER BORDER
            ══════════════════════════════════════════════════════ -->
            <Style x:Key="FooterBorderStyle" TargetType="Border">
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush
                            Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=Window}}"
                            Opacity="0.03"/>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <!-- ══════════════════════════════════════════════════════════════
    WINDOW CHROME  (WindowStyle=None → we draw our own frame)
    ══════════════════════════════════════════════════════════════ -->
    <Border BorderThickness="1"
            CornerRadius="2"
            Background="{Binding Background, RelativeSource={RelativeSource AncestorType=Window}}">
        <Border.BorderBrush>
            <SolidColorBrush
                Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=Window}}"
                Opacity="0.18"/>
        </Border.BorderBrush>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Title bar   -->
                <RowDefinition Height="Auto"/>
                <!-- Separator   -->
                <RowDefinition Height="*"/>
                <!-- List        -->
                <RowDefinition Height="Auto"/>
                <!-- Separator   -->
                <RowDefinition Height="Auto"/>
                <!-- Footer      -->
            </Grid.RowDefinitions>

            <!-- ── TITLE BAR ─────────────────────────────────────── -->
            <Border Grid.Row="0" Style="{StaticResource TitleBarStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <!-- Close btn  -->
                        <ColumnDefinition Width="auto"/>
                        <!-- Title text  -->
                    </Grid.ColumnDefinitions>

                    <Button x:Name="CloseButton"
                            Grid.Column="1"
                            ToolTip="סגור"
                            Click="CloseButton_Click">
                        <Path Data="{StaticResource CloseIcon}" Width="12" Height="12"/>
                    </Button>

                    <TextBlock Grid.Column="0"
                               Style="{StaticResource TitleTextStyle}"
                               Text="רשימת אתרים מותרים"/>
                </Grid>
            </Border>

            <!-- separator -->
            <Rectangle Grid.Row="1" Style="{StaticResource SeparatorLineStyle}"/>

            <!-- ── WHITELIST ──────────────────────────────────────── -->
            <ListBox x:Name="Whitelist"
                     Grid.Row="2"
                     x:FieldModifier="public"
                     ItemsSource="{Binding WebAddressModels}"
                     MinHeight="120"
                     dd:DragDrop.IsDragSource="True"
                     dd:DragDrop.IsDropTarget="True">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox x:Name="checkBox"
                                      IsChecked="{Binding IsVisible}"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"/>
                            <StackPanel x:Name="stackPanel" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}"
                                           Style="{StaticResource ItemNameStyle}"/>
                                <TextBlock Text="{Binding Description}"
                                           Style="{StaticResource ItemDescriptionStyle}"/>
                            </StackPanel>
                        </StackPanel>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsVisible}" Value="false">
                                <Setter TargetName="stackPanel" Property="Opacity" Value="0.40"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- separator -->
            <Rectangle Grid.Row="3" Style="{StaticResource SeparatorLineStyle}"/>

            <!-- ── FOOTER: move buttons · OK · select-all ─────────── -->
            <Border Grid.Row="4" Style="{StaticResource FooterBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <!-- OK button        -->
                        <ColumnDefinition Width="*"/>
                        <!-- Move buttons     -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Select-all check -->
                    </Grid.ColumnDefinitions>

                    <!-- Select all -->
                    <CheckBox x:Name="CheckAllBox"
                              Grid.Column="0"
                              Content="סמן הכל"
                              VerticalAlignment="Center"
                              Checked="CheckAllBox_CheckChanged"
                              Unchecked="CheckAllBox_CheckChanged"/>

                    <!-- Move up / down -->
                    <StackPanel Orientation="Horizontal"
                                Grid.Column="1"
                                HorizontalAlignment="Center">
                        <Button x:Name="MoveUpButton"
                                ToolTip="הזז למעלה"
                                Click="MoveUpButton_Click">
                            <Path Data="{StaticResource MoveUpIcon}"/>
                        </Button>
                        <Button x:Name="MoveDownButton"
                                ToolTip="הזז למטה"
                                Click="MoveDownButton_Click">
                            <Path Data="{StaticResource MoveDownIcon}"/>
                        </Button>
                    </StackPanel>

                    <!-- OK -->
                    <Button x:Name="OK_Button"
                            Grid.Column="2"
                            Style="{StaticResource ActionButton}"
                            Content="אישור"
                            Width="90"
                            Click="OK_Button_Click"/>
                </Grid>
            </Border>

        </Grid>
    </Border>

</Window>
