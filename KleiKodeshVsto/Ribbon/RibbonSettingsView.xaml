<UserControl x:Class="KleiKodesh.Ribbon.RibbonSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             FlowDirection="RightToLeft"
             FontFamily="Segoe UI"
             FontSize="13">
    <UserControl.Resources>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="GroupHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Setter Property="BorderBrush" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="Opacity" Value="0.85"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Setter Property="Opacity" Value="0.2"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="Padding" Value="14,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                <Setter Property="Foreground" Value="{Binding Background, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Background="{Binding Background, RelativeSource={RelativeSource AncestorType=UserControl}}">
        <StackPanel Margin="12" Background="Transparent">

            <Border Style="{StaticResource Card}">
                <StackPanel x:Name="VisibleSettingsPanel">
                    <TextBlock Style="{StaticResource GroupHeader}" Text="רכיבים זמינים"/>
                    <Separator/>
                    <!--
                        IMPORTANT — control names are registry settings keys.
                        InitializeControls() iterates VisibleSettingsPanel.Children and passes cb.Name
                        directly to SettingsManager as the key (e.g. "KitveiHakodesh_Visible").
                        Do NOT rename these — the name IS the key.
                        Format: {ComponentId}_Visible
                    -->
                    <CheckBox x:Name="KitveiHakodesh_Visible"    Content="כתבי הקודש"/>
                    <CheckBox x:Name="Kiwix_Visible"      Content="קיוויקס"/>
                    <CheckBox x:Name="WebSites_Visible"   Content="דרך האתרים"/>
                    <CheckBox x:Name="KleiKodesh_Visible" Content="עיצוב תורני"/>
                    <CheckBox x:Name="RegexFind_Visible"  Content="חיפוש רגקס" Margin="0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel x:Name="OptionsSettingsPanel">
                    <TextBlock Style="{StaticResource GroupHeader}" Text="לחצן ראשי"/>
                    <Separator/>
                    <!--
                        IMPORTANT — control names encode the settings value.
                        InitializeControls() iterates OptionsSettingsPanel.Children and derives the
                        DefaultButton value by stripping "_Option" from rb.Name (e.g. "KitveiHakodesh_Option" → "KitveiHakodesh").
                        Do NOT rename these — the name IS the value.
                        Format: {ComponentId}_Option  (ComponentId must match the one used in _Visible above)
                        Settings_Option is the fallback and is not tied to a visibility checkbox.
                    -->
                    <RadioButton x:Name="KitveiHakodesh_Option"    Content="כתבי הקודש"        IsEnabled="{Binding IsChecked, ElementName=KitveiHakodesh_Visible}"/>
                    <RadioButton x:Name="Kiwix_Option"      Content="קיוויקס"     IsEnabled="{Binding IsChecked, ElementName=Kiwix_Visible}"/>
                    <RadioButton x:Name="WebSites_Option"   Content="דרך האתרים"  IsEnabled="{Binding IsChecked, ElementName=WebSites_Visible}"/>
                    <RadioButton x:Name="KleiKodesh_Option" Content="עיצוב תורני" IsEnabled="{Binding IsChecked, ElementName=KleiKodesh_Visible}"/>
                    <RadioButton x:Name="RegexFind_Option"  Content="חיפוש רגקס"  IsEnabled="{Binding IsChecked, ElementName=RegexFind_Visible}"/>
                    <RadioButton x:Name="Settings_Option"   Content="הגדרות"      Margin="0"/>
                </StackPanel>
            </Border>

            <CheckBox x:Name="ChkTurnOffUpdates"
                      Content="כבה בדיקת עדכונים אוטומטית"
                      Margin="0,0,0,8"/>

            <Button x:Name="BtnReset" Content="איפוס התוכנה"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
