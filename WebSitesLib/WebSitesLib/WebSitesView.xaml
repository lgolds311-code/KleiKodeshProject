<UserControl x:Class="WebSitesLib.WebSitesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WebSitesLib"
             xmlns:ap="clr-namespace:WpfLib.AttachedProperties;assembly=WpfLib"
             xmlns:conv="clr-namespace:WpfLib.Converters;assembly=WpfLib"
             xmlns:sys="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
             mc:Ignorable="d"
             d:DesignHeight="450" MinWidth="350"
             FontSize="14"
             FontFamily="Tahoma"
             x:Name="Root">

    <UserControl.DataContext>
        <local:WebSitesViewModel x:Name="vm"/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <ResourceDictionary>
            <conv:BoolToFlowDirectionConverter x:Key="BoolToFlowConverter"/>
            <sys:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/WpfLib;component/Dictionaries/BaseDictionary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid ap:GridSetup.Columns="auto * auto"
          ap:GridSetup.Rows="auto auto *">

        <!-- ── ROW 0: Chrome tab strip ────────────────────────────────── -->
        <Grid Grid.Row="0" Grid.ColumnSpan="3" Background="#DEE1E6"
              FlowDirection="RightToLeft">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <!-- Add tab button -->
            <Button Grid.Column="2"
                    Content="+"
                    FontSize="16"
                    Width="30"
                    Background="Transparent"
                    BorderThickness="0"
                    MinWidth="{Binding ActualHeight, RelativeSource={RelativeSource Mode=Self}}"
                    Command="{Binding AddTabCommand, ElementName=Tabs}"
                    ToolTip="כרטיסייה חדשה"/>

            <!-- Overflow button + popup -->
            <Grid Grid.Column="1">
                <Button x:Name="OverflowButton"
                        Content="▼"
                        FontSize="10"
                        Width="24"
                        Background="Transparent"
                        BorderThickness="0"
                        MinWidth="{Binding ActualHeight, RelativeSource={RelativeSource Mode=Self}}"
                        Click="OverflowButton_Click"
                        ToolTip="כרטיסיות נוספות"/>

                <Popup x:Name="OverflowPopup"
                       PlacementTarget="{Binding ElementName=OverflowButton}"
                       Placement="Bottom"
                       StaysOpen="False">
                    <Border Background="White"
                            BorderBrush="#BEC0C4"
                            BorderThickness="1"
                            MinWidth="200">
                        <ScrollViewer MaxHeight="300"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl Tag="{Binding ElementName=Tabs}"
                                          ItemsSource="{Binding Tag.Items, RelativeSource={RelativeSource Self}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0"
                                                    Content="✕"
                                                    Width="14" Height="14"
                                                    FontSize="8"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Command="{Binding Tag.CloseTabCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Title}"
                                                       Margin="8,0,0,0"
                                                       Padding="0,4"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Cursor="Hand">
                                                <TextBlock.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick"
                                                                  Command="{Binding Tag.PromoteTabCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                  CommandParameter="{Binding}"/>
                                                </TextBlock.InputBindings>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Popup>
            </Grid>

            <!-- Tab chips — clipped, no scroll -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Items, ElementName=Tabs}"
                     SelectedItem="{Binding SelectedItem, ElementName=Tabs, Mode=TwoWay}"
                     Background="Transparent"
                     BorderThickness="0"
                     ClipToBounds="True"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Title}"
                                       MaxWidth="100"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"/>
                            <Button Content="✕"
                                    Width="14" Height="14"
                                    FontSize="8"
                                    Margin="6,0,0,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding CloseTabCommand, ElementName=Tabs}"
                                    CommandParameter="{Binding}"
                                    Visibility="{Binding IsSelected,
                                    RelativeSource={RelativeSource AncestorType=ListBoxItem},
                                    Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="Margin" Value="1,4,0,0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Background" Value="#D2D5DA"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="#BEC0C4"
                                            BorderThickness="1,1,1,0"
                                            CornerRadius="6,6,0,0"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#E8EAED"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="White"/>
                                            <Setter Property="Margin" Value="1,2,0,0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

        </Grid>

        <!-- ── ROW 1: Navigation toolbar ──────────────────────────────── -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">

            <Button Style="{StaticResource FlatButton}"
                    ToolTip="קדימה"
                    Command="{Binding GoForwardCommand, ElementName=Tabs}">
                <Path Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z"/>
            </Button>

            <Button Style="{StaticResource FlatButton}"
                    ToolTip="חזור אחורה"
                    Command="{Binding GoBackCommand, ElementName=Tabs}">
                <Path Data="M4,11V13H16L10.5,18.5L11.92,19.92L19.84,12L11.92,4.08L10.5,5.5L16,11H4Z"/>
            </Button>

            <Button Style="{StaticResource FlatButton}"
                    ToolTip="ריענון"
                    Command="{Binding ReloadCommand, ElementName=Tabs}">
                <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"/>
            </Button>

        </StackPanel>

        <!-- ── ROW 1: Address bar ──────────────────────────────────────── -->
        <Border Grid.Row="1" Grid.Column="1" Margin="5"
                BorderThickness="1" BorderBrush="LightGray">
            <ComboBox x:Name="AdressBar"
                      IsEditable="True"
                      FlowDirection="RightToLeft"
                      ItemsSource="{Binding VisibleAdresses}"
                      SelectedValuePath="Url"
                      BorderThickness="0"
                      SelectedIndex="-1"
                      HorizontalContentAlignment="Left">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="3">
                            <TextBlock Text="{Binding Name}"/>
                            <TextBlock Text="{Binding Description}"
                                       Opacity="0.5" FontSize="10"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Border>

        <!-- ── ROW 1: Edit whitelist button ───────────────────────────── -->
        <Button Grid.Row="1" Grid.Column="2"
                ToolTip="ערוך רשימת אתרים"
                Margin="5"
                Style="{StaticResource FlatButton}"
                Command="{Binding ShowWhiteListCommand}"
                CommandParameter="{Binding ElementName=Root}">
            <Path Data="M2,6V8H14V6H2M2,10V12H14V10H2M20.04,10.13C19.9,10.13 19.76,10.19 19.65,10.3L18.65,11.3L20.7,13.35L21.7,12.35C21.92,12.14 21.92,11.79 21.7,11.58L20.42,10.3C20.31,10.19 20.18,10.13 20.04,10.13M18.07,11.88L12,17.94V20H14.06L20.12,13.93L18.07,11.88M2,14V16H10V14H2Z"/>
        </Button>

        <!-- ── ROW 2: Browser tab control ─────────────────────────────── -->
        <local:BrowserTabControl x:Name="Tabs"
                                 Grid.Row="2"
                                 Grid.ColumnSpan="3"
                                 Address="{Binding SelectedValue,
                                 ElementName=AdressBar,
                                 Mode=TwoWay}"/>
    </Grid>
</UserControl>
