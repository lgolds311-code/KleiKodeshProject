<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:WebSitesLib">

    <!-- ══════════════════════════════════════════════════════════════════
    BrowserTabControl – custom ControlTemplate

    Layout (top strip):
    ┌──────────────────────────────────────┬───┬───┐
    │  [tab][tab][tab]  (visible tabs)      │ ▼ │ + │
    └──────────────────────────────────────┴───┴───┘
    │                                               │
    │              content area                     │
    └───────────────────────────────────────────────┘

    The tab strip is a single-row ItemsPresenter clipped horizontally.
    Overflow is detected in code-behind; the ▼ button is visible only
    when there are hidden tabs.
    ════════════════════════════════════════════════════════════════════ -->

    <Style TargetType="{x:Type local:BrowserTabControl}">
        <Setter Property="TabStripPlacement" Value="Top"/>
        <Setter Property="Background"         Value="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"/>
        <Setter Property="BorderBrush"        Value="#AAAAAA"/>
        <Setter Property="BorderThickness"    Value="0,0,0,1"/>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" IsItemsHost="True"/>
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:BrowserTabControl}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- tab strip row -->
                            <RowDefinition Height="*"/>
                            <!-- content row   -->
                        </Grid.RowDefinitions>

                        <!-- ── Tab strip ──────────────────────────────── -->
                        <Border Grid.Row="0"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="#F0F0F0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <!-- visible tab strip (clips overflow) -->
                                    <ColumnDefinition Width="*"/>
                                    <!-- overflow ▼ button -->
                                    <ColumnDefinition Width="Auto"/>
                                    <!-- add + button -->
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Single-row, clipped tab host -->
                                <ScrollViewer x:Name="PART_TabScroller"
                                              Grid.Column="0"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Disabled"
                                              Focusable="False">
                                    <ItemsPresenter x:Name="PART_HeaderPanel"
                                                    SnapsToDevicePixels="True"/>
                                </ScrollViewer>

                                <!-- Overflow dropdown button (hidden when all tabs fit) -->
                                <Button x:Name="PART_OverflowButton"
                                        Grid.Column="1"
                                        Width="24"
                                        Focusable="False"
                                        Visibility="Collapsed"
                                        ToolTip="הצג את כל הכרטיסיות"
                                        Command="{Binding ToggleOverflowCommand,
                                        RelativeSource={RelativeSource TemplatedParent}}"
                                        Style="{DynamicResource FlatButton}">
                                    <!-- Down-chevron path -->
                                    <Path Data="M7,10L12,15L17,10H7Z"
                                          Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                                          Stretch="Uniform"
                                          Width="12" Height="12"/>

                                </Button>

                                <!-- Overflow popup (positioned in code-behind) -->
                                <Popup x:Name="PART_OverflowPopup"
                                       StaysOpen="False"
                                       Placement="Bottom"
                                       PlacementTarget="{Binding ElementName=PART_OverflowButton}"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade">
                                    <Border Background="White"
                                            BorderBrush="#AAAAAA"
                                            BorderThickness="1"
                                            CornerRadius="2"
                                            Padding="2"
                                            MinWidth="180">
                                        <Border.Effect>
                                            <DropShadowEffect ShadowDepth="2" BlurRadius="4"
                                                              Opacity="0.3" Direction="270"/>
                                        </Border.Effect>
                                        <ListBox x:Name="PART_OverflowList"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 MaxHeight="300"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                    </Border>
                                </Popup>

                                <!-- Add tab button -->
                                <Button Grid.Column="2"
                                        Width="28"
                                        Margin="2,0"
                                        Focusable="False"
                                        ToolTip="פתח כרטיסייה חדשה"
                                        Command="{Binding AddTabCommand,
                                        RelativeSource={RelativeSource TemplatedParent}}"
                                        Style="{DynamicResource FlatButton}">
                                    <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                                          Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                                          Stretch="Uniform"
                                          Width="14" Height="14"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- ── Content area ────────────────────────────── -->
                        <Border Grid.Row="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,0,1,1">
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              Content="{TemplateBinding SelectedContent}"
                                              ContentTemplate="{TemplateBinding SelectedContentTemplate}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════
    BrowserTabItem style
    ════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="{x:Type local:BrowserTabItem}">
        <Setter Property="Padding"          Value="8,4"/>
        <Setter Property="MinWidth"         Value="80"/>
        <Setter Property="MaxWidth"         Value="200"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:BrowserTabItem}">
                    <Border x:Name="Bd"
                            Background="#E0E0E0"
                            BorderBrush="#AAAAAA"
                            BorderThickness="1,1,1,0"
                            CornerRadius="4,4,0,0"
                            Margin="2,4,0,0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter ContentSource="Header"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"/>
                            <Setter TargetName="Bd" Property="Margin"
                                    Value="2,2,0,0"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#D4D4D4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
