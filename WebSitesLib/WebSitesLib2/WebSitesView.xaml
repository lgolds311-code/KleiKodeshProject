<UserControl x:Class="WebSitesLib2.WebSitesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WebSitesLib2"
             mc:Ignorable="d"
             FlowDirection="RightToLeft"
             FontFamily="Segoe UI"
             x:Name="Root">

    <UserControl.Resources>
        <ResourceDictionary>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <!-- ══════════════════════════════════════════════════════════
            ICON GEOMETRY
            ══════════════════════════════════════════════════════════ -->
            <Geometry x:Key="BackIcon">M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z</Geometry>
            <Geometry x:Key="ForwardIcon">M4,11V13H16L10.5,18.5L11.92,19.92L19.84,12L11.92,4.08L10.5,5.5L16,11H4Z</Geometry>
            <Geometry x:Key="ReloadIcon">M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z</Geometry>
            <Geometry x:Key="EditWhitelistIcon">M2,6V8H14V6H2M2,10V12H14V10H2M20.04,10.13C19.9,10.13 19.76,10.19 19.65,10.3L18.65,11.3L20.7,13.35L21.7,12.35C21.92,12.14 21.92,11.79 21.7,11.58L20.42,10.3C20.31,10.19 20.18,10.13 20.04,10.13M18.07,11.88L12,17.94V20H14.06L20.12,13.93L18.07,11.88M2,14V16H10V14H2Z</Geometry>
            <Geometry x:Key="AddIcon">M12 3.25a.75.75 0 0 1 .75.75v7.25H20a.75.75 0 0 1 0 1.5h-7.25V20a.75.75 0 0 1-1.5 0v-7.25H4a.75.75 0 0 1 0-1.5h7.25V4a.75.75 0 0 1 .75-.75</Geometry>
            <Geometry x:Key="ChevronDown">M4.21967 6.96967C4.51256 6.67678 4.98744 6.67678 5.28033 6.96967L10 11.6893L14.7197 6.96967C15.0126 6.67678 15.4874 6.67678 15.7803 6.96967C16.0732 7.26256 16.0732 7.73744 15.7803 8.03033L10.5303 13.2803C10.2374 13.5732 9.76256 13.5732 9.46967 13.2803L4.21967 8.03033Z</Geometry>
            <Geometry x:Key="CloseIcon">M 0,0 L 8,8 M 8,0 L 0,8</Geometry>

            <!-- ── PATH (icon glyphs) ─────────────────────────────────── -->
            <Style TargetType="Path">
                <Setter Property="Fill"         Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                <Setter Property="Stretch"      Value="Uniform"/>
                <Setter Property="Width"        Value="14"/>
                <Setter Property="Height"       Value="14"/>
                <Setter Property="Margin"       Value="0"/>
                <Setter Property="Opacity"      Value="0.75"/>
                <Setter Property="FlowDirection" Value="LeftToRight"/>
            </Style>

            <!-- ══════════════════════════════════════════════════════════
            ICON BUTTON
            ══════════════════════════════════════════════════════════ -->
            <Style x:Key="IconButton" TargetType="Button">
                <Setter Property="FlowDirection"   Value="RightToLeft"/>
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding"         Value="6"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="2"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=UserControl}}" Opacity="0.10"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Path.Opacity" Value="1"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=UserControl}}" Opacity="0.17"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.35"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="Button" BasedOn="{StaticResource IconButton}"/>

            <!-- ══════════════════════════════════════════════════════════
            TOGGLE BUTTON
            ══════════════════════════════════════════════════════════ -->
            <Style TargetType="ToggleButton">
                <Setter Property="FlowDirection"   Value="RightToLeft"/>
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding"         Value="6"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="2"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=UserControl}}" Opacity="0.10"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Bd" Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=UserControl}}" Opacity="0.15"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══════════════════════════════════════════════════════════
            ADDRESS-BAR COMBOBOX
            ══════════════════════════════════════════════════════════ -->
            <Style TargetType="ComboBox">
                <Setter Property="FlowDirection"            Value="RightToLeft"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="IsEditable"               Value="True"/>
                <Setter Property="StaysOpenOnEdit"          Value="True"/>
                <Setter Property="Foreground"  Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                <Setter Property="Background"  Value="{Binding Background, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontSize"    Value="12"/>
                <Setter Property="FontFamily"  Value="Segoe UI"/>
                <Setter Property="Padding"     Value="10,0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="Bd" Grid.ColumnSpan="2" CornerRadius="2" BorderThickness="1">
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=UserControl}}" Opacity="0.18"/>
                                    </Border.BorderBrush>
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=UserControl}}" Opacity="0.04"/>
                                    </Border.Background>
                                </Border>

                                <TextBox x:Name="PART_EditableTextBox"
                                         Grid.Column="0"
                                         Background="Transparent"
                                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                         BorderThickness="0"
                                         Padding="10,5,4,5"
                                         FontFamily="Segoe UI"
                                         FontSize="12"
                                         CaretBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                         VerticalAlignment="Center"/>

                                <ToggleButton x:Name="PART_ToggleButton"
                                              Grid.Column="1"
                                              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Cursor="Hand"
                                              Padding="6,0,8,0"
                                              VerticalAlignment="Stretch"
                                              Focusable="False">
                                    <Path Data="{StaticResource ChevronDown}"
                                          Width="10" Height="10"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          Stretch="Uniform"
                                          Opacity="0.5"/>
                                </ToggleButton>

                                <Popup x:Name="PART_Popup"
                                       Grid.ColumnSpan="2"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       PlacementTarget="{Binding ElementName=Bd}"
                                       Placement="Bottom"
                                       AllowsTransparency="True"
                                       StaysOpen="False">
                                    <Border CornerRadius="2" BorderThickness="1" Padding="2"
                                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding Background.Color, RelativeSource={RelativeSource AncestorType=UserControl}}" Opacity="0.99"/>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=UserControl}}" Opacity="0.20"/>
                                        </Border.BorderBrush>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.30" Direction="270"/>
                                        </Border.Effect>
                                        <ScrollViewer MaxHeight="240">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=UserControl}}" Opacity="0.35"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsDropDownOpen" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=UserControl}}" Opacity="0.55"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══════════════════════════════════════════════════════════
            BROWSER TAB CONTROL — hide native TabPanel
            ══════════════════════════════════════════════════════════ -->
            <Style TargetType="local:BrowserTabControl">
                <Style.Resources>
                    <Style TargetType="TabPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </Style.Resources>
            </Style>

            <!-- ══════════════════════════════════════════════════════════
            LIST BOX
            ══════════════════════════════════════════════════════════ -->
            <Style TargetType="ListBox">
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding"         Value="0"/>
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            </Style>

            <!-- ══════════════════════════════════════════════════════════
            TAB STRIP LIST ITEM
            ══════════════════════════════════════════════════════════ -->
            <Style x:Key="TabItemStyle" TargetType="ListBoxItem">
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="IsSelected"  Value="{Binding IsSelected}"/>
                <Setter Property="Cursor"      Value="Hand"/>
                <Setter Property="Padding"     Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <ContentPresenter/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── TAB CLOSE-BUTTON PATH style ──────────────────────── -->
            <Style x:Key="TabClosePathStyle" TargetType="Path">
                <Setter Property="Data"    Value="{StaticResource CloseIcon}"/>
                <Setter Property="Width"   Value="8"/>
                <Setter Property="Height"  Value="8"/>
                <Setter Property="Stretch" Value="Fill"/>
                <Setter Property="StrokeThickness" Value="1.5"/>
                <Setter Property="Fill"    Value="Transparent"/>
                <Setter Property="Stroke"
                        Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                <Setter Property="Opacity" Value="0.65"/>
            </Style>

            <!-- ── DROPDOWN LIST ITEM BORDER style ──────────────────── -->
            <Style x:Key="DropItemBorderStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="2"/>
                <Setter Property="Padding"      Value="8,4"/>
                <Setter Property="Background"   Value="Transparent"/>
                <Setter Property="Cursor"       Value="Hand"/>
            </Style>

            <!-- ── SEPARATOR LINE style ─────────────────────────────── -->
            <Style x:Key="SeparatorLineStyle" TargetType="Rectangle">
                <Setter Property="Height"             Value="1"/>
                <Setter Property="VerticalAlignment"  Value="Bottom"/>
                <Setter Property="IsHitTestVisible"   Value="False"/>
                <Setter Property="Fill">
                    <Setter.Value>
                        <SolidColorBrush Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=UserControl}}" Opacity="0.10"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── TOOLBAR ROW BORDER style ─────────────────────────── -->
            <Style x:Key="ToolbarBorderStyle" TargetType="Border">
                <Setter Property="Padding" Value="4,3"/>
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=UserControl}}" Opacity="0.03"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── ADDRESS-BAR ROW BORDER style ─────────────────────── -->
            <Style x:Key="AddressBarBorderStyle" TargetType="Border">
                <Setter Property="Padding"     Value="6,5"/>
                <Setter Property="Background"
                        Value="{Binding Background, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            </Style>

            <!-- ── DROPDOWN POPUP BORDER style ──────────────────────── -->
            <Style x:Key="DropdownBorderStyle" TargetType="Border">
                <Setter Property="CornerRadius"    Value="2"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="3"/>
                <Setter Property="MinWidth"        Value="180"/>
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="{Binding Background.Color, RelativeSource={RelativeSource AncestorType=UserControl}}" Opacity="0.98"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderBrush">
                    <Setter.Value>
                        <SolidColorBrush Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=UserControl}}" Opacity="0.18"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.25" Direction="270"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── TAB TITLE TextBlock style ────────────────────────── -->
            <Style x:Key="TabTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize"     Value="12"/>
                <Setter Property="FontFamily"   Value="Segoe UI"/>
                <Setter Property="Margin"       Value="6,0,4,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                <Setter Property="Foreground"
                        Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                <Setter Property="Opacity" Value="0.80"/>
            </Style>

            <Style x:Key="TabTitleActiveStyle" TargetType="TextBlock"
                   BasedOn="{StaticResource TabTitleStyle}">
                <Setter Property="Opacity"    Value="1"/>
                <Setter Property="FontWeight" Value="Normal"/>
            </Style>

        </ResourceDictionary>
    </UserControl.Resources>

    <!-- ══════════════════════════════════════════════════════════════════
    ROOT LAYOUT
    ══════════════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Tab strip  -->
            <RowDefinition Height="Auto"/>
            <!-- Address bar -->
            <RowDefinition Height="*"/>
            <!-- Browser content -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════
        ROW 0 — TAB STRIP
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource ToolbarBorderStyle}" Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Tab list -->
                <ListBox x:Name="TabStrip"
                         Grid.Column="0"
                         ItemsSource="{Binding ElementName=BrowserTabs, Path=TabsCollection}"
                         SelectedIndex="{Binding ElementName=BrowserTabs, Path=SelectedIndex}">
                    <ListBox.Resources>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource TabItemStyle}"/>
                    </ListBox.Resources>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="TabBorder"
                                    MaxWidth="150"
                                    Padding="0"
                                    Margin="0"
                                    Background="Transparent"
                                    BorderThickness="0,0,1,1"
                                    ToolTip="{Binding Title}">
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=UserControl}}" Opacity="0.10"/>
                                </Border.BorderBrush>

                                <Grid Height="35">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Title: fixed width forces TextTrimming to kick in -->
                                    <TextBlock x:Name="TabTitle"
                                               Grid.Column="0"
                                               Style="{StaticResource TabTitleStyle}"
                                               Text="{Binding Title}"
                                               Padding="8,0,4,0"
                                               TextTrimming="CharacterEllipsis"/>

                                    <!-- Close button: hidden until hover / selected -->
                                    <Button x:Name="CloseTabButton"
                                            Grid.Column="1"
                                            ToolTip="סגור כרטיסייה"
                                            Command="{Binding CloseTabCommand}"
                                            Padding="5"
                                            Margin="0,0,4,0"
                                            VerticalAlignment="Center"
                                            Visibility="Hidden">
                                        <Path Style="{StaticResource TabClosePathStyle}"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <DataTemplate.Triggers>
                                <!-- Hover -->
                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                    <Setter TargetName="CloseTabButton" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="TabBorder" Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=UserControl}}" Opacity="0.06"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <!-- Active tab -->
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="TabBorder" Property="Background"
                                            Value="{Binding Background, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    <Setter TargetName="TabBorder" Property="BorderThickness" Value="0,0,1,0"/>
                                    <Setter TargetName="CloseTabButton" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="TabTitle" Property="Opacity" Value="1"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- New-tab button + dropdown toggle -->
                <StackPanel Orientation="Horizontal"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="2,0,2,0">
                    <Button x:Name="AddTabButton"
                            ToolTip="כרטיסייה חדשה"
                            Command="{Binding ElementName=BrowserTabs, Path=NewTabCommand}"
                            Padding="7">
                        <Path Data="{StaticResource AddIcon}" Width="12" Height="12"/>
                    </Button>

                    <ToggleButton x:Name="TabDropDownToggle"
                                  ToolTip="הצג את כל הכרטיסיות"
                                  Padding="7">
                        <Path Data="{StaticResource ChevronDown}" Width="10" Height="10"/>
                    </ToggleButton>

                    <!-- Dropdown: clicking a row calls MoveToFrontCommand on that tab -->
                    <Popup IsOpen="{Binding IsChecked, ElementName=TabDropDownToggle}"
                           PlacementTarget="{Binding ElementName=TabDropDownToggle}"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           StaysOpen="False">
                        <Border Style="{StaticResource DropdownBorderStyle}">
                            <ListBox ItemsSource="{Binding ElementName=BrowserTabs, Path=TabsCollection}"
                                     SelectedIndex="{Binding ElementName=BrowserTabs, Path=SelectedIndex}">
                                <ListBox.Resources>
                                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource TabItemStyle}"/>
                                </ListBox.Resources>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="DropItemBorder"
                                                Style="{StaticResource DropItemBorderStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Clicking the title moves the tab to front -->
                                                <TextBlock Text="{Binding Title}"
                                                           Style="{StaticResource TabTitleStyle}"
                                                           MaxWidth="200"
                                                           Margin="0"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding Title}">
                                                    <TextBlock.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                      Command="{Binding MoveToFrontCommand}"/>
                                                    </TextBlock.InputBindings>
                                                </TextBlock>

                                                <Button Grid.Column="1"
                                                        ToolTip="סגור כרטיסייה"
                                                        Command="{Binding CloseTabCommand}"
                                                        Padding="4"
                                                        Margin="4,0,0,0"
                                                        VerticalAlignment="Center">
                                                    <Path Style="{StaticResource TabClosePathStyle}"
                                                          Width="7" Height="7"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                <Setter TargetName="DropItemBorder" Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=UserControl}}" Opacity="0.08"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter TargetName="DropItemBorder" Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="{Binding Foreground.Color, RelativeSource={RelativeSource AncestorType=UserControl}}" Opacity="0.13"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>
                </StackPanel>
            </Grid>
        </Border>

        <Rectangle Grid.Row="0" Style="{StaticResource SeparatorLineStyle}"/>

        <!-- ══════════════════════════════════════════════════════════
        ROW 1 — ADDRESS / TOOLBAR BAR
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Style="{StaticResource AddressBarBorderStyle}" FlowDirection="LeftToRight">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- nav buttons  -->
                    <ColumnDefinition Width="*"/>
                    <!-- address bar  -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- action btns  -->
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="0,0,2,0">
                    <Button x:Name="GoBackButton"    ToolTip="חזור אחורה" Command="{Binding ElementName=BrowserTabs, Path=GoBackCommand}">
                        <Path Data="{StaticResource BackIcon}"/>
                    </Button>
                    <Button x:Name="GoForwardButton" ToolTip="קדימה"      Command="{Binding ElementName=BrowserTabs, Path=GoForwardCommand}">
                        <Path Data="{StaticResource ForwardIcon}"/>
                    </Button>
                    <Button x:Name="RefreshButton"   ToolTip="רענן"       Command="{Binding ElementName=BrowserTabs, Path=RefreshCommand}">
                        <Path Data="{StaticResource ReloadIcon}"/>
                    </Button>
                </StackPanel>

                <!-- Address ComboBox — shows only visible whitelist entries -->
                <ComboBox x:Name="AddressBarCombo"
                          Grid.Column="1"
                          Margin="4,0"
                          IsDropDownOpen="{Binding ElementName=BrowserTabs, Path=IsTabDropDownOpen}"
                          ItemsSource="{Binding ElementName=BrowserTabs, Path=VisibleAddressModels}"
                          SelectedValue="{Binding ElementName=BrowserTabs, Path=CurrentAddressModel}">
                    <ComboBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding ElementName=BrowserTabs, Path=NavigateCommand}"/>
                    </ComboBox.InputBindings>
                </ComboBox>

                <!-- <Button x:Name="EditWhiteListButton"
                        Grid.Column="2"
                        ToolTip="ערוך רשימה מותרת"
                        Margin="2,0,0,0"
                        Command="{Binding ElementName=BrowserTabs, Path=EditWhiteListCommand}">
                    <Path Data="{StaticResource EditWhitelistIcon}"/>
                </Button> -->
            </Grid>
        </Border>

        <Rectangle Grid.Row="1" Style="{StaticResource SeparatorLineStyle}"/>

        <!-- ══════════════════════════════════════════════════════════
        ROW 2 — BROWSER CONTENT
        ══════════════════════════════════════════════════════════ -->
        <local:BrowserTabControl x:Name="BrowserTabs" Grid.Row="2"/>

    </Grid>
</UserControl>
