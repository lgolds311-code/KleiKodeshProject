<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        VSCode-style square checkbox — adaptive, inherits fg from ancestor.
        All values inlined — no StaticResource inside ControlTemplates (VSTO rule).
    -->

    <Style TargetType="CheckBox">
        <Setter Property="Foreground"
                Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=FrameworkElement}}"/>
        <Setter Property="FontFamily"       Value="Segoe UI"/>
        <Setter Property="FontSize"         Value="12"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="Box"
                                Width="14" Height="14"
                                CornerRadius="2"
                                BorderThickness="1"
                                BorderBrush="#50808080"
                                Background="Transparent"
                                Margin="0,0,6,0">
                            <Path x:Name="Tick"
                                  Data="M2,7 L5,10 L10,3"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=FrameworkElement}}"
                                  StrokeThickness="1.5"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="9" Height="9"
                                  Opacity="0"
                                  Margin="1"/>
                        </Border>
                        <ContentPresenter VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Tick" Property="Opacity"     Value="1"/>
                            <Setter TargetName="Box"  Property="Background"  Value="#14808080"/>
                            <Setter TargetName="Box"  Property="BorderBrush" Value="#80808080"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush"  Value="#80808080"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
