<Page x:Class="KleiKodeshVstoInstallerWpf.RepairPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="#FFFFFF"
      FlowDirection="RightToLeft"
      FontFamily="Segoe UI">

    <Page.Resources>
        <!-- PrimaryButton -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Background"      Value="#7333FF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}" Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5E1FE8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4A0FD4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#CCCCCC"/>
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- SecondaryButton -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Foreground"      Value="#5A5A5A"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F0F0F0"/>
                                <Setter Property="Foreground" Value="#1F1F1F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8E8E8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- GhostButton -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Foreground"      Value="#5A5A5A"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="8,0"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}" Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0F000000"/>
                                <Setter Property="Foreground" Value="#1F1F1F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#17000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- AccentProgress -->
        <Style x:Key="AccentProgress" TargetType="ProgressBar">
            <Setter Property="Height"          Value="3"/>
            <Setter Property="Foreground"      Value="#7333FF"/>
            <Setter Property="Background"      Value="#E5E5E5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"/>
                            <Border x:Name="PART_Track"/>
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    HorizontalAlignment="Left"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon row: fixed icon column + wrapping text column -->
        <Style x:Key="IconRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <!-- Top accent bar -->
        <Border Grid.Row="0" Background="#7333FF"/>

        <!-- Header -->
        <StackPanel Grid.Row="1" Margin="28,22,28,10">
            <TextBlock Text="תיקון כלי קודש"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#1F1F1F"
                       TextWrapping="Wrap"/>
            <TextBlock Text="ניקוי מלא של כל שאריות התוסף מהמחשב"
                       FontSize="13"
                       Foreground="#5A5A5A"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Content — scrollable -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,0,28,12">

            <!-- Warning -->
            <Border Background="#FFFBEB"
                    BorderBrush="#F6D860"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10,7"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Viewbox Width="13" Height="13" Margin="0,1,6,0" VerticalAlignment="Top" FlowDirection="LeftToRight">
                        <Path Data="M6,0 L12,11 L0,11 Z M6,4 L6,7.5 M6,9 L6,9.5"
                              Stroke="#92700A" StrokeThickness="1.2" Fill="Transparent"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Viewbox>
                    <TextBlock Grid.Column="1" TextWrapping="Wrap" Foreground="#92700A" FontSize="12">
                        <Run FontWeight="SemiBold">פעולה זו עשויה לקחת מספר דקות.</Run>
                        <Run>הכלי יסרוק קבצים, תיקיות ורגיסטרי ולאחר מכן יתקין מחדש.</Run>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- What will be cleaned -->
            <TextBlock Text="מה יימחק"
                       FontSize="11"
                       Foreground="#5A5A5A"
                       Margin="0,0,0,5"/>

            <Border BorderBrush="#E5E5E5"
                    BorderThickness="1"
                    CornerRadius="4"
                    Background="#F8F8F8"
                    Padding="10,8"
                    Margin="0,0,0,10">
                <StackPanel>
                    <StackPanel.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontSize"     Value="11"/>
                            <Setter Property="Foreground"   Value="#5A5A5A"/>
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="VerticalAlignment" Value="Top"/>
                        </Style>
                    </StackPanel.Resources>

                    <!-- Each row: icon + wrapping text via Grid -->
                    <Grid Margin="0,2" Style="{StaticResource IconRow}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Viewbox Width="11" Height="11" VerticalAlignment="Top" FlowDirection="LeftToRight">
                            <Path Data="M0,3 L0,10 L12,10 L12,3 L6,3 L4.5,1 L0,1 Z" Stroke="#5A5A5A" StrokeThickness="1" Fill="Transparent" StrokeLineJoin="Round"/>
                        </Viewbox>
                        <TextBlock Grid.Column="1">תיקיות: AppData\Local\KleiKodesh, AppData\Roaming\KleiKodesh, Program Files</TextBlock>
                    </Grid>
                    <Grid Margin="0,2" Style="{StaticResource IconRow}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Viewbox Width="11" Height="11" VerticalAlignment="Top" FlowDirection="LeftToRight">
                            <Path Data="M0,3 L0,10 L12,10 L12,3 L6,3 L4.5,1 L0,1 Z" Stroke="#5A5A5A" StrokeThickness="1" Fill="Transparent" StrokeLineJoin="Round"/>
                        </Viewbox>
                        <TextBlock Grid.Column="1">מטמון WebView2, מטמון PDF, מטמון ספרים, ClickOnce cache</TextBlock>
                    </Grid>
                    <Grid Margin="0,2" Style="{StaticResource IconRow}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/><ColumnDefinition Width="auto"/></Grid.ColumnDefinitions>
                        <Viewbox Width="11" Height="11" VerticalAlignment="Top" FlowDirection="LeftToRight">
                            <Path Data="M8,0 C5.8,0 4,1.8 4,4 C4,5.1 4.4,6.1 5.1,6.8 L0,12 L1,13 L2,12 L3,13 L4,12 L4,10 L6,10 L6,8 L6.8,8 C7.5,8.4 8.2,8.6 9,8.6 C11.2,8.6 13,6.8 13,4.6 C13,2.4 11.2,0.6 9,0.6 Z M9,2 C10.4,2 11.5,3.1 11.5,4.5 C11.5,5.9 10.4,7 9,7 C7.6,7 6.5,5.9 6.5,4.5 C6.5,3.1 7.6,2 9,2 Z" Stroke="#5A5A5A" StrokeThickness="0.5" Fill="#5A5A5A"/>
                        </Viewbox>
                        <TextBlock Grid.Column="1">רגיסטרי: Addins\KleiKodesh + Addins\כלי קודש — HKLM + HKCU</TextBlock>
                        <TextBlock Grid.Column="2" Foreground="#1D4ED8" FontSize="10" Margin="4,0,0,0" VerticalAlignment="Top">
                            <TextBlock.ToolTip>
                                <ToolTip MaxWidth="220" FlowDirection="RightToLeft">
                                    <TextBlock TextWrapping="Wrap" FontSize="11">רשומות HKLM דורשות ניקוי עמוק (הרשאות מנהל).</TextBlock>
                                </ToolTip>
                            </TextBlock.ToolTip>🛡</TextBlock>
                    </Grid>
                    <Grid Margin="0,2" Style="{StaticResource IconRow}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Viewbox Width="11" Height="11" VerticalAlignment="Top" FlowDirection="LeftToRight">
                            <Path Data="M8,0 C5.8,0 4,1.8 4,4 C4,5.1 4.4,6.1 5.1,6.8 L0,12 L1,13 L2,12 L3,13 L4,12 L4,10 L6,10 L6,8 L6.8,8 C7.5,8.4 8.2,8.6 9,8.6 C11.2,8.6 13,6.8 13,4.6 C13,2.4 11.2,0.6 9,0.6 Z M9,2 C10.4,2 11.5,3.1 11.5,4.5 C11.5,5.9 10.4,7 9,7 C7.6,7 6.5,5.9 6.5,4.5 C6.5,3.1 7.6,2 9,2 Z" Stroke="#5A5A5A" StrokeThickness="0.5" Fill="#5A5A5A"/>
                        </Viewbox>
                        <TextBlock Grid.Column="1">רגיסטרי: Uninstall, VSTO Security, VSTO SolutionMetadata, ClickOnce SideBySide</TextBlock>
                    </Grid>
                    <Grid Margin="0,2" Style="{StaticResource IconRow}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Viewbox Width="11" Height="11" VerticalAlignment="Top" FlowDirection="LeftToRight">
                            <Path Data="M8,0 C5.8,0 4,1.8 4,4 C4,5.1 4.4,6.1 5.1,6.8 L0,12 L1,13 L2,12 L3,13 L4,12 L4,10 L6,10 L6,8 L6.8,8 C7.5,8.4 8.2,8.6 9,8.6 C11.2,8.6 13,6.8 13,4.6 C13,2.4 11.2,0.6 9,0.6 Z M9,2 C10.4,2 11.5,3.1 11.5,4.5 C11.5,5.9 10.4,7 9,7 C7.6,7 6.5,5.9 6.5,4.5 C6.5,3.1 7.6,2 9,2 Z" Stroke="#5A5A5A" StrokeThickness="0.5" Fill="#5A5A5A"/>
                        </Viewbox>
                        <TextBlock Grid.Column="1">רגיסטרי: הגדרות זמן-ריצה (KleiKodesh, ZayitApp, KitveiHakodesh)</TextBlock>
                    </Grid>
                    <Grid Margin="0,2" Style="{StaticResource IconRow}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Viewbox Width="11" Height="11" VerticalAlignment="Top" FlowDirection="LeftToRight">
                            <Path Data="M8,0 C5.8,0 4,1.8 4,4 C4,5.1 4.4,6.1 5.1,6.8 L0,12 L1,13 L2,12 L3,13 L4,12 L4,10 L6,10 L6,8 L6.8,8 C7.5,8.4 8.2,8.6 9,8.6 C11.2,8.6 13,6.8 13,4.6 C13,2.4 11.2,0.6 9,0.6 Z M9,2 C10.4,2 11.5,3.1 11.5,4.5 C11.5,5.9 10.4,7 9,7 C7.6,7 6.5,5.9 6.5,4.5 C6.5,3.1 7.6,2 9,2 Z" Stroke="#5A5A5A" StrokeThickness="0.5" Fill="#5A5A5A"/>
                        </Viewbox>
                        <TextBlock Grid.Column="1">רגיסטרי: Word AddInLoadTimes, AddinEventTimes, NotifiedAddins, CustomUICache</TextBlock>
                    </Grid>
                    <Grid Margin="0,2" Style="{StaticResource IconRow}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Viewbox Width="11" Height="11" VerticalAlignment="Top" FlowDirection="LeftToRight">
                            <Path Data="M8,0 C5.8,0 4,1.8 4,4 C4,5.1 4.4,6.1 5.1,6.8 L0,12 L1,13 L2,12 L3,13 L4,12 L4,10 L6,10 L6,8 L6.8,8 C7.5,8.4 8.2,8.6 9,8.6 C11.2,8.6 13,6.8 13,4.6 C13,2.4 11.2,0.6 9,0.6 Z M9,2 C10.4,2 11.5,3.1 11.5,4.5 C11.5,5.9 10.4,7 9,7 C7.6,7 6.5,5.9 6.5,4.5 C6.5,3.1 7.6,2 9,2 Z" Stroke="#5A5A5A" StrokeThickness="0.5" Fill="#5A5A5A"/>
                        </Viewbox>
                        <TextBlock Grid.Column="1">רגיסטרי: Word Resiliency — רק אם מכיל כלי קודש</TextBlock>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Progress (shown during repair) -->
            <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,0,0,8">
                <TextBlock x:Name="StepText"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#1F1F1F"
                           TextWrapping="Wrap"
                           Margin="0,0,0,5"/>
                <ProgressBar x:Name="ProgressBar"
                             Style="{StaticResource AccentProgress}"
                             Minimum="0" Maximum="100" Value="0"/>
            </StackPanel>

            <!-- Log -->
            <Border x:Name="LogPanel"
                    Visibility="Collapsed"
                    BorderBrush="#E5E5E5"
                    BorderThickness="1"
                    CornerRadius="4"
                    Background="#F8F8F8"
                    Margin="0,0,0,8">
                <ScrollViewer x:Name="LogScroller"
                              Height="100"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="10,8">
                    <TextBox x:Name="LogBox"
                             IsReadOnly="True"
                             BorderThickness="0"
                             Background="Transparent"
                             FontFamily="Consolas"
                             FontSize="11"
                             Foreground="#5A5A5A"
                             TextWrapping="Wrap"
                             FlowDirection="LeftToRight"/>
                </ScrollViewer>
            </Border>

            <!-- Summary -->
            <TextBlock x:Name="SummaryText"
                       Visibility="Collapsed"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#1F1F1F"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"/>
        </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="3"
                Background="#F0F0F0"
                BorderBrush="#E5E5E5"
                BorderThickness="0,1,0,0">
            <Grid Margin="10,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="CancelButton"
                        Grid.Column="0"
                        Content="חזור"
                        Style="{StaticResource SecondaryButton}"
                        Click="CancelButton_Click"/>

                <!-- Basic clean button -->
                <Button x:Name="BasicCleanButton"
                        Grid.Column="2"
                        Content="ניקוי בסיסי"
                        Style="{StaticResource SecondaryButton}"
                        Click="BasicCleanButton_Click">
                    <Button.ToolTip>
                        <ToolTip MaxWidth="260" FlowDirection="RightToLeft">
                            <TextBlock TextWrapping="Wrap" FontSize="11">
                                מוחק קבצים, מטמון ורשומות HKCU — ללא צורך בהרשאות מנהל.
                            </TextBlock>
                        </ToolTip>
                    </Button.ToolTip>
                </Button>

                <!-- Deep clean button -->
                <Button x:Name="DeepCleanButton"
                        Grid.Column="4"
                        Content="ניקוי עמוק 🛡"
                        Style="{StaticResource PrimaryButton}"
                        Click="DeepCleanButton_Click">
                    <Button.ToolTip>
                        <ToolTip MaxWidth="260" FlowDirection="RightToLeft">
                            <TextBlock TextWrapping="Wrap" FontSize="11">
                                כולל גם רשומות HKLM (גרסאות ישנות) — דורש הפעלה מחדש כמנהל.
                            </TextBlock>
                        </ToolTip>
                    </Button.ToolTip>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Page>
