<Page x:Class="KleiKodeshVstoInstallerWpf.InstallPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="#FFFFFF"
      FlowDirection="RightToLeft"
      FontFamily="Segoe UI">

    <Page.Resources>
        <!-- PrimaryButton -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Background"      Value="#7333FF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}" Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5E1FE8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4A0FD4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#CCCCCC"/>
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- SecondaryButton -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Foreground"      Value="#5A5A5A"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="#E5E5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F0F0F0"/>
                                <Setter Property="Foreground" Value="#1F1F1F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8E8E8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- GhostButton -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Foreground"      Value="#5A5A5A"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="8,0"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}" Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0F000000"/>
                                <Setter Property="Foreground" Value="#1F1F1F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#17000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- AccentProgress -->
        <Style x:Key="AccentProgress" TargetType="ProgressBar">
            <Setter Property="Height"          Value="3"/>
            <Setter Property="Foreground"      Value="#7333FF"/>
            <Setter Property="Background"      Value="#E5E5E5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"/>
                            <Border x:Name="PART_Track"/>
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    HorizontalAlignment="Left"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3"/>    <!-- top accent bar -->
            <RowDefinition Height="*"/>    <!-- centred content -->
            <RowDefinition Height="auto"/> <!-- footer -->
        </Grid.RowDefinitions>

        <!-- Top accent bar -->
        <Border Grid.Row="0" Background="#7333FF"/>

        <!-- Centred content -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="280"
                    Margin="28,0">

            <Image Source="/KleiKodesh_Main.ico"
                   Width="56" Height="56"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <TextBlock Text="מתקין כלי קודש לוורד"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#1F1F1F"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,0,0,20"/>

            <ProgressBar x:Name="ProgressBar"
                         Style="{StaticResource AccentProgress}"
                         Height="3"
                         Minimum="0" Maximum="124" Value="0"
                         Margin="0,0,0,8"/>

            <Grid>
                <TextBlock x:Name="StatusText"
                           Text="מחלץ קבצים..."
                           FontSize="12"
                           Foreground="#5A5A5A"
                           HorizontalAlignment="Right"/>
                <TextBlock x:Name="PercentText"
                           Text="0%"
                           FontSize="12"
                           Foreground="#5A5A5A"
                           FlowDirection="LeftToRight"
                           HorizontalAlignment="Left"/>
            </Grid>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2"
                Background="#F0F0F0"
                BorderBrush="#E5E5E5"
                BorderThickness="0,1,0,0"
                Padding="10,6">
            <TextBlock Text="אנא המתן — אל תסגור חלון זה"
                       FontSize="11"
                       Foreground="#5A5A5A"
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Page>
