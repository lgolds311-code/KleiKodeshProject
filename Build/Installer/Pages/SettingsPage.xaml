<Page x:Class="KleiKodeshVstoInstallerWpf.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="#FFFFFF"
      FlowDirection="RightToLeft"
      FontFamily="Segoe UI">

    <Page.Resources>
        <!-- PrimaryButton -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Background"      Value="#7333FF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}" Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5E1FE8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4A0FD4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#CCCCCC"/>
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- SecondaryButton -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Foreground"      Value="#5A5A5A"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="#E5E5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F0F0F0"/>
                                <Setter Property="Foreground" Value="#1F1F1F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8E8E8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- GhostButton -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Foreground"      Value="#5A5A5A"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="8,0"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}" Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0F000000"/>
                                <Setter Property="Foreground" Value="#1F1F1F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#17000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- AccentProgress -->
        <Style x:Key="AccentProgress" TargetType="ProgressBar">
            <Setter Property="Height"          Value="3"/>
            <Setter Property="Foreground"      Value="#7333FF"/>
            <Setter Property="Background"      Value="#E5E5E5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"/>
                            <Border x:Name="PART_Track"/>
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    HorizontalAlignment="Left"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3"/>
            <RowDefinition Height="auto"/>  <!-- sticky header -->
            <RowDefinition Height="*"/>     <!-- scrollable settings -->
            <RowDefinition Height="auto"/>  <!-- footer -->
        </Grid.RowDefinitions>

        <!-- Top accent bar -->
        <Border Grid.Row="0" Background="#7333FF"/>

        <!-- Sticky header -->
        <StackPanel Grid.Row="1" Margin="28,22,28,10">
            <TextBlock Text="הגדרות התוסף"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#1F1F1F"/>
            <TextBlock Text="בחר אילו רכיבים יוצגו בסרגל הכלים ומהו הלחצן הראשי"
                       FontSize="13"
                       Foreground="#5A5A5A"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Scrollable settings -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="28,0,28,16">

                <!-- Section: visible components -->
                <TextBlock Text="רכיבים זמינים"
                           FontSize="11"
                           Foreground="#5A5A5A"
                           Margin="0,0,0,6"/>

                <!--
                    IMPORTANT — control names are registry settings keys.
                    LoadSettings() iterates VisibleSettingsPanel.Children and passes cb.Name
                    directly to SettingsManager as the key (e.g. "KitveiHakodesh_Visible").
                    Do NOT rename these to follow UI naming conventions — the name IS the key.
                    Format: {ComponentId}_Visible
                -->
                <StackPanel x:Name="VisibleSettingsPanel">
                    <StackPanel.Resources>
                        <Style TargetType="CheckBox">
                            <Setter Property="Margin"                  Value="0,0,0,6"/>
                            <Setter Property="FontSize"                Value="13"/>
                            <Setter Property="Foreground"              Value="#1F1F1F"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Cursor"                  Value="Hand"/>
                        </Style>
                    </StackPanel.Resources>
                    <CheckBox x:Name="KitveiHakodesh_Visible"    Content="ספריית כתבי הקודש"/>
                    <CheckBox x:Name="Kiwix_Visible"      Content="ספריית קיוויקס"/>
                    <CheckBox x:Name="WebSites_Visible"   Content="דרך האתרים"/>
                    <CheckBox x:Name="DocDesign_Visible"  Content="עיצוב תורני"/>
                    <CheckBox x:Name="RegexFind_Visible"  Content="חיפוש רגקס בוורד"/>
                </StackPanel>

                <!-- Divider -->
                <Border Height="1" Background="#E5E5E5" Margin="0,8,0,12"/>

                <!-- Section: default button -->
                <TextBlock Text="לחצן ראשי בסרגל"
                           FontSize="11"
                           Foreground="#5A5A5A"
                           Margin="0,0,0,6"/>

                <!--
                    IMPORTANT — control names encode the settings value.
                    LoadSettings() iterates OptionsSettingsPanel.Children and derives the
                    DefaultButton value by stripping "_Option" from rb.Name (e.g. "KitveiHakodesh_Option"
                    → saves "KitveiHakodesh"). Do NOT rename these to follow UI naming conventions.
                    Format: {ComponentId}_Option  (must match the ComponentId used in KitveiHakodesh_Visible etc.)
                -->
                <StackPanel x:Name="OptionsSettingsPanel">
                    <StackPanel.Resources>
                        <Style TargetType="RadioButton">
                            <Setter Property="Margin"                  Value="0,0,0,6"/>
                            <Setter Property="FontSize"                Value="13"/>
                            <Setter Property="Foreground"              Value="#1F1F1F"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Cursor"                  Value="Hand"/>
                        </Style>
                    </StackPanel.Resources>
                    <RadioButton x:Name="KitveiHakodesh_Option"    Content="ספריית כתבי הקודש"/>
                    <RadioButton x:Name="Kiwix_Option"      Content="ספריית קיוויקס"/>
                    <RadioButton x:Name="WebSites_Option"   Content="דרך האתרים"/>
                    <RadioButton x:Name="DocDesign_Option"  Content="עיצוב תורני"/>
                    <RadioButton x:Name="RegexFind_Option"  Content="חיפוש רגקס בוורד"/>
                    <RadioButton x:Name="Settings_Option"   Content="הגדרות"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="3"
                Background="#F0F0F0"
                BorderBrush="#E5E5E5"
                BorderThickness="0,1,0,0">
            <Grid Margin="10,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="CloseButton"
                        Grid.Column="0"
                        Content="סגור"
                        Style="{StaticResource GhostButton}"
                        Click="CloseButton_Click"/>

                <Button x:Name="NextButton"
                        Grid.Column="2"
                        Content="הבא"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,4,0"
                        Click="NextButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Page>
