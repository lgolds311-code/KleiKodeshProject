<Page x:Class="KleiKodeshVstoInstallerWpf.ComponentSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="#FFFFFF"
      FlowDirection="RightToLeft"
      FontFamily="Segoe UI">

    <Page.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Background"      Value="#7333FF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}" Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5E1FE8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4A0FD4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#CCCCCC"/>
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Foreground"      Value="#5A5A5A"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="#E5E5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F0F0F0"/>
                                <Setter Property="Foreground" Value="#1F1F1F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8E8E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3"/>
            <RowDefinition Height="auto"/>  <!-- header -->
            <RowDefinition Height="*"/>     <!-- scrollable content -->
            <RowDefinition Height="auto"/>  <!-- footer -->
        </Grid.RowDefinitions>

        <!-- Accent bar -->
        <Border Grid.Row="0" Background="#7333FF"/>

        <!-- Header -->
        <StackPanel Grid.Row="1" Margin="28,22,28,10">
            <TextBlock Text="הגדרות מתקדמות"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#1F1F1F"/>
            <TextBlock Text="הגדרות נוספות לרכיבים שבחרת"
                       FontSize="13"
                       Foreground="#5A5A5A"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="28,0,28,16">

                <!-- ── KitveiHakodesh DB section ─────────────────────────────── -->
                <StackPanel x:Name="KitveiHakodeshSection">

                    <TextBlock Text="כתבי הקודש"
                               FontSize="11"
                               Foreground="#5A5A5A"
                               Margin="0,0,0,6"/>

                    <Button x:Name="ZayitDbButton"
                            Height="32"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Padding="0"
                            Cursor="Hand"
                            Click="ZayitDbButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"      Value="#F8F8F8"/>
                                <Setter Property="BorderBrush"     Value="#E5E5E5"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6"
                                                    Padding="10,0">
                                                <ContentPresenter HorizontalAlignment="Stretch"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#7333FF"/>
                                                    <Setter TargetName="Bd" Property="Background"  Value="#F5F0FF"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#EDE5FF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Viewbox Grid.Column="0"
                                     Width="14" Height="14"
                                     Margin="0,0,8,0"
                                     FlowDirection="LeftToRight"
                                     VerticalAlignment="Center">
                                <Path Data="M1,3 L1,11 L13,11 L13,4 L7,4 L5.5,2 L1,2 Z M13,4 L7,4"
                                      Stroke="#5A5A5A" StrokeThickness="1"
                                      Fill="Transparent" StrokeLineJoin="Round"/>
                            </Viewbox>
                            <TextBlock x:Name="DbPathText"
                                       Grid.Column="1"
                                       Text="ברירת מחדל"
                                       FontSize="11"
                                       Foreground="#5A5A5A"
                                       FlowDirection="LeftToRight"
                                       TextAlignment="Left"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <TextBlock x:Name="DbHintText"
                               FontSize="11"
                               Foreground="#5A5A5A"
                               Opacity="0.7"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap"/>

                </StackPanel>
                <!-- /KitveiHakodeshSection -->

                <!-- Hidden spacer — keeps SectionDivider name for code-behind -->
                <Border x:Name="SectionDivider" Height="0"/>

                <!-- ── Websites section ───────────────────────────────── -->
                <StackPanel x:Name="WebsitesSection">

                    <TextBlock Text="דרך האתרים"
                               FontSize="11"
                               Foreground="#5A5A5A"
                               Margin="0,12,0,6"/>

                    <Button x:Name="EditWhitelistButton"
                            Height="32"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Padding="0"
                            Cursor="Hand"
                            Click="EditWhitelistButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"      Value="#F8F8F8"/>
                                <Setter Property="BorderBrush"     Value="#E5E5E5"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6"
                                                    Padding="10,0">
                                                <ContentPresenter HorizontalAlignment="Stretch"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#7333FF"/>
                                                    <Setter TargetName="Bd" Property="Background"  Value="#F5F0FF"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#EDE5FF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Viewbox Grid.Column="0"
                                     Width="14" Height="14"
                                     Margin="0,0,8,0"
                                     FlowDirection="LeftToRight"
                                     VerticalAlignment="Center">
                                <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11.5,3.07C9.5,3.36 7.72,4.28 6.38,5.62L11.5,5.62V3.07M12.5,3.07V5.62H17.62C16.28,4.28 14.5,3.36 12.5,3.07M5.62,6.62C4.28,8 3.36,9.78 3.07,11.78H8.12L5.62,6.62M18.38,6.62L15.88,11.78H20.93C20.64,9.78 19.72,8 18.38,6.62M3.07,12.22C3.36,14.22 4.28,16 5.62,17.38L8.12,12.22H3.07M15.88,12.22L18.38,17.38C19.72,16 20.64,14.22 20.93,12.22H15.88M9.12,12.22L11.5,17.38V12.22H9.12M12.5,12.22V17.38L14.88,12.22H12.5M6.38,18.38C7.72,19.72 9.5,20.64 11.5,20.93V18.38H6.38M12.5,18.38V20.93C14.5,20.64 16.28,19.72 17.62,18.38H12.5Z"
                                      Fill="#5A5A5A"/>
                            </Viewbox>
                            <TextBlock Grid.Column="1"
                                       Text="ערוך רשימת אתרים מותרים"
                                       FontSize="12"
                                       Foreground="#1F1F1F"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <TextBlock Text="בחר אילו אתרים יופיעו בסרגל הכלים"
                               FontSize="11"
                               Foreground="#5A5A5A"
                               Opacity="0.7"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap"/>

                </StackPanel>
                <!-- /WebsitesSection -->

                <!-- ── Shell integration section — always last ────────────────── -->
                <TextBlock Text="סייר הקבצים"
                           FontSize="11"
                           Foreground="#5A5A5A"
                           Margin="0,12,0,6"/>

                <CheckBox x:Name="ShellRegisterCheckBox"
                          Content="הוסף לתפריט 'פתיחה עם' של חלונות"
                          FontSize="13"
                          Foreground="#1F1F1F"
                          Margin="0,0,0,6"
                          Checked="ShellRegisterCheckBox_Changed"
                          Unchecked="ShellRegisterCheckBox_Changed"/>
                <TextBlock Text="מאפשר לפתוח קבצי PDF, Word ועוד ישירות בכתבי הקודש מסייר הקבצים"
                           FontSize="11"
                           Foreground="#5A5A5A"
                           Opacity="0.7"
                           Margin="20,0,0,0"
                           TextWrapping="Wrap"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="3"
                Background="#F0F0F0"
                BorderBrush="#E5E5E5"
                BorderThickness="0,1,0,0">
            <Grid Margin="10,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BackButton"
                        Grid.Column="0"
                        Content="חזור"
                        Style="{StaticResource SecondaryButton}"
                        Click="BackButton_Click"/>

                <Button x:Name="CloseButton"
                        Grid.Column="2"
                        Content="סגור"
                        Style="{StaticResource PrimaryButton}"
                        Click="CloseButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Page>
