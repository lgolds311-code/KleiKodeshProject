<Window x:Class="KleiKodeshVstoInstallerWpf.WhitelistEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="רשימת אתרים"
        Width="420" Height="500"
        MinWidth="320" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI"
        Background="#FFFFFF"
        ResizeMode="CanResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Background"      Value="#7333FF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}" Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5E1FE8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4A0FD4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Foreground"      Value="#5A5A5A"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="#E5E5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F0F0F0"/>
                                <Setter Property="Foreground" Value="#1F1F1F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8E8E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Foreground"      Value="#5A5A5A"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Padding"         Value="3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0F000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#17000000"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3"/>    <!-- accent bar -->
            <RowDefinition Height="auto"/> <!-- header -->
            <RowDefinition Height="*"/>    <!-- list -->
            <RowDefinition Height="auto"/> <!-- footer -->
        </Grid.RowDefinitions>

        <!-- Accent bar -->
        <Border Grid.Row="0" Background="#7333FF"/>

        <!-- Header -->
        <StackPanel Grid.Row="1" Margin="16,14,16,8">
            <TextBlock Text="רשימת אתרים מותרים"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="#1F1F1F"/>
            <TextBlock Text="אלו אתרים יהיו זמינים ב-דרך האתרים"
                       FontSize="12"
                       Foreground="#5A5A5A"
                       Margin="0,2,0,0"/>
            <!-- Check / uncheck all -->
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="סמן הכל"
                        Style="{StaticResource SecondaryButton}"
                        Padding="10,0"
                        Margin="0,0,6,0"
                        Click="CheckAllButton_Click"/>
                <Button Content="בטל הכל"
                        Style="{StaticResource SecondaryButton}"
                        Padding="10,0"
                        Click="UncheckAllButton_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- List -->
        <ListView x:Name="SitesList"
                  Grid.Row="2"
                  Margin="12,0,12,0"
                  BorderThickness="1"
                  BorderBrush="#E5E5E5"
                  Background="#FAFAFA"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  SelectionMode="Single">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding"                    Value="8,4"/>
                    <Setter Property="Background"                 Value="Transparent"/>
                    <Setter Property="BorderThickness"            Value="0,0,0,1"/>
                    <Setter Property="BorderBrush"                Value="#EEEEEE"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#F0EAFF"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F5F5F5"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding IsVisible, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0"
                                  Cursor="Hand"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}"
                                       FontSize="12"
                                       Foreground="#1F1F1F"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Url}"
                                       FontSize="10"
                                       Foreground="#888888"
                                       FlowDirection="LeftToRight"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="4,0,0,0">
                            <Button Style="{StaticResource IconButton}"
                                    ToolTip="העלה"
                                    Tag="{Binding}"
                                    Click="MoveUpButton_Click">
                                <Path Data="M12,20V8M5,15L12,8L19,15"
                                      Stroke="#5A5A5A" StrokeThickness="1.5"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Width="12" Height="12" Stretch="Uniform"
                                      FlowDirection="LeftToRight"/>
                            </Button>
                            <Button Style="{StaticResource IconButton}"
                                    ToolTip="הורד"
                                    Tag="{Binding}"
                                    Click="MoveDownButton_Click">
                                <Path Data="M12,4V16M5,9L12,16L19,9"
                                      Stroke="#5A5A5A" StrokeThickness="1.5"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Width="12" Height="12" Stretch="Uniform"
                                      FlowDirection="LeftToRight"/>
                            </Button>
                            <Button Style="{StaticResource IconButton}"
                                    ToolTip="מחק"
                                    Tag="{Binding}"
                                    Click="DeleteButton_Click">
                                <Path Data="M3,6H21M8,6V4H16V6M19,6L18,20H6L5,6"
                                      Stroke="#CC3333" StrokeThickness="1.5"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Width="12" Height="12" Stretch="Uniform"
                                      FlowDirection="LeftToRight"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Footer -->
        <Border Grid.Row="3"
                Background="#F0F0F0"
                BorderBrush="#E5E5E5"
                BorderThickness="0,1,0,0"
                Margin="0,8,0,0">
            <Grid Margin="10,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="ביטול"
                        Style="{StaticResource SecondaryButton}"
                        Click="CancelButton_Click"/>
                <Button Grid.Column="2"
                        Content="אישור"
                        Style="{StaticResource PrimaryButton}"
                        Click="OkButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
