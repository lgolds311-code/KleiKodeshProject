<UserControl x:Class="RegexFindLib.UI.ColorPickerButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Width="28" Height="28">

    <UserControl.Resources>
        <ResourceDictionary Source="/RegexFindLib;component/UI/RegexFindDictionary.xaml"/>
    </UserControl.Resources>

    <!-- Swatch button that opens the color popup -->
    <Button x:Name="SwatchButton"
            Width="28" Height="28"
            Padding="0"
            BorderBrush="#E5E5E5" BorderThickness="1"
            Background="Transparent"
            Cursor="Hand"
            Click="SwatchButton_Click"
            ToolTip="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=ToolTip}">
        <Button.Template>
            <ControlTemplate TargetType="Button">
                <Border x:Name="Bd"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="4">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="A" FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="#5A5A5A" Margin="0,2,0,0"/>
                        <Border x:Name="ColorBar"
                                Height="4" Margin="3,1,3,2"
                                CornerRadius="2"
                                Background="{Binding RelativeSource={RelativeSource AncestorType=UserControl},
                                                     Path=SwatchBrush}"/>
                    </StackPanel>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Bd" Property="Background" Value="#0F000000"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Button.Template>
    </Button>

</UserControl>
