<UserControl x:Class="RegexFindLib.UI.RegexFindView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RegexFindLib.UI"
             mc:Ignorable="d"
             MinWidth="280"
             FlowDirection="RightToLeft"
             FontFamily="Segoe UI"
             FontSize="13">

    <UserControl.Resources>
        <ResourceDictionary Source="/RegexFindLib;component/UI/RegexFindDictionary.xaml"/>
    </UserControl.Resources>

    <UserControl.DataContext>
        <local:RegexFindViewModel/>
    </UserControl.DataContext>

    <!-- Root grid: title-bar | find | replace | results -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- title bar -->
            <RowDefinition Height="Auto"/>  <!-- find container -->
            <RowDefinition Height="Auto"/>  <!-- replace container -->
            <RowDefinition Height="*"/>     <!-- results -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             TITLE BAR
             [החלפה toggle] [mode select | מרחק: input] [theme|help|?]
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BgSecBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="5">
            <WrapPanel Orientation="Horizontal">

                <!-- Replace toggle -->
                <ToggleButton IsChecked="{Binding ShowReplace}"
                              Style="{StaticResource TitleToggle}"
                              ToolTip="החלפה"
                              Margin="0,0,4,0">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M19 7V4H5V7H2L7 12L2 17H5V20H19V17H22L17 12L22 7H19ZM17 15V18H7V15H4.83L7 12.83V9H17V12.83L19.17 15H17Z"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              Stretch="Uniform" Width="14" Height="14" Margin="0,0,4,0"
                              FlowDirection="LeftToRight"/>
                        <TextBlock Text="החלפה"/>
                    </StackPanel>
                </ToggleButton>

                <!-- Search mode + slop -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                    <ComboBox ItemsSource="{Binding SearchModes}"
                              SelectedIndex="{Binding SearchModeIndex}"
                              IsEditable="False"
                              Height="26" FontSize="12"
                              ToolTip="כיוון החיפוש"/>
                    <TextBlock Text="מרחק:" VerticalAlignment="Center"
                               FontSize="12" Margin="6,0,3,0"
                               Foreground="{StaticResource TextSecBrush}"/>
                    <TextBox Text="{Binding Slop, UpdateSourceTrigger=PropertyChanged}"
                             Width="36" Height="26" FontSize="12"
                             VerticalContentAlignment="Center"
                             TextAlignment="Center"
                             ToolTip="מרחק בין מילים"/>
                </StackPanel>

                <!-- Help / regex palette toggle -->
                <ToggleButton IsChecked="{Binding ShowRegexPalette}"
                              Style="{StaticResource IconToggle}"
                              ToolTip="לוח תווי רג'קס">
                    <Path Data="M16,16.92C15.67,16.97 15.34,17 15,17C14.66,17 14.33,16.97 14,16.92V13.41L11.5,15.89C11,15.5 10.5,15 10.11,14.5L12.59,12H9.08C9.03,11.67 9,11.34 9,11C9,10.66 9.03,10.33 9.08,10H12.59L10.11,7.5C10.3,7.25 10.5,7 10.76,6.76C11,6.5 11.25,6.3 11.5,6.11L14,8.59V5.08C14.33,5.03 14.66,5 15,5C15.34,5 15.67,5.03 16,5.08V8.59L18.5,6.11C19,6.5 19.5,7 19.89,7.5L17.41,10H20.92C20.97,10.33 21,10.66 21,11C21,11.34 20.97,11.67 20.92,12H17.41L19.89,14.5C19.7,14.75 19.5,15 19.24,15.24C19,15.5 18.75,15.7 18.5,15.89L16,13.41V16.92Z"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                          Stretch="Uniform" Width="16" Height="16" FlowDirection="LeftToRight"/>
                </ToggleButton>

            </WrapPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             FIND CONTAINER
        ══════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="1" Margin="10,8,10,8">

            <!-- input-wrapper: [text input] [search btn] [regex btn] -->
            <Border Style="{StaticResource InputWrapper}" Margin="0,0,0,5">
                <DockPanel>
                    <Button DockPanel.Dock="Left"
                            Style="{StaticResource InputIconButton}"
                            Command="{Binding SearchCommand}"
                            ToolTip="חיפוש">
                        <Path Data="M10 2.75a7.25 7.25 0 0 1 5.63 11.819l4.9 4.9a.75.75 0 0 1-.976 1.134l-.084-.073-4.901-4.9A7.25 7.25 0 1 1 10 2.75Zm0 1.5a5.75 5.75 0 1 0 0 11.5 5.75 5.75 0 0 0 0-11.5Z"
                              Fill="{StaticResource TextSecBrush}" Stretch="Uniform"
                              Width="16" Height="16" FlowDirection="LeftToRight"/>
                    </Button>
                    <ToggleButton DockPanel.Dock="Right"
                                  Style="{StaticResource InputIconToggle}"
                                  IsChecked="{Binding UseRegex}"
                                  ToolTip="השתמש בביטויים רגולריים">
                        <Path Data="M16,16.92C15.67,16.97 15.34,17 15,17C14.66,17 14.33,16.97 14,16.92V13.41L11.5,15.89C11,15.5 10.5,15 10.11,14.5L12.59,12H9.08C9.03,11.67 9,11.34 9,11C9,10.66 9.03,10.33 9.08,10H12.59L10.11,7.5C10.3,7.25 10.5,7 10.76,6.76C11,6.5 11.25,6.3 11.5,6.11L14,8.59V5.08C14.33,5.03 14.66,5 15,5C15.34,5 15.67,5.03 16,5.08V8.59L18.5,6.11C19,6.5 19.5,7 19.89,7.5L17.41,10H20.92C20.97,10.33 21,10.66 21,11C21,11.34 20.97,11.67 20.92,12H17.41L19.89,14.5C19.7,14.75 19.5,15 19.24,15.24C19,15.5 18.75,15.7 18.5,15.89L16,13.41V16.92Z"
                              Fill="{StaticResource TextSecBrush}" Stretch="Uniform"
                              Width="16" Height="16" FlowDirection="LeftToRight"/>
                    </ToggleButton>
                    <TextBox Style="{StaticResource InlineTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="חיפוש">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                </DockPanel>
            </Border>

            <!-- find-options-wrapper: font-size | B I U sub sup | color | clear | copy -->
            <WrapPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBox Text="{Binding FindFormatting.FontSize, UpdateSourceTrigger=PropertyChanged}"
                         Width="42" Height="26" FontSize="12"
                         VerticalContentAlignment="Center" TextAlignment="Center"
                         ToolTip="גודל גופן" Margin="0,0,3,0"/>
                <ToggleButton Style="{StaticResource FormatToggle}" IsChecked="{Binding FindFormatting.Bold}"    ToolTip="מודגש"    Margin="0,0,2,0"><TextBlock Text="B" FontWeight="Bold"   FontSize="13"/></ToggleButton>
                <ToggleButton Style="{StaticResource FormatToggle}" IsChecked="{Binding FindFormatting.Italic}"  ToolTip="נטוי"     Margin="0,0,2,0"><TextBlock Text="I" FontStyle="Italic" FontSize="13"/></ToggleButton>
                <ToggleButton Style="{StaticResource FormatToggle}" IsChecked="{Binding FindFormatting.Underline}" ToolTip="קו תחתון" Margin="0,0,2,0">
                    <TextBlock Text="U" FontSize="13"><TextBlock.TextDecorations><TextDecoration Location="Underline"/></TextBlock.TextDecorations></TextBlock>
                </ToggleButton>
                <ToggleButton Style="{StaticResource FormatToggle}" IsChecked="{Binding FindFormatting.Subscript}"   ToolTip="כתב תחתי" Margin="0,0,2,0">
                    <TextBlock FontSize="11"><Run Text="x"/><Run Text="₂" FontSize="8" BaselineAlignment="Subscript"/></TextBlock>
                </ToggleButton>
                <ToggleButton Style="{StaticResource FormatToggle}" IsChecked="{Binding FindFormatting.Superscript}" ToolTip="כתב עילי"  Margin="0,0,2,0">
                    <TextBlock FontSize="11"><Run Text="x"/><Run Text="²" FontSize="8" BaselineAlignment="Superscript"/></TextBlock>
                </ToggleButton>
                <local:ColorPickerButton SelectedColor="{Binding FindFormatting.TextColor, Mode=TwoWay}"
                                         ToolTip="צבע גופן" Margin="0,0,2,0"/>
                <Button Style="{StaticResource FormatButton}"
                        Command="{Binding ClearFindFormattingCommand}" ToolTip="נקה הגדרות עיצוב" Margin="0,0,2,0">
                    <Path Data="M16.24,3.56L21.19,8.5C21.97,9.29 21.97,10.55 21.19,11.34L12,20.53C10.44,22.09 7.91,22.09 6.34,20.53L2.81,17C2.03,16.21 2.03,14.95 2.81,14.16L13.41,3.56C14.2,2.78 15.46,2.78 16.24,3.56M4.22,15.58L7.76,19.11C8.54,19.9 9.8,19.9 10.59,19.11L14.12,15.58L9.17,10.63L4.22,15.58Z"
                          Fill="{StaticResource TextSecBrush}" Stretch="Uniform" Width="14" Height="14" FlowDirection="LeftToRight"/>
                </Button>
                <Button Style="{StaticResource FormatButton}"
                        Command="{Binding CopyFindFormattingCommand}" ToolTip="שאב הגדרות עיצוב">
                    <Path Data="M19.35,11.72L17.22,13.85L15.81,12.43L8.1,20.14L3.5,22L2,20.5L3.86,15.9L11.57,8.19L10.15,6.78L12.28,4.65L19.35,11.72M16.76,3C17.93,1.83 19.83,1.83 21,3C22.17,4.17 22.17,6.07 21,7.24L19.08,9.16L14.84,4.92L16.76,3M5.56,17.03L4.5,19.5L6.97,18.44L14.4,11L13,9.6L5.56,17.03Z"
                          Fill="{StaticResource TextSecBrush}" Stretch="Uniform" Width="14" Height="14" FlowDirection="LeftToRight"/>
                </Button>
            </WrapPanel>

            <!-- find-font-style-wrapper: style combobox | font combobox -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding StyleList}"
                          Text="{Binding FindFormatting.StyleName, UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="True" Height="26" FontSize="12"
                          VirtualizingPanel.IsVirtualizing="True"
                          ToolTip="בחר סגנון"/>
                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding FontList}"
                          Text="{Binding FindFormatting.FontName, UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="True" Height="26" FontSize="12"
                          VirtualizingPanel.IsVirtualizing="True"
                          ToolTip="בחר גופן"/>
            </Grid>

        </StackPanel>

        <!-- ══════════════════════════════════════════════════════════
             REPLACE CONTAINER (visible when ShowReplace = true)
        ══════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="2"
                    Margin="10,0,10,8"
                    Visibility="{Binding ShowReplace,
                        Converter={x:Static local:BoolToVisibilityConverter.Instance}}">

            <Border Background="{StaticResource BgSecBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="0,8,0,0">

                <!-- input-wrapper: [text] [replace btn] [replace-all btn] -->
                <StackPanel>
                    <Border Style="{StaticResource InputWrapper}" Margin="0,0,0,5">
                        <DockPanel>
                            <Button DockPanel.Dock="Left"
                                    Style="{StaticResource InputIconButton}"
                                    Command="{Binding ReplaceCommand}"
                                    ToolTip="החלף">
                                <Path Data="M11,6C12.38,6 13.63,6.56 14.54,7.46L12,10H18V4L15.95,6.05C14.68,4.78 12.93,4 11,4C7.47,4 4.57,6.61 4.08,10H6.1C6.56,7.72 8.58,6 11,6M16.64,15.14C17.3,14.24 17.76,13.17 17.92,12H15.9C15.44,14.28 13.42,16 11,16C9.62,16 8.37,15.44 7.46,14.54L10,12H4V18L6.05,15.95C7.32,17.22 9.07,18 11,18C12.55,18 14,17.5 15.14,16.64L20,21.5L21.5,20L16.64,15.14Z"
                                      Fill="{StaticResource TextSecBrush}" Stretch="Uniform"
                                      Width="16" Height="16" FlowDirection="LeftToRight"/>
                            </Button>
                            <Button DockPanel.Dock="Left"
                                    Style="{StaticResource InputIconButton}"
                                    Command="{Binding ReplaceAllCommand}"
                                    ToolTip="החלף הכל">
                                <Path Data="M 20 37.5 c 0 -0.8 -0.7 -1.5 -1.5 -1.5 h -15 C 2.7 36 2 36.7 2 37.5 v 11 C 2 49.3 2.7 50 3.5 50 h 15 c 0.8 0 1.5 -0.7 1.5 -1.5 V 37.5 z M 8.1 22 H 3.2 c -1 0 -1.5 0.9 -0.9 1.4 l 8 8.3 c 0.4 0.3 1 0.3 1.4 0 l 8 -8.3 c 0.6 -0.6 0.1 -1.4 -0.9 -1.4 h -4.7 c 0 -5 4.9 -10 9.9 -10 V 6 C 15 6 8.1 13 8.1 22 z M 41.8 20.3 c -0.4 -0.3 -1 -0.3 -1.4 0 l -8 8.3 c -0.6 0.6 -0.1 1.4 0.9 1.4 h 4.8 c 0 6 -4.1 10 -10.1 10 v 6 c 9 0 16.1 -7 16.1 -16 H 49 c 1 0 1.5 -0.9 0.9 -1.4 L 41.8 20.3 z M 50 3.5 C 50 2.7 49.3 2 48.5 2 h -15 C 32.7 2 32 2.7 32 3.5 v 11 c 0 0.8 0.7 1.5 1.5 1.5 h 15 c 0.8 0 1.5 -0.7 1.5 -1.5 V 3.5 z"
                                      Fill="{StaticResource TextSecBrush}" Stretch="Uniform"
                                      Width="16" Height="16" FlowDirection="LeftToRight"/>
                            </Button>
                            <TextBox Style="{StaticResource InlineTextBox}"
                                     Text="{Binding ReplaceText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="החלף ב.."/>
                        </DockPanel>
                    </Border>

                    <!-- replace-options-wrapper -->
                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBox Text="{Binding ReplaceFormatting.FontSize, UpdateSourceTrigger=PropertyChanged}"
                                 Width="42" Height="26" FontSize="12"
                                 VerticalContentAlignment="Center" TextAlignment="Center"
                                 ToolTip="גודל גופן" Margin="0,0,3,0"/>
                        <ToggleButton Style="{StaticResource FormatToggle}" IsChecked="{Binding ReplaceFormatting.Bold}"      ToolTip="מודגש"    Margin="0,0,2,0"><TextBlock Text="B" FontWeight="Bold"   FontSize="13"/></ToggleButton>
                        <ToggleButton Style="{StaticResource FormatToggle}" IsChecked="{Binding ReplaceFormatting.Italic}"    ToolTip="נטוי"     Margin="0,0,2,0"><TextBlock Text="I" FontStyle="Italic" FontSize="13"/></ToggleButton>
                        <ToggleButton Style="{StaticResource FormatToggle}" IsChecked="{Binding ReplaceFormatting.Underline}" ToolTip="קו תחתון" Margin="0,0,2,0">
                            <TextBlock Text="U" FontSize="13"><TextBlock.TextDecorations><TextDecoration Location="Underline"/></TextBlock.TextDecorations></TextBlock>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource FormatToggle}" IsChecked="{Binding ReplaceFormatting.Subscript}"   ToolTip="כתב תחתי" Margin="0,0,2,0">
                            <TextBlock FontSize="11"><Run Text="x"/><Run Text="₂" FontSize="8" BaselineAlignment="Subscript"/></TextBlock>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource FormatToggle}" IsChecked="{Binding ReplaceFormatting.Superscript}" ToolTip="כתב עילי"  Margin="0,0,2,0">
                            <TextBlock FontSize="11"><Run Text="x"/><Run Text="²" FontSize="8" BaselineAlignment="Superscript"/></TextBlock>
                        </ToggleButton>
                        <local:ColorPickerButton SelectedColor="{Binding ReplaceFormatting.TextColor, Mode=TwoWay}"
                                                 ToolTip="צבע גופן" Margin="0,0,2,0"/>
                        <Button Style="{StaticResource FormatButton}"
                                Command="{Binding ClearReplaceFormattingCommand}" ToolTip="נקה הגדרות עיצוב" Margin="0,0,2,0">
                            <Path Data="M16.24,3.56L21.19,8.5C21.97,9.29 21.97,10.55 21.19,11.34L12,20.53C10.44,22.09 7.91,22.09 6.34,20.53L2.81,17C2.03,16.21 2.03,14.95 2.81,14.16L13.41,3.56C14.2,2.78 15.46,2.78 16.24,3.56M4.22,15.58L7.76,19.11C8.54,19.9 9.8,19.9 10.59,19.11L14.12,15.58L9.17,10.63L4.22,15.58Z"
                                  Fill="{StaticResource TextSecBrush}" Stretch="Uniform" Width="14" Height="14" FlowDirection="LeftToRight"/>
                        </Button>
                        <Button Style="{StaticResource FormatButton}"
                                Command="{Binding CopyReplaceFormattingCommand}" ToolTip="שאב הגדרות עיצוב">
                            <Path Data="M19.35,11.72L17.22,13.85L15.81,12.43L8.1,20.14L3.5,22L2,20.5L3.86,15.9L11.57,8.19L10.15,6.78L12.28,4.65L19.35,11.72M16.76,3C17.93,1.83 19.83,1.83 21,3C22.17,4.17 22.17,6.07 21,7.24L19.08,9.16L14.84,4.92L16.76,3M5.56,17.03L4.5,19.5L6.97,18.44L14.4,11L13,9.6L5.56,17.03Z"
                                  Fill="{StaticResource TextSecBrush}" Stretch="Uniform" Width="14" Height="14" FlowDirection="LeftToRight"/>
                        </Button>
                    </WrapPanel>

                    <!-- replace-font-style-wrapper -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding StyleList}"
                                  Text="{Binding ReplaceFormatting.StyleName, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True" Height="26" FontSize="12"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  ToolTip="בחר סגנון"/>
                        <ComboBox Grid.Column="2"
                                  ItemsSource="{Binding FontList}"
                                  Text="{Binding ReplaceFormatting.FontName, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True" Height="26" FontSize="12"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  ToolTip="בחר גופן"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ══════════════════════════════════════════════════════════
             RESULTS CONTAINER (fills remaining space)
        ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="3">
            <!-- Regex palette (shown when help toggle is on) -->
            <local:RegexPalettePanel
                Visibility="{Binding ShowRegexPalette,
                    Converter={x:Static local:BoolToVisibilityConverter.Instance}}"/>

            <!-- Search results list -->
            <Border Background="{StaticResource BgSecBrush}"
                    Visibility="{Binding ShowRegexPalette,
                        Converter={x:Static local:InverseBoolToVisibilityConverter.Instance}}">
                <ListBox ItemsSource="{Binding Results}"
                         SelectedIndex="{Binding SelectedResultIndex}"
                         ItemContainerStyle="{StaticResource ResultItem}"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="5"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <local:SnippetBlock Snippet="{Binding}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>

    </Grid>
</UserControl>
