<UserControl x:Class="RegexFindLib.UI.FormattingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RegexFindLib.UI"
             mc:Ignorable="d"
             FlowDirection="RightToLeft"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <ResourceDictionary Source="/RegexFindLib;component/UI/RegexFindDictionary.xaml"/>
    </UserControl.Resources>

    <StackPanel>

        <!-- ── Format toggles row ──────────────────────────────────── -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">

            <!-- Bold -->
            <ToggleButton Style="{StaticResource FormatToggle}"
                          IsChecked="{Binding Bold}"
                          ToolTip="מודגש"
                          Margin="0,0,4,0">
                <TextBlock Text="B" FontWeight="Bold" FontSize="13"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </ToggleButton>

            <!-- Italic -->
            <ToggleButton Style="{StaticResource FormatToggle}"
                          IsChecked="{Binding Italic}"
                          ToolTip="נטוי"
                          Margin="0,0,4,0">
                <TextBlock Text="I" FontStyle="Italic" FontSize="13"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </ToggleButton>

            <!-- Underline -->
            <ToggleButton Style="{StaticResource FormatToggle}"
                          IsChecked="{Binding Underline}"
                          ToolTip="קו תחתון"
                          Margin="0,0,4,0">
                <TextBlock Text="U" FontSize="13"
                           VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock.TextDecorations>
                        <TextDecoration Location="Underline"/>
                    </TextBlock.TextDecorations>
                </TextBlock>
            </ToggleButton>

            <!-- Superscript -->
            <ToggleButton Style="{StaticResource FormatToggle}"
                          IsChecked="{Binding Superscript}"
                          ToolTip="כתב עילי"
                          Margin="0,0,4,0">
                <TextBlock FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Run Text="x"/>
                    <Run Text="2" BaselineAlignment="Superscript" FontSize="8"/>
                </TextBlock>
            </ToggleButton>

            <!-- Subscript -->
            <ToggleButton Style="{StaticResource FormatToggle}"
                          IsChecked="{Binding Subscript}"
                          ToolTip="כתב תחתי"
                          Margin="0,0,8,0">
                <TextBlock FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Run Text="x"/>
                    <Run Text="2" BaselineAlignment="Subscript" FontSize="8"/>
                </TextBlock>
            </ToggleButton>

            <!-- Color swatch -->
            <local:ColorPickerButton x:Name="ColorPicker"
                                     SelectedColor="{Binding TextColor, Mode=TwoWay}"
                                     ToolTip="צבע טקסט"
                                     Width="28" Height="28"/>

        </StackPanel>

        <!-- ── Font name ───────────────────────────────────────────── -->
        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="גופן:"
                       Style="{StaticResource SectionLabel}"
                       VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1"
                      Style="{StaticResource FilterCombo}"
                      ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=local:FormattingPanel},
                                            Path=FontList}"
                      Text="{Binding FontName, UpdateSourceTrigger=PropertyChanged}"
                      IsEditable="True"
                      VirtualizingPanel.IsVirtualizing="True"/>
        </Grid>

        <!-- ── Font size ───────────────────────────────────────────── -->
        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="גודל:"
                       Style="{StaticResource SectionLabel}"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="1"
                     Style="{StaticResource SearchInput}"
                     Height="28" FontSize="12"
                     Text="{Binding FontSize, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="גודל גופן (נקודות)"/>
        </Grid>

        <!-- ── Style ───────────────────────────────────────────────── -->
        <Grid Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="סגנון:"
                       Style="{StaticResource SectionLabel}"
                       VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1"
                      Style="{StaticResource FilterCombo}"
                      ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=local:FormattingPanel},
                                            Path=StyleList}"
                      Text="{Binding StyleName, UpdateSourceTrigger=PropertyChanged}"
                      IsEditable="True"
                      VirtualizingPanel.IsVirtualizing="True"/>
        </Grid>

    </StackPanel>
</UserControl>
