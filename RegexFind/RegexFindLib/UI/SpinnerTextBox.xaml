<UserControl x:Class="RegexFindLib.UI.SpinnerTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RegexFindLib.UI"
             xmlns:controls="clr-namespace:WpfLib.Controls;assembly=WpfLib"
             mc:Ignorable="d"
             Height="28"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <ResourceDictionary Source="/RegexFindLib;component/ui/regexfinddictionary.xaml"/>
    </UserControl.Resources>

    <!--
        Office-style numeric spinner:
        [  value text  ] [▲]
                         [▼]
        Border matches the ComboBox style: #EDEBE9, 4px radius.
    -->
    <Border x:Name="OuterBorder"
                       CornerRadius="4"
                       BorderBrush="#EDEBE9"
                       BorderThickness="1"
                       Background="#FFFFFF">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
            </Grid.ColumnDefinitions>

            <!-- Numeric input — integer or float depending on IsFloat -->
            <controls:UpDownTextBox x:Name="IntBox"
                                    Grid.Column="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="6,0"
                                    FontSize="12"
                                    FontFamily="Segoe UI"
                                    Foreground="#323130"
                                    VerticalContentAlignment="Center"
                                    TextAlignment="Center"
                                    FocusVisualStyle="{x:Null}"
                                    Value="{Binding RelativeSource={RelativeSource AncestorType=local:SpinnerTextBox},
                                                    Path=IntValue, Mode=TwoWay}"
                                    Step="{Binding RelativeSource={RelativeSource AncestorType=local:SpinnerTextBox},
                                                   Path=Step}"
                                    Visibility="Visible"/>

            <controls:UpDownFloatTextBox x:Name="FloatBox"
                                         Grid.Column="0"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="6,0"
                                         FontSize="12"
                                         FontFamily="Segoe UI"
                                         Foreground="#323130"
                                         VerticalContentAlignment="Center"
                                         TextAlignment="Center"
                                         FocusVisualStyle="{x:Null}"
                                         Value="{Binding RelativeSource={RelativeSource AncestorType=local:SpinnerTextBox},
                                                         Path=FloatValue, Mode=TwoWay}"
                                         Step="{Binding RelativeSource={RelativeSource AncestorType=local:SpinnerTextBox},
                                                        Path=FloatStep}"
                                         Visibility="Collapsed"/>

            <!-- ▲ / ▼ buttons stacked on the right -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ▲ Up -->
                <RepeatButton Grid.Row="0"
                              x:Name="UpBtn"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="0"
                              Cursor="Hand"
                              Focusable="False"
                              Click="UpBtn_Click">
                    <RepeatButton.Template>
                        <ControlTemplate TargetType="RepeatButton">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="0,4,0,0">
                                <Path Data="M5 7L8 4L11 7"
                                      Stroke="#605E5C" StrokeThickness="1.2"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Width="8" Height="5" Stretch="Uniform" HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      FlowDirection="LeftToRight"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#F3F2F1"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#EDEBE9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </RepeatButton.Template>
                </RepeatButton>

                <!-- Divider between ▲ and ▼ -->
                <Border Grid.Row="0" Grid.RowSpan="2"
                        BorderBrush="#EDEBE9" BorderThickness="1,0,0,0"
                        IsHitTestVisible="False"/>

                <!-- ▼ Down -->
                <RepeatButton Grid.Row="1"
                              x:Name="DownBtn"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="0"
                              Cursor="Hand"
                              Focusable="False"
                              Click="DownBtn_Click">
                    <RepeatButton.Template>
                        <ControlTemplate TargetType="RepeatButton">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="0,0,4,0">
                                <Path Data="M5 4L8 7L11 4"
                                      Stroke="#605E5C" StrokeThickness="1.2"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Width="8" Height="5" Stretch="Uniform" HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      FlowDirection="LeftToRight"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#F3F2F1"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#EDEBE9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </RepeatButton.Template>
                </RepeatButton>

            </Grid>
        </Grid>
    </Border>
</UserControl>
