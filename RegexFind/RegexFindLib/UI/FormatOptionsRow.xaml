<UserControl x:Class="RegexFindLib.UI.FormatOptionsRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RegexFindLib.UI"
             mc:Ignorable="d"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RegexFindLib;component/ui/regexfinddictionary.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!--
                THREE-STATE FORMAT TOGGLE — pure XAML using CheckBox IsThreeState.
                IsChecked = bool?:
                  null  (indeterminate) → transparent bg, no overlay
                  true  (checked)       → active-bg  (#0F000000 gray tint)
                  false (unchecked)     → error-light (#F8D7DA) + diagonal red line

                CheckBox cycles null→true→false→null automatically when IsThreeState=True.
                We completely replace the CheckBox template so it looks like an icon button.
            -->
            <Style x:Key="FormatToggle" TargetType="CheckBox">
                <Setter Property="IsThreeState"    Value="True"/>
                <Setter Property="Width"           Value="26"/>
                <Setter Property="Height"          Value="26"/>
                <Setter Property="Padding"         Value="3"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <Grid Width="{TemplateBinding Width}"
                                  Height="{TemplateBinding Height}">

                                <!-- Layer 1: state background -->
                                <Border x:Name="Bg"
                                        CornerRadius="4"
                                        Background="Transparent"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>

                                <!-- Layer 2: diagonal red line (false state only) -->
                                <Border x:Name="ErrorLine"
                                        CornerRadius="4"
                                        IsHitTestVisible="False"
                                        Visibility="Collapsed">
                                    <Border.Background>
                                        <DrawingBrush TileMode="None" Stretch="Fill">
                                            <DrawingBrush.Drawing>
                                                <GeometryDrawing>
                                                    <GeometryDrawing.Geometry>
                                                        <LineGeometry StartPoint="0,0" EndPoint="1,1"/>
                                                    </GeometryDrawing.Geometry>
                                                    <GeometryDrawing.Pen>
                                                        <Pen Brush="#DC3545" Thickness="0.07"/>
                                                    </GeometryDrawing.Pen>
                                                </GeometryDrawing>
                                            </DrawingBrush.Drawing>
                                        </DrawingBrush>
                                    </Border.Background>
                                </Border>

                                <!-- Layer 3: hover overlay -->
                                <Border x:Name="Hover"
                                        CornerRadius="4"
                                        Background="Transparent"
                                        IsHitTestVisible="False"/>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <!-- true → active gray tint -->
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#0F000000"/>
                                </Trigger>
                                <!-- false → red tint + diagonal line -->
                                <Trigger Property="IsChecked" Value="False">
                                    <Setter TargetName="Bg"        Property="Background" Value="#F8D7DA"/>
                                    <Setter TargetName="ErrorLine" Property="Visibility"  Value="Visible"/>
                                </Trigger>
                                <!-- null (indeterminate) → transparent (default, no setter needed) -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Hover" Property="Background" Value="#0A000000"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </UserControl.Resources>

    <!--
        Mirrors HTML .flex-row inside find/replace containers.
        Uses a Grid with * spacer columns to push the clear/copy buttons to the left edge.

        Visual order (RTL — right side is "start"):
          [font-size] [B] [I] [U] [x²] [x₂] [A] [eraser] [pencil]
          SpaceBetweenPanel distributes them evenly across the full width automatically.
          Adding or removing items requires no layout changes.
    -->
    <local:SpaceBetweenPanel>

        <!-- font-size spinner -->
        <local:SpinnerTextBox
                 IsFloat="True"
                 FloatValue="{Binding RelativeSource={RelativeSource AncestorType=local:FormatOptionsRow},
                                      Path=FontSizeValue, Mode=TwoWay}"
                 FloatStep="0.5"
                 Width="52" Height="26"
                 ToolTip="גודל גופן (נקודות)"/>

        <!-- B — Bold -->
        <CheckBox Style="{StaticResource FormatToggle}"
                  IsChecked="{Binding RelativeSource={RelativeSource AncestorType=local:FormatOptionsRow},
                                     Path=Bold, Mode=TwoWay}"
                  ToolTip="מודגש">
            <Viewbox Width="16" Height="16" FlowDirection="LeftToRight">
                <Canvas Width="24" Height="24">
                    <Path Fill="#1A1A1A"
                          Data="{StaticResource Icon.Bold}"/>
                </Canvas>
            </Viewbox>
        </CheckBox>

        <!-- I — Italic -->
        <CheckBox Style="{StaticResource FormatToggle}"
                  IsChecked="{Binding RelativeSource={RelativeSource AncestorType=local:FormatOptionsRow},
                                     Path=Italic, Mode=TwoWay}"
                  ToolTip="נטוי">
            <Viewbox Width="16" Height="16" FlowDirection="LeftToRight">
                <Canvas Width="24" Height="24">
                    <Path Fill="#1A1A1A"
                          Data="{StaticResource Icon.Italic}"/>
                </Canvas>
            </Viewbox>
        </CheckBox>

        <!-- U — Underline -->
        <CheckBox Style="{StaticResource FormatToggle}"
                  IsChecked="{Binding RelativeSource={RelativeSource AncestorType=local:FormatOptionsRow},
                                     Path=Underline, Mode=TwoWay}"
                  ToolTip="קו תחתון">
            <Viewbox Width="16" Height="16" FlowDirection="LeftToRight">
                <Canvas Width="24" Height="24">
                    <Path Fill="#1A1A1A"
                          Data="{StaticResource Icon.Underline}"/>
                </Canvas>
            </Viewbox>
        </CheckBox>

        <!-- x² — Superscript -->
        <CheckBox x:Name="SuperscriptCheck"
                  Style="{StaticResource FormatToggle}"
                  IsChecked="{Binding RelativeSource={RelativeSource AncestorType=local:FormatOptionsRow},
                                     Path=Superscript, Mode=TwoWay}"
                  ToolTip="כתב עילי"
                  Checked="SuperscriptCheck_Checked">
            <Viewbox Width="16" Height="16" FlowDirection="LeftToRight">
                <Canvas Width="24" Height="24">
                    <Path Fill="#1A1A1A"
                          Data="{StaticResource Icon.Superscript}"/>
                </Canvas>
            </Viewbox>
        </CheckBox>

        <!-- x₂ — Subscript -->
        <CheckBox x:Name="SubscriptCheck"
                  Style="{StaticResource FormatToggle}"
                  IsChecked="{Binding RelativeSource={RelativeSource AncestorType=local:FormatOptionsRow},
                                     Path=Subscript, Mode=TwoWay}"
                  ToolTip="כתב תחתי"
                  Checked="SubscriptCheck_Checked">
            <Viewbox Width="16" Height="16" FlowDirection="LeftToRight">
                <Canvas Width="24" Height="24">
                    <Path Fill="#1A1A1A"
                          Data="{StaticResource Icon.Subscript}"/>
                </Canvas>
            </Viewbox>
        </CheckBox>

        <!-- A — Color picker -->
        <local:ColorPickerButton
            SelectedColor="{Binding RelativeSource={RelativeSource AncestorType=local:FormatOptionsRow},
                                    Path=TextColor, Mode=TwoWay}"
            ToolTip="צבע גופן"/>

        <!-- Eraser — Clear formatting -->
        <Button Style="{StaticResource FormatButton}"
                Command="{Binding RelativeSource={RelativeSource AncestorType=local:FormatOptionsRow},
                                  Path=ClearCommand}"
                ToolTip="נקה הגדרות עיצוב">
            <Viewbox Width="16" Height="16" FlowDirection="LeftToRight">
                <Canvas Width="24" Height="24">
                    <Path Fill="#666666"
                          Data="{StaticResource Icon.Eraser}"/>
                </Canvas>
            </Viewbox>
        </Button>

        <!-- Pencil — Copy formatting from selection -->
        <Button Style="{StaticResource FormatButton}"
                Command="{Binding RelativeSource={RelativeSource AncestorType=local:FormatOptionsRow},
                                  Path=CopyCommand}"
                ToolTip="שאב הגדרות עיצוב">
            <Viewbox Width="16" Height="16" FlowDirection="LeftToRight">
                <Canvas Width="24" Height="24">
                    <Path Fill="#666666"
                          Data="{StaticResource Icon.Eyedropper}"/>
                </Canvas>
            </Viewbox>
        </Button>

    </local:SpaceBetweenPanel>
</UserControl>
