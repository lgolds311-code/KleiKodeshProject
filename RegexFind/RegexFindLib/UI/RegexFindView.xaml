<UserControl x:Class="RegexFindLib.UI.RegexFindView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RegexFindLib.UI"
             mc:Ignorable="d"
             MinWidth="280"
             FlowDirection="RightToLeft"
             FontFamily="Segoe UI"
             FontSize="13"
             Background="#FFFFFF"
             Foreground="#323130">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RegexFindLib;component/ui/RegexFindDictionary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:BoolToVisibilityConverter        x:Key="BoolToVis"/>
            <local:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>

            <!-- History item template — kept here so Click handler can reference code-behind -->
            <DataTemplate x:Key="HistoryItemTemplate">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding}"
                               Padding="8,6"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Foreground="#323130"/>
                    <Button Grid.Column="1"
                            Content="×"
                            FontSize="13"
                            Width="26" Height="26"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Opacity="0.5"
                            ToolTip="הסר מההיסטוריה"
                            Tag="{Binding}"
                            Click="HistoryRemove_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="Transparent"
                                                    CornerRadius="2" Padding="2">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#FDE7E9"/>
                                                    <Setter Property="Opacity" Value="1"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <!--
        Layout mirrors the HTML exactly:
          #title-bar      — flex-row: [החלפה toggle] [mode+slop] [help icon]
          #search-find-container   — input-wrapper + options-row + font-style-row
          #search-replace-container (hidden by default)
          #results-container       — regex-palette OR results list
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- title-bar -->
            <RowDefinition Height="Auto"/>   <!-- find container -->
            <RowDefinition Height="Auto"/>   <!-- replace container -->
            <RowDefinition Height="*"/>      <!-- results -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             TITLE BAR
             #title-bar: flex-wrap, space-between, secondary-bg, border-bottom
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BgSecBrush}"
                BorderBrush="{StaticResource BorderStrong}"
                BorderThickness="0,0,0,1"
                Padding="5,4">
            <DockPanel LastChildFill="False">

                <!-- [החלפה] toggle — replaceall icon + label -->
                <ToggleButton DockPanel.Dock="Right"
                              Style="{StaticResource TitleToggle}"
                              IsChecked="{Binding ShowReplace}"
                              ToolTip="החלפה">
                    <StackPanel Orientation="Horizontal">
                        <!-- Icon.ReplaceAll (24x24) -->
                        <Viewbox Width="14" Height="14" FlowDirection="LeftToRight" Margin="0,0,4,0">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{Binding Foreground,
                                          RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      Data="{StaticResource Icon.ReplaceAll}"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="החלפה" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>

                <!-- [mode select] [מרחק: input] — center group -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0">
                    <ComboBox ItemsSource="{Binding SearchModes}"
                              SelectedIndex="{Binding SearchModeIndex}"
                              IsEditable="False"
                              Height="24" FontSize="12"
                              ToolTip="כיוון החיפוש"/>
                    <TextBlock Text="מרחק:" VerticalAlignment="Center"
                               FontSize="12" Margin="5,0,3,0"
                               Foreground="{StaticResource TextSecBrush}"/>
                    <controls:UpDownTextBox
                             xmlns:controls="clr-namespace:WpfLib.Controls;assembly=WpfLib"
                             Value="{Binding Slop, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Step="1"
                             Width="40" Height="26"
                             FontSize="12"
                             FontFamily="Segoe UI"
                             Foreground="#323130"
                             Background="#FFFFFF"
                             BorderBrush="#EDEBE9"
                             BorderThickness="1"
                             TextAlignment="Center"
                             VerticalContentAlignment="Center"
                             ToolTip="מרחק בין מילים (מקשי ↑↓)"/>
                </StackPanel>

                <!-- [regex palette help toggle] — left side -->
                <ToggleButton DockPanel.Dock="Left"
                              Style="{StaticResource IconToggle}"
                              IsChecked="{Binding ShowRegexPalette}"
                              ToolTip="לוח תווי רג'קס">
                    <Viewbox Width="16" Height="16" FlowDirection="LeftToRight">
                        <Canvas Width="24" Height="24">
                            <Path Fill="{Binding Foreground,
                                      RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                  Data="{StaticResource Icon.Sparkle}"/>
                        </Canvas>
                    </Viewbox>
                </ToggleButton>

            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             FIND CONTAINER  (#search-find-container)
        ══════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="1" Margin="10,8,10,0">

            <!-- input-wrapper: [regex .*] [text fills] [🔍] — LTR DockPanel, absolute dock positions -->
            <Border CornerRadius="4" BorderBrush="#EDEBE9" BorderThickness="1" Background="#FFFFFF" Height="28" Margin="0,0,0,5">
                <DockPanel FlowDirection="LeftToRight">
                    <!-- 🔍 search icon — LEFT side -->
                    <Button DockPanel.Dock="Left"
                            Style="{StaticResource InputIconButton}"
                            Command="{Binding SearchCommand}"
                            ToolTip="חיפוש">
                        <Viewbox Width="16" Height="16" FlowDirection="LeftToRight">
                            <Canvas Width="24" Height="24">
                                <Path Fill="#666666"
                                      Data="{StaticResource Icon.Search}"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <!-- .* regex toggle — LEFT side of the input (HTML: left of text) -->
                    <ToggleButton DockPanel.Dock="Left"
                                  Style="{StaticResource InputIconToggle}"
                                  IsChecked="{Binding UseRegex}"
                                  ToolTip="השתמש בביטויים רגולריים">
                        <Viewbox Width="16" Height="16" FlowDirection="LeftToRight">
                            <Canvas Width="24" Height="24">
                                <Path Fill="#666666"
                                      Data="{StaticResource Icon.Regex}"/>
                            </Canvas>
                        </Viewbox>
                    </ToggleButton>
                    <!-- text fills remaining space -->
                    <ComboBox x:Name="FindCombo"
                              Style="{StaticResource SearchCombo}"
                              FlowDirection="RightToLeft"
                              ItemsSource="{Binding RecentSearches}"
                              ItemTemplate="{StaticResource HistoryItemTemplate}"
                              Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Tag="חיפוש..."
                              ToolTip="חיפוש"
                              GotFocus="FindCombo_GotFocus"
                              KeyDown="FindCombo_KeyDown"/>
                </DockPanel>
            </Border>

            <!-- find-options-wrapper: font-size | B I U x² x₂ | A(color) | clear | copy -->
            <local:FormatOptionsRow
                FontSizeValue="{Binding FindFormatting.FontSize, Mode=TwoWay}"
                Bold="{Binding FindFormatting.Bold, Mode=TwoWay}"
                Italic="{Binding FindFormatting.Italic, Mode=TwoWay}"
                Underline="{Binding FindFormatting.Underline, Mode=TwoWay}"
                Superscript="{Binding FindFormatting.Superscript, Mode=TwoWay}"
                Subscript="{Binding FindFormatting.Subscript, Mode=TwoWay}"
                TextColor="{Binding FindFormatting.TextColor, Mode=TwoWay}"
                ClearCommand="{Binding ClearFindFormattingCommand}"
                CopyCommand="{Binding CopyFindFormattingCommand}"
                Margin="0,0,0,5"/>

            <!-- find-font-style-wrapper: [style combobox] [font combobox] -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding StyleList}"
                          Text="{Binding FindFormatting.StyleName, UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="True" Height="26" FontSize="12"
                          VirtualizingPanel.IsVirtualizing="True"
                          local:PlaceholderBehavior.Placeholder="בחר סגנון"
                          ToolTip="בחר סגנון"
                          GotFocus="StyleCombo_GotFocus"/>
                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding FontList}"
                          Text="{Binding FindFormatting.FontName, UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="True" Height="26" FontSize="12"
                          VirtualizingPanel.IsVirtualizing="True"
                          local:PlaceholderBehavior.Placeholder="בחר גופן"
                          ToolTip="בחר גופן">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2,1">
                                <TextBlock Text="{Binding}" FontSize="12"
                                           FontWeight="Medium"/>
                                <TextBlock Text="ABC abc אבג" FontSize="11"
                                           Opacity="0.6"
                                           FontFamily="{Binding}"
                                           FlowDirection="LeftToRight"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

        </StackPanel>

        <!-- ══════════════════════════════════════════════════════════
             REPLACE CONTAINER (#search-replace-container)
             Hidden by default; shown when ShowReplace = true
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource BgSecBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,8,10,8"
                Visibility="{Binding ShowReplace,
                    Converter={StaticResource BoolToVis}}">
            <StackPanel>

                <!-- input-wrapper: [replace icon] [replace-all icon] [text] -->
                <Border CornerRadius="4" BorderBrush="#EDEBE9" BorderThickness="1" Background="#FFFFFF" Height="28" Margin="0,0,0,5">
                    <DockPanel FlowDirection="LeftToRight">
                        <!-- replace icon — docks Left → appears on LEFT (LTR) = RIGHT in RTL UI -->
                        <Button DockPanel.Dock="Left"
                                Style="{StaticResource InputIconButton}"
                                Command="{Binding ReplaceCommand}"
                                ToolTip="החלף">
                            <Viewbox Width="16" Height="16" FlowDirection="LeftToRight">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="#666666"
                                          Data="{StaticResource Icon.Replace}"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <!-- replace-all icon -->
                        <Button DockPanel.Dock="Left"
                                Style="{StaticResource InputIconButton}"
                                Command="{Binding ReplaceAllCommand}"
                                ToolTip="החלף הכל">
                            <Viewbox Width="16" Height="16" FlowDirection="LeftToRight">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="#666666"
                                          Data="{StaticResource Icon.ReplaceAll}"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <!-- replace text fills remaining space -->
                        <ComboBox x:Name="ReplaceCombo"
                                  Style="{StaticResource SearchCombo}"
                                  FlowDirection="RightToLeft"
                                  ItemsSource="{Binding RecentReplacements}"
                                  ItemTemplate="{StaticResource HistoryItemTemplate}"
                                  Text="{Binding ReplaceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Tag="החלף ב..."
                                  ToolTip="החלף ב.."
                                  GotFocus="ReplaceCombo_GotFocus"
                                  KeyDown="ReplaceCombo_KeyDown"/>
                    </DockPanel>
                </Border>

                <!-- replace-options-wrapper -->
                <local:FormatOptionsRow
                    FontSizeValue="{Binding ReplaceFormatting.FontSize, Mode=TwoWay}"
                    Bold="{Binding ReplaceFormatting.Bold, Mode=TwoWay}"
                    Italic="{Binding ReplaceFormatting.Italic, Mode=TwoWay}"
                    Underline="{Binding ReplaceFormatting.Underline, Mode=TwoWay}"
                    Superscript="{Binding ReplaceFormatting.Superscript, Mode=TwoWay}"
                    Subscript="{Binding ReplaceFormatting.Subscript, Mode=TwoWay}"
                    TextColor="{Binding ReplaceFormatting.TextColor, Mode=TwoWay}"
                    ClearCommand="{Binding ClearReplaceFormattingCommand}"
                    CopyCommand="{Binding CopyReplaceFormattingCommand}"
                    Margin="0,0,0,5"/>

                <!-- replace-font-style-wrapper -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding StyleList}"
                              Text="{Binding ReplaceFormatting.StyleName, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True" Height="26" FontSize="12"
                              VirtualizingPanel.IsVirtualizing="True"
                              local:PlaceholderBehavior.Placeholder="בחר סגנון"
                              ToolTip="בחר סגנון"
                              GotFocus="StyleCombo_GotFocus"/>
                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding FontList}"
                              Text="{Binding ReplaceFormatting.FontName, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True" Height="26" FontSize="12"
                              VirtualizingPanel.IsVirtualizing="True"
                              local:PlaceholderBehavior.Placeholder="בחר גופן"
                              ToolTip="בחר גופן">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2,1">
                                    <TextBlock Text="{Binding}" FontSize="12"
                                               FontWeight="Medium"/>
                                    <TextBlock Text="ABC abc אבג" FontSize="11"
                                               Opacity="0.6"
                                               FontFamily="{Binding}"
                                               FlowDirection="LeftToRight"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             RESULTS CONTAINER (#results-container)
             Fills remaining space. Shows regex palette OR results list.
        ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="3">

            <!-- Regex palette (help toggle on) -->
            <local:RegexPalettePanel
                x:Name="RegexPalette"
                Background="{StaticResource BgSecBrush}"
                Visibility="{Binding ShowRegexPalette,
                    Converter={StaticResource BoolToVis}}"/>

            <!-- Search results list (help toggle off) -->
            <Border Background="{StaticResource BgSecBrush}"
                    Visibility="{Binding ShowRegexPalette,
                        Converter={StaticResource InvBoolToVis}}">
                <Grid>
                    <!-- No-results message — shown when search ran but found nothing -->
                    <TextBlock Text="לא נמצאו תוצאות התואמות לחיפוש"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecBrush}"
                               FontStyle="Italic"
                               FontSize="12"
                               Padding="20"
                               Visibility="{Binding NoResults,
                                   Converter={StaticResource BoolToVis}}"/>

                    <!-- Results list -->
                    <ListBox x:Name="ResultsList"
                             ItemsSource="{Binding Results}"
                             SelectedIndex="{Binding SelectedResultIndex}"
                             ItemContainerStyle="{StaticResource ResultItem}"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="5,3"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             KeyDown="ResultsList_KeyDown"
                             Visibility="{Binding NoResults,
                                 Converter={StaticResource InvBoolToVis}}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <local:SnippetBlock Snippet="{Binding}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

        </Grid>

    </Grid>
</UserControl>
