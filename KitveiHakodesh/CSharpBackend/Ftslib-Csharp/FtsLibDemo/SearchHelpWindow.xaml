<Window x:Class="FtsLibDemo.SearchHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="תחביר חיפוש"
        Width="480" Height="480"
        MinWidth="380" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI"
        FontSize="13"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- Header row style -->
        <Style x:Key="HeaderCell" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>
        <!-- Pattern cell — monospace -->
        <Style x:Key="PatternCell" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas, Courier New"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1A5490"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- Description cell -->
        <Style x:Key="DescCell" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- Alternating row background -->
        <Style x:Key="EvenRow" TargetType="Border">
            <Setter Property="Background" Value="#F7F9FC"/>
        </Style>
        <Style x:Key="OddRow" TargetType="Border">
            <Setter Property="Background" Value="White"/>
        </Style>
    </Window.Resources>

    <Border Background="White">
        <DockPanel Margin="16">

            <!-- Title -->
            <TextBlock DockPanel.Dock="Top"
                       Text="תחביר חיפוש"
                       FontSize="17"
                       FontWeight="SemiBold"
                       Foreground="#1A1A1A"
                       Margin="0,0,0,12"/>

            <!-- Close button -->
            <Button DockPanel.Dock="Bottom"
                    Content="סגור"
                    HorizontalAlignment="Left"
                    Padding="20,6"
                    Margin="0,14,0,0"
                    IsDefault="True"
                    IsCancel="True"
                    Click="CloseButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#2E6DA4"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1A5490"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Syntax table -->
            <ScrollViewer DockPanel.Dock="Top"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- Table header -->
                    <Border Background="#E8EEF5" CornerRadius="4,4,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="תבנית" Style="{StaticResource HeaderCell}"/>
                            <TextBlock Grid.Column="1" Text="משמעות ודוגמה" Style="{StaticResource HeaderCell}"/>
                        </Grid>
                    </Border>

                    <!-- Row 1: wildcard -->
                    <Border Style="{StaticResource OddRow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="*מילה*" Style="{StaticResource PatternCell}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource DescCell}">
                                <Run Text="כוכבית — (לפני או אחרי המילה) תחיליות וסופיות."/>
                                <LineBreak/>
                                <Run Text="דוגמה: " Foreground="#888888"/>
                                <Run Text="ישר*" FontFamily="Consolas, Courier New" Foreground="#1A5490"/>
                                <Run Text=" → ישראל, ישרים…   "/>
                                <Run Text="*לום" FontFamily="Consolas, Courier New" Foreground="#1A5490"/>
                                <Run Text=" → שלום, עולם…"/>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Row 2: optional char -->
                    <Border Style="{StaticResource EvenRow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="מיל?ה" Style="{StaticResource PatternCell}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource DescCell}">
                                <Run Text="שאלתית — (כתיב חסר) התו שלפני הסימן שאלה אופציונלי."/>
                                <LineBreak/>
                                <Run Text="דוגמה: " Foreground="#888888"/>
                                <Run Text="שלו?ם" FontFamily="Consolas, Courier New" Foreground="#1A5490"/>
                                <Run Text=" → שלום או שלם"/>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Row 3: fuzzy -->
                    <Border Style="{StaticResource OddRow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="מילה~" Style="{StaticResource PatternCell}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource DescCell}">
                                <Run Text="טילדה — חיפוש מטושטש, מרחק עריכה 1."/>
                                <LineBreak/>
                                <Run Text="דוגמה: " Foreground="#888888"/>
                                <Run Text="יצחק~" FontFamily="Consolas, Courier New" Foreground="#1A5490"/>
                                <Run Text=" → יצחק, ביצחק, ליצחק…"/>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Row 4: fuzzy distance -->
                    <Border Style="{StaticResource EvenRow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="מילה~2  /  מילה~3" Style="{StaticResource PatternCell}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource DescCell}">
                                <Run Text="טילדה עם מספר — מרחק עריכה מותאם (1–3)."/>
                                <LineBreak/>
                                <Run Text="דוגמה: " Foreground="#888888"/>
                                <Run Text="משה~2" FontFamily="Consolas, Courier New" Foreground="#1A5490"/>
                                <Run Text=" → משה, למשה, ממשה…"/>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Row 5: OR -->
                    <Border Style="{StaticResource OddRow}" CornerRadius="0,0,4,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="א | ב" Style="{StaticResource PatternCell}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource DescCell}">
                                <Run Text="מקף אנכי — OR: מספיק שאחת מהמילים תופיע. ניתן לכתוב עם רווחים או בלעדיהם."/>
                                <LineBreak/>
                                <Run Text="דוגמה: " Foreground="#888888"/>
                                <Run Text="משה | אהרן תורה" FontFamily="Consolas, Courier New" Foreground="#1A5490"/>
                                <Run Text=" → (משה או אהרן) וגם תורה"/>
                                <LineBreak/>
                                <Run Text="דוגמה: " Foreground="#888888"/>
                                <Run Text="משה|אהרן תורה" FontFamily="Consolas, Courier New" Foreground="#1A5490"/>
                                <Run Text=" → זהה לדוגמה למעלה"/>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Divider -->
                    <Border Height="1" Background="#E0E0E0" Margin="0,14,0,10"/>

                    <!-- Notes section header -->
                    <TextBlock Text="הערות נוספות"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#888888"
                               Margin="0,0,0,6"/>

                    <!-- Notes table -->
                    <Border Background="#E8EEF5" CornerRadius="4,4,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="תבנית" Style="{StaticResource HeaderCell}"/>
                            <TextBlock Grid.Column="1" Text="הסבר" Style="{StaticResource HeaderCell}"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource OddRow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="שרשרת OR" Style="{StaticResource PatternCell}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource DescCell}">
                                <Run Text="א | ב | ג תורה" FontFamily="Consolas, Courier New" Foreground="#1A5490"/>
                                <Run Text=" → (א או ב או ג) וגם תורה. השרשרת נשברת כשמילה מופיעה ללא מקף לפניה."/>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource EvenRow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="קבוצות נפרדות" Style="{StaticResource PatternCell}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource DescCell}">
                                <Run Text="א | ב ג | ד" FontFamily="Consolas, Courier New" Foreground="#1A5490"/>
                                <Run Text=" → (א או ב) וגם (ג או ד)."/>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource OddRow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="כוכבית + שאלתית" Style="{StaticResource PatternCell}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource DescCell}">
                                <Run Text="ניתן לשלב באותה מילה, למשל "/>
                                <Run Text="שלו?ם*" FontFamily="Consolas, Courier New" Foreground="#1A5490"/>
                                <Run Text="."/>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource EvenRow}" CornerRadius="0,0,4,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="טילדה + כוכבית" Style="{StaticResource PatternCell}" Foreground="#C0392B"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource DescCell}" Foreground="#C0392B">
                                <Run Text="לא ניתן לשלב — הכוכבית/שאלתית גוברת."/>
                            </TextBlock>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Border>
</Window>
