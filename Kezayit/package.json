{
  "name": "zayit-vue-clean",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --build && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "format": "prettier --write \"src/**/*.{vue,ts}\"",
    "dict:create": "node scripts/dictionary/create-dictionary-db.cjs",
    "dict:import-aramaic": "node scripts/dictionary/import-aramaic.cjs",
    "dict:import-jewishbooks": "node scripts/dictionary/import-jewishbooks-abbrev.cjs",
    "wikidict:create": "node scripts/dictionary/create-wikidictionary-db.cjs",
    "wikidict:fetch": "powershell -ExecutionPolicy Bypass -File scripts/dictionary/fetch-wiktionary-api.ps1",
    "wikidict:import": "node scripts/dictionary/import-wiktionary.cjs",
    "wikidict:netfree": "node scripts/dictionary/add-netfree-flag.cjs",
    "wikidict:netfree-xml": "node scripts/dictionary/netfree-xml-check.cjs"
  },
  "serverDependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "dependencies": {
    "@hebcal/core": "^6.1.0",
    "@hebcal/learning": "^6.8.0",
    "@iconify-prerendered/vue-fluent": "latest",
    "@iconify-prerendered/vue-fluent-color": "latest",
    "@tanstack/vue-virtual": "^3.13.23",
    "@vueuse/core": "^10.0.0",
    "better-sqlite3": "^12.8.0",
    "pinia": "^3.0.3",
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "iconv-lite": "^0.7.2",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.0",
    "vite": "^7.0.0",
    "vite-plugin-singlefile": "^2.3.0",
    "vue-tsc": "^3.1.1"
  }
}
