<Window x:Class="FtsLibDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:FtsLibDemo.ViewModels"
        xmlns:local="clr-namespace:FtsLibDemo"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:MainViewModel}"
        Title="חיפוש בספרים"
        Height="620" Width="390"
        MinHeight="400" MinWidth="320"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI"
        FontSize="14">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InvertBooleanConverter x:Key="InvertBool"/>
        <local:BoolToVisibilityInvertedConverter x:Key="BoolToVisInverted"/>

        <!-- ── Shared styles ─────────────────────────────────────── -->

        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Background" Value="#2E6DA4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A5490"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#AAAAAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#C0392B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#96281B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Result card DataTemplate ─────────────────────────── -->
        <!--
            Each SearchResultItem is rendered as:
              title    (blue, Google-style)
              snippet  (gray, with bold highlights)
            A thin separator line sits below each card.
        -->
        <DataTemplate x:Key="ResultCardTemplate" DataType="{x:Type vm:SearchResultItem}">
            <Border BorderBrush="#EBEBEB" BorderThickness="0,0,0,1"
                    Padding="0,14,0,10">
                <StackPanel>

                    <!-- Title — selectable, blue link style -->
                    <TextBox Text="{Binding BookTitle, Mode=OneTime}"
                             FontSize="18"
                             Foreground="#1A0DAB"
                             TextWrapping="Wrap"
                             Margin="0,0,0,3"
                             IsReadOnly="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0"
                             Cursor="IBeam"/>

                    <!-- Snippet — selectable, with bold highlights via MarkupBehavior.
                         Because TextBox doesn't support Inlines, we layer a transparent
                         selectable TextBox on top of a TextBlock that renders the markup.
                         The TextBox carries the plain text for copying; the TextBlock
                         renders the highlights underneath. -->
                    <Grid>
                        <!-- Rendered highlights (not selectable, but visible) -->
                        <TextBlock FontSize="13"
                                   Foreground="#4D5156"
                                   TextWrapping="Wrap"
                                   LineHeight="20"
                                   local:MarkupBehavior.Text="{Binding Snippet, Mode=OneTime}"/>
                        <!-- Transparent overlay — selectable, carries plain text for copy -->
                        <TextBox FontSize="13"
                                 Foreground="Transparent"
                                 TextWrapping="Wrap"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="0"
                                 Cursor="IBeam"
                                 CaretBrush="#4D5156"
                                 SelectionBrush="#3399FF"
                                 SelectionOpacity="0.35"
                                 Text="{Binding PlainSnippet, Mode=OneTime}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- toolbar -->
            <RowDefinition Height="Auto"/>  <!-- search progress bar -->
            <RowDefinition Height="Auto"/>  <!-- index progress bar -->
            <RowDefinition Height="*"/>     <!-- results -->
            <RowDefinition Height="Auto"/>  <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             Row 0 — Toolbar: search box + buttons
        ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#DDDDDD"
                BorderThickness="0,0,0,1" Padding="10,8">
            <StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Info / syntax help button — circle with "i" -->
                <Button Grid.Column="0"
                        Command="{Binding ShowSyntaxHelpCommand}"
                        ToolTip="תחביר חיפוש"
                        Width="22" Height="22"
                        Margin="0,0,8,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="#2E6DA4"/>
                            <Setter Property="BorderThickness" Value="1.5"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="11"
                                                Width="22" Height="22">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E8F0FA"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <!-- "i" icon: dot + vertical stroke -->
                    <Viewbox Width="10" Height="10" Stretch="Uniform">
                        <Canvas Width="24" Height="24">
                            <!-- dot -->
                            <Ellipse Canvas.Left="10.5" Canvas.Top="3"
                                     Width="3" Height="3"
                                     Fill="#2E6DA4"/>
                            <!-- stem -->
                            <Path Data="M12,9 L12,19"
                                  Stroke="#2E6DA4"
                                  StrokeThickness="2."
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <TextBox Grid.Column="1"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchBoxStyle}"
                         Margin="0,0,8,0">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <!-- Search button — magnifying glass icon -->
                <Button Grid.Column="2"
                        Command="{Binding SearchCommand}"
                        ToolTip="חפש"
                        Style="{StaticResource PrimaryButton}"
                        Width="36" MinWidth="0"
                        Padding="0"
                        Margin="0,0,6,0">
                    <Viewbox Width="16" Height="16" Stretch="Uniform">
                        <Canvas Width="24" Height="24">
                            <!-- lens circle -->
                            <Ellipse Canvas.Left="2" Canvas.Top="2"
                                     Width="14" Height="14"
                                     Stroke="White" StrokeThickness="2"
                                     Fill="Transparent"/>
                            <!-- handle -->
                            <Path Data="M14,14 L21,21"
                                  Stroke="White"
                                  StrokeThickness="2.5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <Button Grid.Column="3"
                        Content="צור אינדקס"
                        Command="{Binding BuildIndexCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,6,0"
                        Visibility="{Binding IsIndexing, Converter={StaticResource BoolToVisInverted}}"/>

                <Button Grid.Column="3"
                        Content="בטל"
                        Command="{Binding CancelIndexCommand}"
                        Style="{StaticResource DangerButton}"
                        Margin="0,0,6,0"
                        Visibility="{Binding IsIndexing, Converter={StaticResource BoolToVis}}"/>
            </Grid>

            <!-- Word distance row -->
            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="מרחק מקסימלי בין מילים:"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="#555555"/>

                <TextBox Grid.Column="1"
                         Width="52"
                         Text="{Binding MaxWordDistance, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchBoxStyle}"
                         TextAlignment="Center"
                         FontSize="13"/>
            </Grid>

            <!-- Order mode row -->
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                <TextBlock Text="סדר מילים:"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="#555555"
                           Margin="0,0,10,0"/>
                <RadioButton Content="לא מסודר"
                             FontSize="12"
                             VerticalContentAlignment="Center"
                             Margin="0,0,14,0"
                             IsChecked="{Binding IsOrderedSearch, Converter={StaticResource InvertBool}}"/>
                <RadioButton Content="לפי סדר השאילתה"
                             FontSize="12"
                             VerticalContentAlignment="Center"
                             IsChecked="{Binding IsOrderedSearch}"/>
            </StackPanel>
        </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             Row 1 — Search progress bar (thin, indeterminate, while searching)
        ═══════════════════════════════════════════════════════════ -->
        <ProgressBar Grid.Row="1"
                     IsIndeterminate="True"
                     Height="3"
                     BorderThickness="0"
                     Foreground="#2E6DA4"
                     Background="Transparent"
                     Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}}"/>

        <!-- ═══════════════════════════════════════════════════════════
             Row 2 — Index progress bar (visible only while indexing)
        ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="#FFFBF0"
                BorderBrush="#F0C040"
                BorderThickness="0,0,0,1"
                Padding="10,6"
                Visibility="{Binding IsIndexing, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Foreground="#7A5800"
                           FontSize="12"
                           Margin="0,0,0,4">
                    <Run Text="{Binding ProgressDetail, Mode=OneWay}"/>
                    <Run Text="  "/>
                    <Run Text="{Binding ElapsedTime, Mode=OneWay}" FontWeight="SemiBold"/>
                    <Run Text="  |  נותר: "/>
                    <Run Text="{Binding EtaText, Mode=OneWay}" FontWeight="SemiBold"/>
                </TextBlock>

                <ProgressBar Grid.Row="1"
                             Value="{Binding IndexProgress, Mode=OneWay}"
                             Minimum="0" Maximum="100"
                             Height="8"
                             Foreground="#2E6DA4"
                             Background="#E0E0E0"
                             BorderThickness="0"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             Row 3 — Results list
        ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Result count header — visible only when there is text -->
            <TextBlock Grid.Row="0"
                       Text="{Binding ResultCountText}"
                       FontSize="13"
                       Foreground="#70757A"
                       Margin="12,10,12,4">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ResultCountText}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ResultCountText}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!--
                ListView with VirtualizingStackPanel (the default panel for ListView).
                Only the visible items are realized as WPF elements — essential for
                large result sets (tens of thousands of rows).
                ScrollUnit=Item gives smooth per-item scrolling.
            -->
            <ListView Grid.Row="1"
                      ItemsSource="{Binding Results}"
                      ItemTemplate="{StaticResource ResultCardTemplate}"
                      BorderThickness="0"
                      Background="Transparent"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      VirtualizingPanel.ScrollUnit="Item"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,0,40">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="12,0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <!-- Remove the default focus/selection highlight -->
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             Row 4 — Status bar
        ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4"
                Background="#EEEEEE"
                BorderBrush="#DDDDDD"
                BorderThickness="0,1,0,0"
                Padding="10,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           Foreground="#444444"
                           VerticalAlignment="Center"
                           FontSize="12"/>

                <TextBlock Grid.Column="1"
                           Foreground="#888888"
                           FontSize="11"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IndexedDbPath}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    <Run Text="DB: "/>
                    <Run Text="{Binding IndexedDbPath, Mode=OneWay}"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
