fice/word/2020/wordml/sdtdatahash" xmlns:w16sdtfl="http://schemas.microsoft.com/office/word/2024/wordml/sdtformatlock" xmlns:w16se="http://schemas.microsoft.com/office/word/2015/wordml/symex" xmlns:wpg="http://schemas.microsoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" mc:Ignorable="w14 w15 w16se w16cid w16 w16cex w16sdtdh w16sdtfl w16du wp14"><w:body><w:p w14:paraId="37681246" w14:textId="2F314029" w:rsidR="000D30B5" w:rsidRPr="00C06EE9" w:rsidRDefault="000D30B5" w:rsidP="00C06EE9"><w:pPr><w:pStyle w:val="a3"/><w:spacing w:line="500" w:lineRule="exact"/><w:jc w:val="center"/><w:rPr><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rStyle w:val="ae"/><w:rFonts w:cs="Guttman Mantova" w:hint="cs"/><w:b w:val="0"/><w:bCs w:val="0"/><w:sz w:val="64"/><w:szCs w:val="64"/><w:rtl/></w:rPr><w:t>סיפור ההגדה כפשוטו</w:t></w:r></w:p><w:p w14:paraId="5344BD74" w14:textId="202B0746" w:rsidR="000D30B5" w:rsidRPr="00C06EE9" w:rsidRDefault="00C06EE9" w:rsidP="00C06EE9"><w:pPr><w:pStyle w:val="a5"/><w:jc w:val="center"/><w:rPr><w:rFonts w:hint="cs"/><w:sz w:val="34"/><w:szCs w:val="34"/><w:rtl/></w:rPr><w:sectPr w:rsidR="000D30B5" w:rsidRPr="00C06EE9" w:rsidSect="000D30B5"><w:pgSz w:w="12240" w:h="15840"/><w:pgMar w:top="1440" w:right="1440" w:bottom="1440" w:left="1440" w:header="720" w:footer="720" w:gutter="0"/><w:pgBorders w:offsetFrom="page"><w:top w:val="whiteFlowers" w:sz="24" w:space="24" w:color="4472C4" w:themeColor="accent1"/><w:left w:val="whiteFlowers" w:sz="24" w:space="24" w:color="4472C4" w:themeColor="accent1"/><w:bottom w:val="whiteFlowers" w:sz="24" w:space="24" w:color="4472C4" w:themeColor="accent1"/><w:right w:val="whiteFlowers" w:sz="24" w:space="24" w:color="4472C4" w:themeColor="accent1"/></w:pgBorders><w:cols w:space="720"/><w:bidi/><w:docGrid w:linePitch="360"/></w:sectPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:sz w:val="34"/><w:szCs w:val="34"/></w:rPr><w:t xml:space="preserve"> </w:t></w:r><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rFonts w:hint="cs"/><w:sz w:val="34"/><w:szCs w:val="34"/></w:rPr><w:sym w:font="Wingdings 2" w:char="F068"/></w:r><w:r w:rsidR="000D30B5" w:rsidRPr="00C06EE9"><w:rPr><w:rFonts w:hint="cs"/><w:sz w:val="34"/><w:szCs w:val="34"/><w:rtl/></w:rPr><w:t>סיפור ההגדה מתוך ההגדה</w:t></w:r><w:r w:rsidR="004F3560" w:rsidRPr="00C06EE9"><w:rPr><w:rFonts w:hint="cs"/><w:sz w:val="34"/><w:szCs w:val="34"/><w:rtl/></w:rPr><w:t xml:space="preserve"> עצמה</w:t></w:r><w:r w:rsidRPr="00C06EE9"><w:rPr><w:sz w:val="34"/><w:szCs w:val="34"/></w:rPr><w:t xml:space="preserve"> </w:t></w:r><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rFonts w:hint="cs"/><w:sz w:val="34"/><w:szCs w:val="34"/></w:rPr><w:sym w:font="Wingdings 2" w:char="F067"/></w:r><w:r w:rsidRPr="00C06EE9"><w:rPr><w:sz w:val="34"/><w:szCs w:val="34"/></w:rPr><w:t xml:space="preserve"> </w:t></w:r></w:p><w:p w14:paraId="115C1510" w14:textId="3431571E" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="0064090A" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr><w:t xml:space="preserve">מתחילה עבודי עבודה זרה היו אבותינו ועכשיו קרבנו המקום לעבודתו. שנאמר וכו' ואקח את אביכם וכו' מעבר הנהר וכו' ואתן לו את יצחק וכו' ויעקב ובניו ירדו מצרימה. </w:t></w:r></w:p><w:p w14:paraId="78002FDF" w14:textId="10A47D00" w:rsidR="00F516A6" w:rsidRPr="00C06EE9" w:rsidRDefault="00F516A6" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t xml:space="preserve">בתחילה לא היה את עם ישראל בעולם, לא היה עם שתפקידו היה לעבוד את ה', אלא כל אחד או שעבד את ה' או שלא. הקב"ה רצה שיהיה עם ישראל עם המיוחד לעבודתו, ולכן הוא לקח את אברהם אבינו מעבר הנהר לארץ ישראל, כדי ששם יוכל לבנות את עם ישראל. אברהם אבינו לבד לא יכל לבנות את עם ישראל ולכן ה' </w:t></w:r><w:r w:rsidRPr="00C06EE9"><w:rPr><w:b/><w:bCs/><w:rtl/></w:rPr><w:t xml:space="preserve">נתן </w:t></w:r><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>לו את יצחק, וליצחק הוא נתן את יעקב ועשיו. עשיו לא רצה להיות חלק מעם ישראל הוא עזב את ארץ ישראל וה' נתן לו את הר שעיר. ויעקב ובניו הם אלה שירדו למצרים.</w:t></w:r></w:p><w:p w14:paraId="2A4C57F3" w14:textId="0D4415EA" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="0064090A" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr><w:t xml:space="preserve">ברוך שומר הבטחתו וכו' שהקב"ה חישב את הקץ לעשות כמה שאמר לאברהם אבינו בברית בין הבתרים וכו'. </w:t></w:r></w:p><w:p w14:paraId="7B073FE8" w14:textId="1E2C7334" w:rsidR="00F516A6" w:rsidRPr="00C06EE9" w:rsidRDefault="00F516A6" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>כאן הבן שואל, ואם איננו יודע לשאול את פתח לו: אם ה' לקח את אברהם אבינו לארץ ישראל כדי שיוכל לבנות את עם ישראל למה הוא הוריד אותם למצרים?</w:t></w:r></w:p><w:p w14:paraId="16968A14" w14:textId="69B99B13" w:rsidR="00F516A6" w:rsidRPr="00C06EE9" w:rsidRDefault="00F516A6" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>ועל כך באה התשובה שכל זה היה בגלל ההבטחה של הקב"ה אברהם אבינו בברית בין הבתרים שככה ייבנה עם ישראל על ידי הירידה למצרים.</w:t></w:r></w:p><w:p w14:paraId="2FDE05D4" w14:textId="08095AD9" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="0064090A" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr><w:t xml:space="preserve">והיא שעמדה לאבותינו ולנו וכו' שלא אחד בלבד עמד עלינו לכלותינו וכו' צא ומד מה ביקש לבן הארמי לעשות וכו'. </w:t></w:r></w:p><w:p w14:paraId="3C15AB92" w14:textId="77777777" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="00F516A6" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>הבטחה זו יצאה לפועל עוד טרם ירדנו למצרים (וגם אח"כ לאורך כל הדורות)</w:t></w:r><w:r w:rsidR="00BE3E9F" w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>. לבן הארמי כבר רצה לעקור את הכל – שלא יהיה שום עם ישראל, והקב"ה הוא זה שמציל אותנו מידם, והכל מכח הבטחה זו.</w:t></w:r></w:p><w:p w14:paraId="6120B46F" w14:textId="1BF90A87" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="0064090A" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr><w:t xml:space="preserve">וירד מצרימה אנוס על פי הדיבור, ויגר שם מלמד שלא ירד יעקב אבינו להשתקע שם וכו'  </w:t></w:r></w:p><w:p w14:paraId="0D970AC3" w14:textId="77777777" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="00BE3E9F" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>יעקב אבינו ירד למצריים כדי לקיים את ההבטחה שה' אמר לאברהם בברית בין הבתרים, לא מסיבות חיצוניות כלשהם, ולכן הוא רק ירד "לגור" שם ולא להשתקע שם.</w:t></w:r></w:p><w:p w14:paraId="2DB9C94F" w14:textId="69EEEA15" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="0064090A" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr><w:t xml:space="preserve">ויגר שם במתי מעט וכו' ועתה שמך וכו' ויהי שם לגוי וכו'. </w:t></w:r></w:p><w:p w14:paraId="581D9689" w14:textId="77777777" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="00BE3E9F" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>יעקב ובניו היו גרים במצרים ומעטים – שבעים נפש, והקב"ה הוא זה שברך אותם בכל מיני ברכה של ריבוי, ובצורה פלאית נהיו לגוי גדול עצום ורב, ובמהירות גדולה מאוד.</w:t></w:r></w:p><w:p w14:paraId="408AE976" w14:textId="76849A3A" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="0064090A" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr><w:t xml:space="preserve">וירעו אותנו המצרים וכו', פן ירבה והיה כי תקראנה מלחמה וכו' ויענונו וכו' ויתנו עלינו עבודה קשה וכו' </w:t></w:r></w:p><w:p w14:paraId="03707F0B" w14:textId="0C0F4306" w:rsidR="00BE3E9F" w:rsidRPr="00C06EE9" w:rsidRDefault="00BE3E9F" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t xml:space="preserve">המצרים ראו שעם ישראל מתרבים והם התחילו לשנוא אותנו, ולהעליל עלינו עלילות, </w:t></w:r><w:r w:rsidR="00B936A1" w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>ולשעבד אותנו כדי שלא נתרבה עוד. בתחילה במסווה של מיסים, ולבסוף בעבודה קשה ומפרכת.</w:t></w:r></w:p><w:p w14:paraId="222FD4B4" w14:textId="4716D456" w:rsidR="00B936A1" w:rsidRPr="00C06EE9" w:rsidRDefault="00B936A1" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>ונצעק אל ה' וכו' וירא ענינו וכו'.</w:t></w:r></w:p><w:p w14:paraId="5B1EFB4B" w14:textId="77777777" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="00B936A1" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t xml:space="preserve">היהודים התפללו לה' שלא יעזוב אותם. ואז כאשר הם צעקו, הקב"ה הביט על כל מה שהמצרים עושים להם מתוך שנאה, ועל כל האכזריות והרוע העשוי להם. </w:t></w:r></w:p><w:p w14:paraId="3A8F0985" w14:textId="0224DC2A" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="0064090A" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr><w:t xml:space="preserve">ויוציאנו ה' וכו' הקב"ה בכבודו ובעצמו וכו' אני הוא ולא אחר. </w:t></w:r></w:p><w:p w14:paraId="35752753" w14:textId="77777777" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="00B936A1" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t xml:space="preserve">ה' היה יכול לשלוח מלאך או שרף לשרוף ולכלות את מצרים או כל שליח אחר – אם המטרה היתה רק כדי להציל את היהודים. אבל ה' רצה לקחת את עם ישראל שיהיו לו לעם ולכן הוא בכבודו ובעצמו </w:t></w:r><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:lastRenderedPageBreak/><w:t>התגלה בתוך מצרים כדי להוציא את בני ישראל ממצרים.</w:t></w:r></w:p><w:p w14:paraId="008E1728" w14:textId="4E9B4364" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="0064090A" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr><w:t xml:space="preserve">ביד חזקה זה הדבר וכו' בזרוע נטויה זו החרב וכו' ובמורא גדול זו גילוי שכינה וכו' ובאותות זה המטה וכו' ובמופתים זה הדם וכו'. </w:t></w:r></w:p><w:p w14:paraId="41CE7F2A" w14:textId="77777777" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="00D410CA" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t xml:space="preserve">הקב"ה לא רק שהתגלה במצרים כדי להוציא את בני ישראל משם, אלא אף התגלה בגילויים שונים כדי </w:t></w:r><w:r w:rsidR="00B936A1" w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>לקרבם אליו. א</w:t></w:r><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>'</w:t></w:r><w:r w:rsidR="00B936A1" w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t xml:space="preserve"> – במכת דבר </w:t></w:r><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>הקב"ה גילה</w:t></w:r><w:r w:rsidR="00B936A1" w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t xml:space="preserve"> את ידו החזקה שהחיים עצמם בידו הם. ב</w:t></w:r><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>'</w:t></w:r><w:r w:rsidR="00B936A1" w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t xml:space="preserve"> </w:t></w:r><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>–</w:t></w:r><w:r w:rsidR="00B936A1" w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t xml:space="preserve"> </w:t></w:r><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>הקב"ה גילה את זרועו הנטויה על פני כל הארצות, לנקום את נקמת בני ישראל ממצרים (חרב נוקמת נקם ברית). ג' – הקב"ה התגלה להוציא את בני ישראל באופן גלוי וישיר. ד' – ה' נתן בידו של משה את המטה להראות שהוא המשיל אותו על כל הבריאה ועל פרעה. ה' – הקב"ה עשה מופתים ושינה את טבע העולם ומן המים נעשה דם.</w:t></w:r></w:p><w:p w14:paraId="71178F30" w14:textId="6A726661" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="0064090A" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr><w:t xml:space="preserve">דבר אחר וכו' אלו עשר המכות וכו' דם צפרדע וכו' </w:t></w:r></w:p><w:p w14:paraId="2808DD06" w14:textId="77777777" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="00D410CA" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>מלבד הגילויים הכלליים הרמוזים בפסוק זה רמוזים בו גם הפרטים של עשר המכות שה' עשה במצרים.</w:t></w:r></w:p><w:p w14:paraId="23BF6476" w14:textId="29F145A0" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="0064090A" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr><w:t xml:space="preserve">רבי יהודה היה נותן בהם סימנים וכו'  </w:t></w:r></w:p><w:p w14:paraId="53FBD565" w14:textId="77777777" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="00D410CA" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t xml:space="preserve">המכות באו בסדרות של שלוש </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>שלוש</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>.</w:t></w:r></w:p><w:p w14:paraId="73B731E6" w14:textId="7713F71C" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="0064090A" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr><w:t xml:space="preserve">רבי יוסי הגלילי אומר וכו' ועל הים לקו חמישים מכות וכו' במצרים וכו' אצבע אלוקים וכו' ועל הים וכו' היד הגדולה וכו'  </w:t></w:r></w:p><w:p w14:paraId="6780501B" w14:textId="77777777" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="00D410CA" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>קריעת ים סוף היה המשך והשלמה לגילויים שהיו במצריים. במצרים התגלה לעין כל שהקב"ה יש לו כח בבריאה ברם עדיין אמרו המצרים שזהו כמו אצבע שיש בכחה להניד דבר ממקומו, אך לא שליטה מלאה. ועל הים השולם הגילוי ש</w:t></w:r><w:r w:rsidR="005C3B2A" w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>הכל בידו יתברך.</w:t></w:r></w:p><w:p w14:paraId="0341B192" w14:textId="7F367701" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="0064090A" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr><w:t xml:space="preserve">רבי אליעזר אומר וכו' שכל מכה וכו' היתה של ארבע מכות וכו' רבי עקיבא אומר וכו' של חמש מכות וכו' </w:t></w:r></w:p><w:p w14:paraId="23C793F1" w14:textId="77777777" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="005C3B2A" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>כמו אדם המכה את חבירו במקל מלבד המכה עצמה יש גם את הצער היוצא מתוך המכה ואת שאר ההשפעות שיש למכה זו על האדם. כך גם בעשרת המכות כל מכה כלולה בתוכה כמה מכות.</w:t></w:r></w:p><w:p w14:paraId="4FBA5B6F" w14:textId="408E07A1" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="0064090A" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr><w:t xml:space="preserve">כמה מעלות טובות למקום עלינו וכו' אילו וכו' דיינו וכו'. </w:t></w:r></w:p><w:p w14:paraId="44DFE709" w14:textId="0C23AD41" w:rsidR="005C3B2A" w:rsidRPr="00C06EE9" w:rsidRDefault="005C3B2A" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>כל הדברים שהקב"ה עשה בשבילנו מרוב אהבתו אלינו בהעלותו אותנו ממצרים לארץ ישראל. היהודים לא רק יצאו ממצרים אלא עלו ועלו עד שהגיעו לבנים בית הבחירה – המקום שבו הקב"ה בחר להשכין את שכינתו בינינו.</w:t></w:r></w:p><w:p w14:paraId="5839E881" w14:textId="77777777" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="005C3B2A" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>דיינו – כלומר היה בכך די הצורך שנתחייב להודות לה'.</w:t></w:r></w:p><w:p w14:paraId="64B0C909" w14:textId="3A833FF8" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="0064090A" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr><w:t xml:space="preserve">רבן גמליאל אומר כל שלא אמר שלושה דברים אלו בפסח לא יצא ידי חובתו. פסח מצה ומרור וכו' על שום שפסח וכו' על שום שלא הספיק בצקם וכו' להחמיץ וכו' על שום שמררו המצרים את חיי אבותינו וכו'. </w:t></w:r></w:p><w:p w14:paraId="5DE1013B" w14:textId="77777777" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="005C3B2A" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t xml:space="preserve">צריך להזכיר שלושה עניינים אלו בפה. עניין הפסח, כיצד ה' התגלה במצרים, והציל אותנו אליו. עניין המצה שלא יצאנו ממצרים בכחות עצמנו אלא גורשנו משם במהרה ברצות ה' לגאלנו, עניין המרור </w:t></w:r><w:r w:rsidR="00755DC1" w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t>לזכור שהשעבוד והמרור היה בהשגחה לטובתנו.</w:t></w:r></w:p><w:p w14:paraId="280E772F" w14:textId="40998DC8" w:rsidR="0064090A" w:rsidRPr="00C06EE9" w:rsidRDefault="0064090A" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rStyle w:val="ae"/><w:rtl/></w:rPr><w:t xml:space="preserve">בכל דור ודור חייב אדם לראות את עצמו כאילו הוא יצא ממצרים וכו'  </w:t></w:r></w:p><w:p w14:paraId="255B9E6C" w14:textId="73FD893B" w:rsidR="00B936A1" w:rsidRPr="00C06EE9" w:rsidRDefault="00755DC1" w:rsidP="00C06EE9"><w:pPr><w:rPr><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t xml:space="preserve">שכן היציאה לא היתה רק נס הצלה עבור אבותינו אלא בשבילנו היה בשביל עם ישראל שבכל דור ודור להיות בני ישראל בחיריו. לפיכך חייבים </w:t></w:r><w:r w:rsidRPr="00C06EE9"><w:rPr><w:b/><w:bCs/><w:rtl/></w:rPr><w:t>אנחנו</w:t></w:r><w:r w:rsidRPr="00C06EE9"><w:rPr><w:rtl/></w:rPr><w:t xml:space="preserve"> להודות וכו'.</w:t></w:r></w:p><w:p w14:paraId="7173232A" w14:textId="77777777" w:rsidR="00B936A1" w:rsidRPr="00B936A1" w:rsidRDefault="00B936A1" w:rsidP="00C06EE9"/><w:sectPr w:rsidR="00B936A1" w:rsidRPr="00B936A1" w:rsidSect="000D30B5"><w:type w:val="continuous"/><w:pgSz w:w="12240" w:h="15840"/><w:pgMar w:top="1440" w:right="1440" w:bottom="1440" w:left="1440" w:header="720" w:footer="720" w:gutter="0"/><w:pgBorders w:offsetFrom="page"><w:top w:val="whiteFlowers" w:sz="24" w:space="24" w:color="4472C4" w:themeColor="accent1"/><w:left w:val="whiteFlowers" w:sz="24" w:space="24" w:color="4472C4" w:themeColor="accent1"/><w:bottom w:val="whiteFlowers" w:sz="24" w:space="24" w:color="4472C4" w:themeColor="accent1"/><w:right w:val="whiteFlowers" w:sz="24" w:space="24" w:color="4472C4" w:themeColor="accent1"/></w:pgBorders><w:cols w:num="2" w:space="720"/><w:bidi/><w:docGrid w:linePitch="360"/></w:sectPr></w:body></w:document>
