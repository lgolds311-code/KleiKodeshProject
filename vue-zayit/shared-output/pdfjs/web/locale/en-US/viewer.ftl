# LOCALIZATION NOTE (pdfjs-find-match-count): The supported plural forms are
# [one|two|few|many|other], with [other] as the default value.
# "{{current}}" and "{{total}}" will be replaced by a number representing the
# index of the currently active find result, respectively a number representing
# the total number of matches in the document.
pdfjs-find-match-count =
    { $total ->
        [one] {{current}} of {{total}} match
       *[other] {{current}} of {{total}} matches
    }
# LOCALIZATION NOTE (pdfjs-find-match-count-limit): The supported plural forms are
# [zero|one|two|few|many|other], with [other] as the default value.
# "{{limit}}" will be replaced by a numerical limit.
pdfjs-find-match-count-limit =
    { $limit ->
        [zero] More than {{limit}} matches
        [one] More than {{limit}} match
       *[other] More than {{limit}} matches
    }
pdfjs-find-not-found = Phrase not found

